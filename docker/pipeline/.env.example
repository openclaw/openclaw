# === PostgreSQL ===
POSTGRES_DB=openclaw_pipeline
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_PORT=5432

# === OpenClaw Gateway ===
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan

# Compose builds from repo root; local dev can also point at a pre-built image.
# OPENCLAW_IMAGE=openclaw:local

# === AWS / S3 Backup ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BACKUP_BUCKET=my-openclaw-backups

# Daily at 03:00 UTC (cron expression for backup sidecar)
BACKUP_CRON=0 3 * * *
BACKUP_RETAIN_DAYS=30
