+        agents: {
+          defaults: {
+            imageModel: {},
+          },
+        },
+      },
+    });
+
+    expect(result).toBe(false);
+  });
+
+  it("returns false when imageModel.primary is empty string", () => {
+    const result = shouldUseImagePreAnalysis({
+      config: {
+        agents: {
+          defaults: {
+            imageModel: {
+              primary: "   ",
+            },
+          },
+        },
+      },
+    });
+
+    expect(result).toBe(false);
