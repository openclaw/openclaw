+    env: params.env,
+    agentDirs: ["/tmp/openclaw-agent-main"],
+    loadAuthStore: () => ({ version: 1, profiles: {} }),
+  });
+  secretsRuntime.activateSecretsRuntimeSnapshot(snapshot);
