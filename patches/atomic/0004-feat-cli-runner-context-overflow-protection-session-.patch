+  });
+
+  it("returns undefined when no local or auth-profile credentials exist", async () => {
+    setCliAuthEpochTestDeps({
+      readClaudeCliCredentialsCached: () => null,
+      readCodexCliCredentialsCached: () => null,
+      loadAuthProfileStoreForRuntime: () => ({
+        version: 1,
+        profiles: {},
+      }),
