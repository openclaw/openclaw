+                  workspaceDir,
+                  config: params.config,
+                  defaultThinkLevel: params.thinkLevel,
+                  extraSystemPrompt,
+                  skillsPrompt,
+                  ownerNumbers: params.ownerNumbers,
+                  heartbeatPrompt,
+                  docsPath: docsPath ?? undefined,
