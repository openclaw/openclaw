+import path from "node:path";
+import { shouldLogVerbose } from "../../globals.js";
+import { isTruthyEnvValue } from "../../infra/env.js";
+import { requestHeartbeatNow as requestHeartbeatNowImpl } from "../../infra/heartbeat-wake.js";
