+          // /stop fired during /compact — don't swallow the abort into a
+          // profile-downgrade retry; propagate so the outer catch recognises
+          // it as a user abort.
+          if (compactErr instanceof Error && compactErr.name === "AbortError") {
+            throw compactErr;
+          }
