Environment=GEMINI_API_KEY=AIzaSyA2rEvczNGcf5FhScyVpOma57pqQghPEkg
Environment=NODE_ENV=production
Environment=OPENCLAW_STATE_DIR=/home/vova/OpenPro/workspace
