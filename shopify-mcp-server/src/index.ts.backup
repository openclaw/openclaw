// ============= GRAPHQL TOOLS =============

server.tool(
  "custom-graphql-query",
  "Execute custom GraphQL query against Shopify Admin API",
  {
    query: z.string().describe("GraphQL query string"),
    variables: z.record(z.any()).optional().describe("Query variables"),
  },
  async ({ query, variables }) => {
    const client = new ShopifyClient();
    try {
      const result = await client.shopifyGraphqlRequest({
        url: `https://${MYSHOPIFY_DOMAIN}/admin/api/2024-04/graphql.json`,
        accessToken: SHOPIFY_ACCESS_TOKEN,
        query,
        variables,
      });

      return {
        content: [{ type: "text", text: JSON.stringify(result.data, null, 2) }],
      };
    } catch (error) {
      return handleError("Failed to execute GraphQL query", error);
    }
  }
);

/**
 * Utility function to handle errors consistently
 */
function handleError(
  defaultMessage: string,
  error: unknown
): {
  content: { type: "text"; text: string }[];
  isError: boolean;
} {
  let errorMessage = defaultMessage;
  if (error instanceof CustomError) {
    errorMessage = `${defaultMessage}: ${error.message}`;
  }
  return {
    content: [{ type: "text", text: errorMessage }],
    isError: true,
  };
}

/**
 * Set up resource handlers
 */
function setupResourceHandlers() {
  // List available resources
  server.setRequestHandler(ListResourcesRequestSchema, async () => {
    return {
      resources: [
        {
          uri: "shopify://store/info",
          name: "Store Information",
          description: "Current Shopify store configuration and details",
          mimeType: "application/json",
        },
        {
          uri: "shopify://products/catalog",
          name: "Product Catalog",
          description: "Complete product catalog with variants and inventory",
          mimeType: "application/json",
        },
        {
          uri: "shopify://orders/recent",
          name: "Recent Orders",
          description: "Recent orders from the Shopify store",
          mimeType: "application/json",
        },
      ],
    };
  });

  // Read specific resources
  server.setRequestHandler(ReadResourceRequestSchema, async (request) => {
    const { uri } = request.params;
    const client = new ShopifyClient(MYSHOPIFY_DOMAIN, SHOPIFY_ACCESS_TOKEN);

    try {
      let content = "";
      
      switch (uri) {
        case "shopify://store/info":
          const shopInfo = await client.getShopDetails();
          content = JSON.stringify(shopInfo, null, 2);
          break;
          
        case "shopify://products/catalog":
          const products = await client.getProducts({ first: 50 });
          content = JSON.stringify(products, null, 2);
          break;
          
        case "shopify://orders/recent":
          const orders = await client.getOrders({ first: 20 });
          content = JSON.stringify(orders, null, 2);
          break;
          
        default:
          throw new Error(`Unknown resource: ${uri}`);
      }

      return {
        contents: [
          {
            uri,
            mimeType: "application/json",
            text: content,
          },
        ],
      };
    } catch (error) {
      throw new Error(`Failed to read resource ${uri}: ${error instanceof Error ? error.message : String(error)}`);
    }
  });
}

/**
 * Set up prompt handlers
 */
function setupPromptHandlers() {
  // List available prompts
  server.setRequestHandler(ListPromptsRequestSchema, async () => {
    return {
      prompts: [
        {
          name: "analyze-sales",
          description: "Analyze sales data and provide insights",
          arguments: [
            {
              name: "timeframe",
              description: "Time period to analyze (e.g., 'last-30-days', 'last-quarter')",
              required: true,
            },
          ],
        },
        {
          name: "product-recommendations",
          description: "Get product recommendations based on criteria",
          arguments: [
            {
              name: "category",
              description: "Product category to focus on",
              required: false,
            },
            {
              name: "priceRange",
              description: "Price range (e.g., '10-50')",
              required: false,
            },
          ],
        },
        {
          name: "inventory-status",
          description: "Check inventory status and low stock items",
          arguments: [],
        },
      ],
    };
  });

  // Get specific prompt
  server.setRequestHandler(GetPromptRequestSchema, async (request) => {
    const { name, arguments: args } = request.params;
    const client = new ShopifyClient(MYSHOPIFY_DOMAIN, SHOPIFY_ACCESS_TOKEN);

    try {
      let messages = [];
      
      switch (name) {
        case "analyze-sales":
          const timeframe = args?.timeframe || "last-30-days";
          messages = [
            {
              role: "user" as const,
              content: {
                type: "text" as const,
                text: `Please analyze the sales data for ${timeframe} and provide insights on top performing products, revenue trends, and customer patterns.`,
              },
            },
          ];
          break;
          
        case "product-recommendations":
          const category = args?.category || "all";
          const priceRange = args?.priceRange || "all";
          messages = [
            {
              role: "user" as const,
              content: {
                type: "text" as const,
                text: `Based on the current inventory, recommend products${category !== "all" ? ` in the ${category} category` : ""}${priceRange !== "all" ? ` within the price range ${priceRange}` : ""} that would be good to promote.`,
              },
            },
          ];
          break;
          
        case "inventory-status":
          messages = [
            {
              role: "user" as const,
              content: {
                type: "text" as const,
                text: "Check the current inventory status and identify any products that are low in stock or need restocking.",
              },
            },
          ];
          break;
          
        default:
          throw new Error(`Unknown prompt: ${name}`);
      }

      return {
        description: `Prompt for ${name}`,
        messages,
      };
    } catch (error) {
      throw new Error(`Failed to get prompt ${name}: ${error instanceof Error ? error.message : String(error)}`);
    }
  });
}

/**
 * Main server initialization
 */
async function main() {
  // Set up handlers
  setupResourceHandlers();
  setupPromptHandlers();
  
  // Connect transport
  const transport = new StdioServerTransport();
  await server.connect(transport);
  console.error("Shopify Admin MCP Server running on stdio");
}

main().catch((error) => {
  console.error("Fatal error in main():", error);
  process.exit(1);
});
