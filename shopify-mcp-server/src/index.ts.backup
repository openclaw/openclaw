    author: z.string().optional().describe("New author of the page"),
    published: z.boolean().optional().describe("Whether the page is published"),
    templateSuffix: z.string().optional().describe("New template suffix for the page"),
  },
  async ({ id, title, bodyHtml, handle, summaryBody, author, published, templateSuffix }) => {
    const client = new ShopifyClient();
    try {
      const pageData = {
        id,
