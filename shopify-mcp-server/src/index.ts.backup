    name: z.string().describe("Name of the new theme"),
    src: z.string().optional().describe("URL to ZIP file containing theme"),
    role: z.enum(["main", "unpublished"]).optional().describe("Role of the theme"),
  },
  async ({ name, src, role }) => {
    const client = new ShopifyClient();
    try {
      const themeData = { name, src, role };
      const theme = await client.createTheme(SHOPIFY_ACCESS_TOKEN, MYSHOPIFY_DOMAIN, themeData);
      return {
        content: [{ type: "text", text: JSON.stringify(theme, null, 2) }],
      };
    } catch (error) {
      return handleError("Failed to create theme", error);
    }
  }
);

