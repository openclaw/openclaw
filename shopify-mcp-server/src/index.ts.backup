server.tool(
  "create-page",
  "Create a new page in the store",
  {
    title: z.string().describe("Title of the page"),
    bodyHtml: z.string().describe("HTML content of the page"),
    handle: z.string().optional().describe("URL handle for the page"),
    summaryBody: z.string().optional().describe("Summary of the page"),
    author: z.string().optional().describe("Author of the page"),
    published: z.boolean().optional().default(true).describe("Whether the page is published"),
    templateSuffix: z.string().optional().describe("Template suffix for the page"),
  },
  async ({ title, bodyHtml, handle, summaryBody, author, published, templateSuffix }) => {
    const client = new ShopifyClient();
    try {
      const pageData = {
        title,
        body_html: bodyHtml,
        handle,
        summary_body: summaryBody,
        author,
        published,
        template_suffix: templateSuffix,
      };
      const page = await client.createPage(SHOPIFY_ACCESS_TOKEN, MYSHOPIFY_DOMAIN, pageData);
      return {
        content: [{ type: "text", text: JSON.stringify(page, null, 2) }],
      };
    } catch (error) {
      return handleError("Failed to create page", error);
    }
  }
);

