## **Error Handling & Recovery**

### **Robust Error Management**
```javascript
// ✅ DO: Implement comprehensive error handling
async function updateInventoryWithRetry(variantId, quantity, maxRetries = 3) {
  for (let attempt = 1; attempt <= maxRetries; attempt++) {
    try {
      const result = await updateInventory(variantId, quantity);
      console.log(`✅ Success: Updated ${variantId} to ${quantity} pieces`);
      return result;
    } catch (error) {
      console.warn(`⚠️ Attempt ${attempt}/${maxRetries} failed: ${error.message}`);
      
      if (attempt === maxRetries) {
        console.error(`❌ Final attempt failed for ${variantId}`);
        throw error;
      }
      
      // ✅ DO: Implement exponential backoff
      await new Promise(resolve => setTimeout(resolve, 1000 * attempt));
    }
  }
}
```

### **Rate Limiting & Performance**
```javascript
// ✅ DO: Respect Shopify API limits
const RATE_LIMIT_DELAY = 100; // milliseconds between requests

async function processWithRateLimit(items, processor) {
  const results = [];
  
  for (const [index, item] of items.entries()) {
    try {
      const result = await processor(item);
      results.push({ success: true, item, result });
      
      // ✅ DO: Add delay between requests
      if (index < items.length - 1) {
        await new Promise(resolve => setTimeout(resolve, RATE_LIMIT_DELAY));
      }
    } catch (error) {
      console.error(`❌ Error processing ${item}:`, error.message);
      results.push({ success: false, item, error });
    }
  }
  
  return results;
}
```

## **Data Validation Patterns**

### **CSV Data Validation**
```javascript
// ✅ DO: Validate data structure before processing
function validateInventoryData(csvData) {
  const validation = {
    valid: true,
    errors: [],
    summary: {
      totalProducts: 0,
      totalVariants: 0,
      totalPieces: 0
    }
  };
  
  const productGroups = csvData.reduce((groups, row) => {
    const productHandle = row['Product Handle'];
    if (!groups[productHandle]) groups[productHandle] = [];
    groups[productHandle].push(row);
    return groups;
  }, {});
  
  // ✅ DO: Validate each product structure
  Object.entries(productGroups).forEach(([handle, variants]) => {
    if (variants.length !== 6) {
      validation.errors.push(`${handle}: Expected 6 variants, found ${variants.length}`);
      validation.valid = false;
    }
    
    const totalQuantity = variants.reduce((sum, v) => sum + parseInt(v.Quantity || 0), 0);
    if (totalQuantity !== 300) {
      validation.errors.push(`${handle}: Expected 300 total pieces, found ${totalQuantity}`);
      validation.valid = false;
    }
  });
  
  return validation;
}
```

### **SKU Mapping Validation**
```javascript
// ✅ DO: Ensure SKU consistency
function validateSKUMapping(csvData, shopifyVariants) {
  const skuMap = new Map();
  const unmappedSKUs = [];
  
  csvData.forEach(row => {
    const sku = row['Variant SKU'];
    const variant = shopifyVariants.find(v => v.sku === sku);
    
    if (variant) {
      skuMap.set(sku, variant.id);
    } else {
      unmappedSKUs.push(sku);
    }
  });
  
  if (unmappedSKUs.length > 0) {
    throw new Error(`Unmapped SKUs found: ${unmappedSKUs.join(', ')}`);
  }
  
  return skuMap;
}
```

## **Deployment Automation**

### **Theme File Deployment**
```javascript
// ✅ DO: Use MCP server for theme operations
async function deployThemeFiles(files) {
  const mcpClient = new MCPClient({
    serverPath: './build/index.js',
    env: {
      SHOPIFY_ACCESS_TOKEN: process.env.SHOPIFY_ACCESS_TOKEN,
      MYSHOPIFY_DOMAIN: process.env.MYSHOPIFY_DOMAIN
    }
  });
  
  const results = [];
  
  for (const file of files) {
    try {
      const result = await mcpClient.call('theme-file-write', {
        directory: './themes/current',
        filePath: file.path,
        content: file.content,
        backup: true
      });
      
      console.log(`✅ Deployed: ${file.path}`);
      results.push({ success: true, file: file.path, result });
    } catch (error) {
      console.error(`❌ Failed to deploy ${file.path}:`, error.message);
      results.push({ success: false, file: file.path, error });
    }
  }
  
  return results;
}
```

