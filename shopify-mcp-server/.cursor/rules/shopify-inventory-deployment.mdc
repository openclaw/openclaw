## **Environment Management**

### **Configuration Validation**
```javascript
// ✅ DO: Validate all required configurations
function validateDeploymentEnvironment() {
  const checks = [
    {
      name: 'Shopify Access Token',
      check: () => !!process.env.SHOPIFY_ACCESS_TOKEN,
      fix: 'Set SHOPIFY_ACCESS_TOKEN environment variable'
    },
    {
      name: 'Store Domain',
      check: () => !!process.env.MYSHOPIFY_DOMAIN,
      fix: 'Set MYSHOPIFY_DOMAIN environment variable'
    },
    {
      name: 'Theme Access',
      check: async () => await canAccessThemes(),
      fix: 'Ensure access token has read_themes and write_themes permissions'
    },
    {
      name: 'Location Exists',
      check: async () => await validateLocation('170 Avenue F'),
      fix: 'Create or verify fulfillment location in Shopify admin'
    }
  ];
  
  const results = await Promise.all(checks.map(async check => {
    try {
      const passed = await check.check();
      return { name: check.name, passed, fix: check.fix };
    } catch (error) {
      return { name: check.name, passed: false, error: error.message, fix: check.fix };
    }
  }));
  
  const failed = results.filter(r => !r.passed);
  if (failed.length > 0) {
    console.error('❌ Environment validation failed:');
    failed.forEach(f => console.error(`  - ${f.name}: ${f.fix}`));
    throw new Error('Environment validation failed');
  }
  
  console.log('✅ Environment validation passed');
  return true;
}
```

## **Monitoring & Reporting**

### **Progress Tracking**
```javascript
// ✅ DO: Provide detailed progress reporting
class DeploymentMonitor {
  constructor(totalItems) {
    this.total = totalItems;
    this.completed = 0;
    this.failed = 0;
    this.startTime = Date.now();
  }
  
  update(success = true) {
    this.completed++;
    if (!success) this.failed++;
    
    const progress = Math.round((this.completed / this.total) * 100);
    const elapsed = Date.now() - this.startTime;
    const rate = this.completed / (elapsed / 1000);
    const eta = (this.total - this.completed) / rate;
    
    console.log(`📊 Progress: ${progress}% (${this.completed}/${this.total}) | ` +
               `Rate: ${rate.toFixed(1)}/s | ETA: ${eta.toFixed(0)}s | ` +
               `Failed: ${this.failed}`);
  }
  
  summary() {
    const elapsed = Date.now() - this.startTime;
    return {
      total: this.total,
      completed: this.completed,
      failed: this.failed,
      successRate: (this.completed - this.failed) / this.total,
      duration: elapsed / 1000
    };
  }
}
```

