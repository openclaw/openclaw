### **JavaScript Optimization**
```javascript
// ✅ DO: Use efficient DOM updates
function updateInventoryDisplay(variantId, quantity) {
  const widget = document.querySelector('[data-variant-id="' + variantId + '"]');
  if (widget) {
    widget.querySelector('.inventory-count').textContent = quantity;
    widget.classList.toggle('low-stock', quantity < 4);
    widget.classList.toggle('sold-out', quantity === 0);
  }
}
```

