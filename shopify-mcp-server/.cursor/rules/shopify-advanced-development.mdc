        status: 'passed', 
        result,
        rubricScore 
      });
      
      // Ensure quality standards are met
      if (rubricScore.overall < 4) {
        console.warn(`⚠️ ${test.name} below quality threshold`);
        // Trigger improvement recommendations
        await generateImprovementRecommendations(test, result, rubricScore);
