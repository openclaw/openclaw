```javascript
// ✅ DO: Implement automated asset optimization with design standards
// Invoke: @design-rubric-rule.mdc for comprehensive evaluation
async function optimizeThemeAssets(directory) {
  const tasks = [
    { 
      name: 'Design Token Validation', 
      task: () => validateDesignTokens(directory),
      rubricCriteria: ['consistency', 'accessibility', 'scalability']
    },
    { 
      name: 'CSS Optimization', 
      task: () => optimizeCSS(directory),
      rubricCriteria: ['performance', 'maintainability']
    },
    { 
      name: 'Typography Hierarchy Check', 
      task: () => validateTypographyHierarchy(directory),
      rubricCriteria: ['readability', 'hierarchy', 'accessibility']
    },
    { 
      name: 'Color Contrast Validation', 
      task: () => validateColorContrast(directory),
      rubricCriteria: ['accessibility', 'usability']
    },
    { 
      name: 'Layout Grid Verification', 
      task: () => validateLayoutGrid(directory),
      rubricCriteria: ['alignment', 'consistency', 'responsiveness']
    },
    { 
      name: 'JavaScript Bundling', 
      task: () => bundleJS(directory),
      rubricCriteria: ['performance', 'maintainability']
    },
    { 
      name: 'Image Compression', 
      task: () => compressImages(directory),
      rubricCriteria: ['performance', 'quality']
    },
    { 
      name: 'SVG Optimization', 
      task: () => optimizeSVGs(directory),
      rubricCriteria: ['performance', 'accessibility']
    }
  ];
  
  const results = [];
  for (const task of tasks) {
    console.log(`🔧 ${task.name}...`);
    
    try {
      const result = await task.task();
      const rubricScore = await evaluateAgainstRubric(result, task.rubricCriteria);
      
      results.push({
        task: task.name,
        status: 'completed',
        rubricScore,
        result
      });
      
      console.log(`✅ ${task.name} complete (Score: ${rubricScore.overall}/5)`);
      
      // Ensure minimum quality standards
      if (rubricScore.overall < 4) {
        console.warn(`⚠️ ${task.name} below quality threshold. Applying improvements...`);
        await applyQualityImprovements(task, result);
      }
      
    } catch (error) {
      console.error(`❌ ${task.name} failed:`, error);
      results.push({
        task: task.name,
        status: 'failed',
        error: error.message
      });
    }
  }
  
  return results;
}

// ✅ DO: Evaluate against design rubric standards
async function evaluateAgainstRubric(result, criteria) {
  // Invoke: @design-principle-rubric.mdc for evaluation
  const rubricEvaluation = {
    colorPalette: await evaluateColorPalette(result),
    layoutGrid: await evaluateLayoutGrid(result),
    typography: await evaluateTypography(result),
    hierarchyNavigation: await evaluateHierarchy(result),
    accessibility: await evaluateAccessibility(result),
    spacingAlignment: await evaluateSpacing(result)
  };
  
  const overall = Object.values(rubricEvaluation)
    .reduce((sum, score) => sum + score, 0) / Object.keys(rubricEvaluation).length;
  
  return {
    ...rubricEvaluation,
    overall: Math.round(overall * 10) / 10
  };
}
```

