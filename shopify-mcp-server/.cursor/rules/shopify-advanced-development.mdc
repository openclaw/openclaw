## **Error Handling & Recovery with Design Considerations**

### **Comprehensive Error Management**
```javascript
// ✅ DO: Implement robust error handling with design fallbacks
// Invoke: @design-system-token-gen-rules.mdc for fallback tokens
class ThemeDeploymentError extends Error {
  constructor(message, code, recoverable = true, designImpact = false) {
    super(message);
    this.code = code;
    this.recoverable = recoverable;
    this.designImpact = designImpact;
    this.timestamp = new Date().toISOString();
    this.fallbackStrategy = this.determineFallbackStrategy();
  }
  
  determineFallbackStrategy() {
    if (this.designImpact) {
      return {
        useDesignTokenFallbacks: true,
        applyMinimalViableDesign: true,
        maintainAccessibility: true
      };
    }
    return { useStandardFallbacks: true };
  }
}

async function deployWithRecovery(operation, maxRetries = 3) {
  for (let attempt = 1; attempt <= maxRetries; attempt++) {
    try {
      const result = await operation();
      
      // Validate design standards even on successful deployment
      const designValidation = await validateDesignStandards(result);
      if (designValidation.score < 4) {
        console.warn(`⚠️ Design standards below threshold: ${designValidation.score}/5`);
        await applyDesignImprovements(result, designValidation);
      }
      
      console.log(`✅ Operation successful on attempt ${attempt}`);
      return result;
      
    } catch (error) {
      console.warn(`⚠️ Attempt ${attempt} failed: ${error.message}`);
      
      // Apply design fallbacks if needed
      if (error.designImpact) {
        await applyDesignFallbacks(error.fallbackStrategy);
      }
      
      if (!error.recoverable || attempt === maxRetries) {
        console.error(`❌ Operation failed permanently: ${error.message}`);
        throw error;
      }
      
      // Exponential backoff
      await new Promise(resolve => setTimeout(resolve, 1000 * Math.pow(2, attempt - 1)));
    }
  }
}
```

