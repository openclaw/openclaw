{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ceviz.local/contracts/sketchup-bridge-request-envelope-v1.json",
  "title": "SketchUpBridgeRequestEnvelopeV1",
  "type": "object",
  "required": ["schemaVersion", "requestId", "kind", "createdAtUtc", "status", "payload"],
  "properties": {
    "schemaVersion": {
      "const": "sketchup-bridge-request-envelope-v1"
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["ping", "capabilities", "extract-presentation-context"]
    },
    "createdAtUtc": {
      "type": "string"
    },
    "status": {
      "const": "pending"
    },
    "payload": {
      "type": "object",
      "properties": {
        "extractionMode": {
          "type": "string",
          "enum": ["seeded", "prefer-live", "live-only"]
        },
        "sceneHint": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
