# Core
ENV=dev
DRY_RUN=true
READ_ONLY=false
KILL_SWITCH=false

# Webhook auth
WEBHOOK_SHARED_SECRET=replace-with-long-random-string

# Booking
BOOKING_LINK=https://example.com/book

# GoHighLevel
GHL_API_KEY=replace
GHL_BASE_URL=https://rest.gohighlevel.com
GHL_PIPELINE_ID=replace
GHL_STAGE_NEW_ID=replace
GHL_STAGE_WON_ID=replace
TAG_LEAD=lead
TAG_CUTMV=cutmv
TAG_FULLDIGITAL=fulldigital

# GHL custom field key/name used to store Trello board id
# Use the EXACT custom field key your GHL API expects (often an ID or "customFields" mapping key).
GHL_CUSTOM_FIELD_TRELLO_BOARD_ID_KEY=TrelloBoardId

# If you want, also store primary card id
GHL_CUSTOM_FIELD_TRELLO_PRIMARY_CARD_ID_KEY=TrelloPrimaryCardId

# ManyChat
MANYCHAT_API_KEY=replace
MANYCHAT_BASE_URL=https://api.manychat.com

# Ops/admin (required for /ops/* endpoints)
ADMIN_OPS_TOKEN=replace-with-long-random-string

# Stripe
STRIPE_SECRET_KEY=replace
STRIPE_WEBHOOK_SECRET=replace

# Stripe checkout defaults (used by /ops/create_checkout_link)
CHECKOUT_SUCCESS_URL=https://example.com/success
CHECKOUT_CANCEL_URL=https://example.com/cancel

# Offer → Stripe Price mapping (start with your core offers)
STRIPE_PRICE_ID_FD_ROLLOUT_800=replace
STRIPE_PRICE_ID_FD_SUB_1500=replace
STRIPE_PRICE_ID_CUTMV_PRO=replace

# Trello (fulfillment)
TRELLO_KEY=replace
TRELLO_TOKEN=replace
TRELLO_WORKSPACE_ID=replace
TRELLO_TEMPLATE_BOARD_ID=replace

# Trello inbound webhook auth (Trello can't add custom headers; use URL secret)
TRELLO_WEBHOOK_SECRET=replace-with-long-random-string

# Public URL (or Cloudflare Tunnel URL) used in Trello webhook callback
PUBLIC_BASE_URL=https://your-domain.example.com

# Optional: allow toggling auto-webhook on/off without code changes
TRELLO_AUTO_WEBHOOK_ENABLED=true

# GHL stage sync inbound (GHL can send headers; we use shared secret header)
GHL_WEBHOOK_SHARED_SECRET=replace-with-long-random-string

# Stage ↔ List mapping (JSON)
# Keys are GHL stage IDs; values are Trello list names
STAGE_TO_TRELLO_LIST_JSON={"replace_stage_new":"Awaiting Details","replace_stage_booked":"In Progress","replace_stage_won":"Published/Delivered"}

# Reverse mapping (JSON)
# Keys are Trello list names; values are GHL stage IDs
TRELLO_LIST_TO_STAGE_JSON={"Awaiting Details":"replace_stage_new","In Progress":"replace_stage_booked","Published/Delivered":"replace_stage_won"}

# Lifecycle cleanup triggers
# If GHL stage_id matches one of these, we cleanup the Trello webhook + (optionally) close board
CLEANUP_ON_GHL_STAGE_IDS_JSON=["replace_stage_archived","replace_stage_lost"]

# If Trello primary card is moved into one of these lists, we cleanup
CLEANUP_ON_TRELLO_LIST_NAMES_JSON=["Archived","Lost","Closed"]

# Soft cleanup behavior (recommended)
TRELLO_CLOSE_BOARD_ON_CLEANUP=false

# NEW: Move the primary card to an archive list during cleanup (instead of closing board)
TRELLO_MOVE_PRIMARY_CARD_ON_CLEANUP=true
TRELLO_ARCHIVE_LIST_NAME=Archived

# If archive list missing, auto-create it during cleanup
TRELLO_AUTOCREATE_ARCHIVE_LIST_ON_CLEANUP=true

# Label automation during cleanup
TRELLO_APPLY_ARCHIVED_LABEL_ON_CLEANUP=true
TRELLO_AUTOCREATE_ARCHIVED_LABEL_ON_CLEANUP=true
TRELLO_ARCHIVED_LABEL_NAME=Archived

# Add a cleanup summary comment to the primary card during cleanup
TRELLO_ADD_CLEANUP_COMMENT_ON_CLEANUP=true

# Timeline logging to Trello primary card
TIMELINE_LOG_ENABLED=true

# Optional: prefix marker to make parsing trivial
TIMELINE_JSON_MARKER=[OPENCLAW_JSON]

# Optional: only log certain event types (empty = log all)
TIMELINE_ALLOWED_EVENT_TYPES_JSON=[]

# Internal Fulfillment Board (single board for the team)
INTERNAL_FULFILLMENT_TRELLO_BOARD_ID=trello_board_id_here

# Where to place new internal work orders
INTERNAL_FULFILLMENT_INBOX_LIST_NAME=Inbox

# Optionally create these lists on the internal board if missing
INTERNAL_FULFILLMENT_AUTOCREATE_LISTS=true
INTERNAL_FULFILLMENT_LISTS_JSON=["Inbox","Assigned","In Progress","Needs Review","Ready","Done","Blocked"]

# Intake endpoints (shared secrets)
GHL_INTAKE_WEBHOOK_SECRET=replace_me
MANYCHAT_INTAKE_WEBHOOK_SECRET=replace_me

# Request routing
REQUEST_ROUTING_RULES_JSON={"cover_art":{"role":"designer_static","priority":"high"},"flyer":{"role":"designer_static","priority":"medium"},"motion":{"role":"designer_motion","priority":"high"},"lyric_video":{"role":"designer_motion","priority":"medium"},"branding":{"role":"designer_static","priority":"medium"},"unknown":{"role":"pm","priority":"low"}}

# Optional: create a client-board card too (if intake didn't originate from Trello)
AUTO_CREATE_CLIENT_REQUEST_CARD=true
CLIENT_REQUEST_LIST_NAME=Awaiting Details

# Client board list names (for Trello intake mirror + stage sync)
CLIENT_REQUEST_LIST_NAMES_JSON=["Inbox / Awaiting Details","Request","Requests"]
CLIENT_IN_PROGRESS_LIST_NAMES_JSON=["In Progress"]
CLIENT_NEEDS_REVIEW_LIST_NAMES_JSON=["Needs Review / Feedback"]
CLIENT_APPROVED_READY_LIST_NAMES_JSON=["Approved / Ready for Delivery"]
CLIENT_PUBLISHED_LIST_NAMES_JSON=["Published / Delivered"]
CLIENT_REFERENCE_LIST_NAMES_JSON=["Reference & Links","Reference and Links","References & Links"]

# Aspect ratio auto-label on intake
TRELLO_AUTO_AR_LABELS=true

# Assignment system (local DB truth, mirrored to Trello via labels/timeline)
ASSIGNMENT_MIRROR_TO_TRELLO_LABEL=true
ASSIGNMENT_LABEL_PREFIX=Assigned:
ASSIGNMENT_MIRROR_TO_TIMELINE=true
ASSIGNMENT_PREFIX_CARD_TITLE=false

# Per-offer override: if offer_key is mapped here, it overrides the default above
OFFER_CLEANUP_CLOSE_BOARD_JSON={"fd_rollout_800": false, "fd_sub_1500": false, "cutmv_pro": false}

# Observability (optional)
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Telegram control plane
TELEGRAM_BOT_TOKEN=replace
TELEGRAM_ALLOWED_CHAT_IDS=123,456
TELEGRAM_DEFAULT_BRAND=fulldigital
TELEGRAM_APPROVAL_TTL_MINUTES=60
TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-string
TELEGRAM_PRIMARY_CHAT_ID=123
TELEGRAM_SIGNING_SECRET=replace-with-hmac-signing-secret
TELEGRAM_BOT_USERNAME=your_bot_username

# Local storage
SQLITE_PATH=./data/app.db
OPENCLAW_DB=./data/openclaw.db

# Cluster layout (see config/runtime.yaml + docs/ops/CLUSTER_CURRENT_STATE.md)
OPENCLAW_REPO=~/openclaw
OPENCLAW_CLUSTER_DIR=~/cluster
OPENCLAW_SHARED_JOBS=~/cluster/jobs
OPENCLAW_SHARED_LOGS=~/cluster/logs
OPENCLAW_SHARED_RESULTS=~/cluster/results

# Creative engine (see config/runtime.yaml)
OPENCLAW_DEFAULT_CREATIVE_LANE=remotion_json
CUTMV_AD_LIBRARY=~/cutmv-ad-library
FULLDIGITAL_AD_LIBRARY=~/fulldigital-ad-library

# Auto-migrate on dev server startup
OPENCLAW_AUTO_MIGRATE=true

# ── OpenClaw Gateway (M4 coordinator) ──
# See gateway/openclaw.json5 for full config
OPENCLAW_GATEWAY_PORT=18789

# Ollama (local inference)
OLLAMA_PRIMARY_HOST=http://10.0.0.145:11434
OLLAMA_FALLBACK_HOST=http://10.0.0.10:11434

# Cloud fallback (Anthropic)
ANTHROPIC_API_KEY=

# Telegram channel bindings (Full Digital)
TELEGRAM_FD_OPS_CHAT_ID=replace
TELEGRAM_FD_SALES_CHAT_ID=replace
TELEGRAM_FD_CONTENT_CHAT_ID=replace
TELEGRAM_FD_FINANCE_CHAT_ID=replace

# Telegram channel bindings (CUTMV)
TELEGRAM_CUTMV_OPS_CHAT_ID=replace
TELEGRAM_CUTMV_SUPPORT_CHAT_ID=replace
TELEGRAM_CUTMV_GROWTH_CHAT_ID=replace

# Discord (optional)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_IDS=

# GrantOps (Finance sub-module — see docs/ops/GRANTOPS_COMMAND_CENTER_INTEGRATION.md)
GRANTOPS_ENABLED=false
GRANTOPS_AUTO_SUBMIT_ENABLED=false
GRANTOPS_FIT_SCORE_THRESHOLD=0.7
GRANTOPS_MAX_SUBMISSIONS_PER_DAY=3
GRANTOPS_REQUIRE_TELEGRAM_APPROVAL=true
GRANTOPS_DAILY_SCAN_HOUR=6
GRANTOPS_DAILY_SCAN_TIMEZONE=America/New_York

# Candid API (grant discovery)
CANDID_API_KEY=
CANDID_BASE_URL=https://api.candid.org/grants/v1

# Submittable API (grant submission automation)
SUBMITTABLE_API_KEY=
SUBMITTABLE_ORG_ID=
SUBMITTABLE_BASE_URL=https://api.submittable.com/v4

# Notion DB IDs for GrantOps (populated after Notion bootstrap)
NOTION_DB_GRANT_OPPORTUNITIES_ID=
NOTION_DB_GRANT_DRAFTS_ID=
NOTION_DB_GRANT_SUBMISSIONS_ID=
