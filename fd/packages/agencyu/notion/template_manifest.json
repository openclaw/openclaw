{
  "manifest_version": "2026-02-28",
  "workspace": {
    "root_page_required": true,
    "root_page_title": "Full Digital — AgencyOS",
    "required_child_pages": [
      "CEO Overview",
      "Sales Dashboard",
      "Project Command Center",
      "Financial Dashboard",
      "Team & Capacity",
      "Databases",
      "Admin / Config"
    ]
  },
  "databases": [
    {
      "key": "clients",
      "name": "Clients",
      "required": true,
      "primary_title_property": "Client Name",
      "properties": {
        "Client Name": { "type": "title" },
        "Status": { "type": "select", "options": ["Active", "Onboarding", "Paused", "Churned", "Prospect"] },
        "Service Package": { "type": "select" },
        "MRR": { "type": "number", "format": "dollar" },
        "Start Date": { "type": "date" },
        "Account Manager": { "type": "people" },
        "Client Portal": { "type": "page_reference" },
        "Outcomes": { "type": "relation", "target_db_key": "outcomes" },
        "Invoices": { "type": "relation", "target_db_key": "invoices" },
        "Expenses": { "type": "relation", "target_db_key": "expenses" },
        "Contacts": { "type": "relation", "target_db_key": "contacts" },
        "Client Assets": { "type": "relation", "target_db_key": "client_assets" },
        "Meetings": { "type": "relation", "target_db_key": "meetings" },
        "Source": { "type": "select" },
        "Campaign": { "type": "rich_text" },
        "Notes": { "type": "rich_text" },
        "canonical_id": { "type": "rich_text", "required_for_sync": true },
        "sync.source_system": { "type": "select", "options": ["notion", "trello", "stripe", "quickbooks", "ghl", "clickfunnels", "system"] },
        "sync.source_id": { "type": "rich_text" },
        "sync.locked": { "type": "checkbox" },
        "sync.override_owner": { "type": "select", "options": ["trello", "notion", "system"] },
        "sync.health": { "type": "select", "options": ["ok", "warning", "broken"] },
        "sync.error": { "type": "rich_text" },
        "sync.last_mirrored_at": { "type": "date" }
      },
      "required_views": [
        { "name": "All Clients", "type": "table" },
        { "name": "Active Clients", "type": "table", "filter": { "Status": "Active" } },
        { "name": "Onboarding", "type": "table", "filter": { "Status": "Onboarding" } }
      ],
      "required_templates": [
        { "name": "Client Portal Template", "required": true }
      ]
    },
    {
      "key": "crm_pipeline",
      "name": "CRM Pipeline",
      "required": true,
      "primary_title_property": "Lead Name",
      "properties": {
        "Lead Name": { "type": "title" },
        "Pipeline Stage": {
          "type": "status",
          "options": ["New Lead", "Qualified", "Booked", "Called", "Proposal Sent", "Negotiating", "Closed Won", "Closed Lost"]
        },
        "Source": { "type": "select", "options": ["meta_ad", "organic_reel", "story_reply", "click_to_dm", "referral", "cold_outreach", "clickfunnels", "ghl"] },
        "Campaign": { "type": "rich_text" },
        "Revenue Tier": { "type": "select", "options": ["Under $5K", "$5K–$15K", "$15K–$50K", "$50K+"] },
        "Pain Point": { "type": "select", "options": ["Acquisition", "Retention", "Team", "Operations", "All"] },
        "Assigned Setter": { "type": "people" },
        "IG Handle": { "type": "url" },
        "Email": { "type": "email" },
        "Phone": { "type": "phone_number" },
        "Call Date": { "type": "date" },
        "Call Notes": { "type": "rich_text" },
        "Deal Value": { "type": "number", "format": "dollar" },
        "Follow-Up Date": { "type": "date" },
        "Last Contacted": { "type": "date" },
        "ManyChat Tags": { "type": "multi_select" },
        "Objections": { "type": "multi_select", "options": ["Price", "Timing", "Trust", "Need", "Already have provider"] },
        "Converted to Client": { "type": "relation", "target_db_key": "clients" },
        "Created": { "type": "created_time" },
        "canonical_id": { "type": "rich_text", "required_for_sync": true },
        "sync.source_system": { "type": "select", "options": ["notion", "ghl", "manychat", "clickfunnels", "system"] },
        "sync.source_id": { "type": "rich_text" },
        "sync.locked": { "type": "checkbox" },
        "sync.override_owner": { "type": "select", "options": ["source", "notion", "system"] },
        "sync.health": { "type": "select", "options": ["ok", "warning", "broken"] },
        "sync.error": { "type": "rich_text" },
        "sync.last_mirrored_at": { "type": "date" }
      },
      "required_views": [
        { "name": "Pipeline Board", "type": "board", "group_by": "Pipeline Stage" },
        { "name": "Follow-Up Queue", "type": "table", "filter": { "Follow-Up Date": "on_or_before_today" }, "sort": ["Follow-Up Date asc"] },
        { "name": "By Campaign", "type": "table", "group_by": "Campaign" }
      ]
    },
