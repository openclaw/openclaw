# OpenClaw Agent Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ── Core Safety ──────────────────────────────────────────────────────────────
ENVIRONMENT=dev
DRY_RUN=true
READ_ONLY=false
KILL_SWITCH=false
SAFE_MODE=true

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_DA_CHAT_ID=
TELEGRAM_FULLDIGITAL_OPS_CHAT_ID=
TELEGRAM_CUTMV_OPS_CHAT_ID=

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_PRIMARY_HOST=http://10.0.0.145:11434
OLLAMA_FALLBACK_HOST=http://localhost:11434

# ── Anthropic (cloud escalation) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=18789

# ── Webhook Auth ─────────────────────────────────────────────────────────────
WEBHOOK_SHARED_SECRET=
STRIPE_WEBHOOK_SECRET=
GHL_WEBHOOK_SHARED_SECRET=

# ── External APIs ────────────────────────────────────────────────────────────
GHL_API_KEY=
STRIPE_SECRET_KEY=
TRELLO_KEY=
TRELLO_TOKEN=
NOTION_API_KEY=
POSTHOG_API_KEY=
