{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/agent.lineage.schema.json",
  "title": "OpenClaw Agent Lineage Record",
  "description": "Frozen canonical lineage record for M11 design-studio admission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "lineageId",
    "agentId",
    "canonical",
    "seat",
    "designStudio",
    "parents",
    "provenance",
    "trace",
    "receipts"
  ],
  "properties": {
    "kind": {
      "const": "agent.lineage"
    },
    "schemaVersion": {
      "const": 1
    },
    "lineageId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
    },
    "agentId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "canonical": {
      "const": true
    },
    "seat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seatId", "seatKind", "registryNamespace"],
      "properties": {
        "seatId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "seatKind": {
          "type": "string",
          "enum": ["engineering", "ops", "product", "support"]
        },
        "registryNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        }
      }
    },
    "designStudio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["studioId", "outputId", "outputVersion", "outputDigest", "exportedAt"],
      "properties": {
        "studioId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "outputId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "outputVersion": {
          "type": "integer",
          "minimum": 1
        },
        "outputDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "exportedAt": {
          "$ref": "#/definitions/timestamp"
        }
      }
    },
    "parents": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/lineageParent"
      },
      "uniqueItems": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceOfTruth", "authoredAt", "authoredBy", "sourceCommit", "inputs"],
      "properties": {
        "sourceOfTruth": {
          "const": "design-studio"
        },
        "authoredAt": {
          "$ref": "#/definitions/timestamp"
        },
        "authoredBy": {
          "type": "string",
          "minLength": 1
        },
        "sourceCommit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/provenanceInput"
          },
          "uniqueItems": true
        }
      }
    },
    "trace": {
      "$ref": "#/definitions/traceEnvelope"
    },
    "receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineageDigest", "admissionContractDigest"],
      "properties": {
        "lineageDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "admissionContractDigest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    }
  },
  "definitions": {
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "lineageParent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineageId", "relation", "digest"],
      "properties": {
        "lineageId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "relation": {
          "type": "string",
          "enum": ["derived-from", "forked-from", "imported-from", "promoted-from"]
        },
        "digest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    },
    "provenanceInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["brief", "prompt", "bundle", "snapshot"]
        },
        "digest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    },
    "traceEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceNamespace", "receiptNamespace", "routeLawNamespace", "approvalNamespace"],
      "properties": {
        "traceNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "receiptNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "routeLawNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "approvalNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        }
      }
    }
  }
}
