{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/agent.runtime.schema.json",
  "title": "OpenClaw Agent Runtime Manifest",
  "description": "Frozen runtime truth contract for M11 admission and registry publication.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "runtimeId",
    "lineage",
    "agent",
    "registry",
    "runtimeTruthSource",
    "runtime",
    "provenance",
    "trace",
    "receipts"
  ],
  "properties": {
    "kind": {
      "const": "agent.runtime"
    },
    "schemaVersion": {
      "const": 1
    },
    "runtimeId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
    },
    "lineage": {
      "$ref": "#/definitions/lineageBinding"
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agentId", "seatId"],
      "properties": {
        "agentId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
        },
        "seatId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "recordKey"],
      "properties": {
        "namespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "recordKey": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        }
      }
    },
    "runtimeTruthSource": {
      "const": "manifest"
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executor", "provider", "model", "instructionsDigest", "toolCatalogDigest"],
      "properties": {
        "executor": {
          "type": "string",
          "enum": ["embedded", "subagent", "acp"]
        },
        "provider": {
          "type": "string",
          "enum": ["anthropic", "google", "openai", "openrouter", "other"]
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "instructionsDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "toolCatalogDigest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceOfTruth",
        "authoredAt",
        "authoredBy",
        "designStudioOutputDigest",
        "lineageDigest"
      ],
      "properties": {
        "sourceOfTruth": {
          "const": "runtime-manifest"
        },
        "authoredAt": {
          "$ref": "#/definitions/timestamp"
        },
        "authoredBy": {
          "type": "string",
          "minLength": 1
        },
        "designStudioOutputDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "lineageDigest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    },
    "trace": {
      "$ref": "#/definitions/traceEnvelope"
    },
    "receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeDigest", "lineageDigest", "policyDigest"],
      "properties": {
        "runtimeDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "lineageDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "policyDigest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    }
  },
  "definitions": {
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "lineageBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineageId", "lineageDigest"],
      "properties": {
        "lineageId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "lineageDigest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    },
    "traceEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceNamespace", "receiptNamespace", "routeLawNamespace", "approvalNamespace"],
      "properties": {
        "traceNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "receiptNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "routeLawNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "approvalNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        }
      }
    }
  }
}
