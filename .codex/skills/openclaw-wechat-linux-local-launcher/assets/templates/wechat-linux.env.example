# Required model provider settings
OPENAI_API_KEY=__OPENAI_API_KEY__
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENAI_MODEL=qwen3-coder-plus

# Optional image / main-window vision model settings
MAIN_WINDOW_VISION_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
MAIN_WINDOW_VISION_MODEL=qwen3.5-plus

# Required display settings for Linux desktop WeChat automation
DISPLAY=:1.0

# Optional when the desktop session needs explicit Xauthority
# XAUTHORITY=/run/user/1000/gdm/Xauthority
