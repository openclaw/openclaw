#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
RUN_NODE_TOOL="$ROOT_DIR/scripts/pre-commit/run-node-tool.sh"
FILTER_FILES="$ROOT_DIR/scripts/pre-commit/filter-staged-files.mjs"

if [[ ! -x "$RUN_NODE_TOOL" ]]; then
  echo "Missing helper: $RUN_NODE_TOOL" >&2
  exit 1
fi

if [[ ! -f "$FILTER_FILES" ]]; then
  echo "Missing helper: $FILTER_FILES" >&2
  exit 1
fi

# Security: avoid option-injection from malicious file names (e.g. "--all", "--force").
# Robustness: NUL-delimited file list handles spaces/newlines safely.
# Compatibility: use read loops instead of `mapfile` so this runs on macOS Bash 3.x.
files=()
while IFS= read -r -d '' file; do
  files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

lint_files=()
while IFS= read -r -d '' file; do
  lint_files+=("$file")
done < <(node "$FILTER_FILES" lint -- "${files[@]}")

format_files=()
while IFS= read -r -d '' file; do
  format_files+=("$file")
done < <(node "$FILTER_FILES" format -- "${files[@]}")

if [ "${#lint_files[@]}" -gt 0 ]; then
  "$RUN_NODE_TOOL" oxlint --type-aware --fix -- "${lint_files[@]}"
fi

if [ "${#format_files[@]}" -gt 0 ]; then
  "$RUN_NODE_TOOL" oxfmt --write -- "${format_files[@]}"
fi

# Regenerate skills/manifest.json if any skill files changed.
skills_changed=false
for f in "${files[@]}"; do
  case "$f" in
    skills/*/SKILL.md)
      skills_changed=true
      break
      ;;
  esac
done

if [ "$skills_changed" = "true" ]; then
  echo "skills/SKILL.md files changed — regenerating skills/manifest.json..."
  node --import tsx "$ROOT_DIR/scripts/generate-skills-manifest.ts"
  # Stage the (possibly) updated manifest and normalized SKILL.md files.
  git add "$ROOT_DIR/skills/manifest.json"
  # Re-stage any SKILL.md files that were normalized.
  for f in "${files[@]}"; do
    case "$f" in
      skills/*/SKILL.md)
        git add "$ROOT_DIR/$f"
        ;;
    esac
  done
fi

# Validate manifest is in sync (catches cases where manifest.json was edited directly).
if node --import tsx "$ROOT_DIR/scripts/generate-skills-manifest.ts" --check 2>/dev/null; then
  :
else
  echo "ERROR: skills/manifest.json is out of sync with SKILL.md files." >&2
  echo "Run: pnpm skills:manifest" >&2
  exit 1
fi

git add -- "${files[@]}"
