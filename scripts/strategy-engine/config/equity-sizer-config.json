    },
    "TX": {
      "riskPct": 0.02,
      "maxContracts": 5
    },
    "ES": {
      "riskPct": 0.02,
      "maxContracts": 3
    },
    "NQ": {
      "riskPct": 0.02,
      "maxContracts": 2
    },
    "CL": {
      "riskPct": 0.02,
      "maxContracts": 3
