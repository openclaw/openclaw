# Telegram MTProto user credentials (my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Bot token used by tg polling and sender-id filtering in fallback checks.
# Format: <botId>:<token>
TG_BOT_TOKEN=

# Absolute path to built tg binary
TG_BIN=

# Optional default model expectation used in some manual checks
TG_EXPECTED_MODEL=openai-codex/gpt-5.3-codex
TG_WAIT_TIMEOUT_SECONDS=45

# Group forum test targets
TG_FORUM_CHAT_ID=
TG_TOPIC_A_ID=
TG_TOPIC_B_ID=
TG_TOPIC_C_ID=

# DM threaded-mode test targets
TG_DM_CHAT_ID=
TG_DM_THREAD_X_ID=
TG_DM_THREAD_Y_ID=
TG_DM_THREAD_Z_ID=

