[Unit]
Description=OpenClaw Chrome Browser Process Cleanup
After=network.target
Documentation=https://github.com/openclaw/openclaw/blob/main/scripts/chrome-cleanup.sh

[Service]
Type=simple
# Script is installed to ~/.openclaw/browser/chrome-cleanup.sh by install.sh
ExecStart=%h/.openclaw/browser/chrome-cleanup.sh daemon
Restart=always
RestartSec=10
TimeoutStopSec=30
KillSignal=SIGTERM

[Install]
WantedBy=default.target
