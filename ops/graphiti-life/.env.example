# Copy to .env on the host and fill in. NEVER commit the real .env.
# FalkorDB password — generate with: openssl rand -hex 24
FALKORDB_PASSWORD=changeme
# OpenAI key for Graphiti's extractor LLM + embedder.
# On the US host this is shared in /root/.openclaw/agents/life/docker.env.
OPENAI_API_KEY=sk-...
# Cheap extractor model (runs on every add_memory). gpt-4o-mini is the default.
MODEL_NAME=gpt-4o-mini
# Graphiti LLM concurrency cap.
SEMAPHORE_LIMIT=5
