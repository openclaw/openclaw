{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MAI Universe Run Ledger",
  "description": "Execution and approval audit ledger schema (hardened v2)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "timestamp",
    "project",
    "stage",
    "agent_role",
    "risk_level",
    "action_type",
    "actor_id",
    "target_scope",
    "approval_required",
    "result"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]{8,128}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]{2,64}$"
    },
    "stage": {
      "type": "string",
      "enum": ["COLLECT", "DISCOVER", "CREATE", "BUILD", "DEPLOY", "REALIZE"]
    },
    "agent_role": {
      "type": "string",
      "enum": ["orchestrator", "scout", "builder", "operator", "auditor", "analyst"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "action_type": {
      "type": "string",
      "pattern": "^[a-z0-9_]{3,80}$"
    },
    "actor_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:@-]{2,128}$"
    },
    "target_scope": {
      "type": "string",
      "minLength": 2,
      "maxLength": 256
    },
    "cost_estimate": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "enum": ["KRW", "USD", "USDT", "OTHER"]
    },
    "approval_required": {
      "type": "boolean"
    },
    "approval_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 4,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ]
    },
    "approver_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 2,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ]
    },
    "result": {
      "type": "string",
      "enum": ["success", "partial", "failed", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 5,
      "maxLength": 2000
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 512
      }
    },
    "rollback_reference": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 3,
          "maxLength": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "integrity_hash": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "tags": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_.-]{2,40}$"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "approval_required": {
            "const": true
          }
        },
        "required": ["approval_required"]
      },
      "then": {
        "required": ["approval_id", "approver_id"]
      }
    },
    {
      "if": {
        "properties": {
          "risk_level": {
            "enum": ["high", "critical"]
          }
        },
        "required": ["risk_level"]
      },
      "then": {
        "required": ["summary", "evidence_refs"]
      }
    }
  ]
}
