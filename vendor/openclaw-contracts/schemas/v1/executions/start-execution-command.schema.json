{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.openclaw.local/v1/executions/start-execution-command.schema.json",
  "title": "StartExecutionCommand",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "message_id",
    "correlation_id",
    "occurred_at",
    "project_id",
    "job_id",
    "git_repository_id",
    "base_commit_sha",
    "task"
  ],
  "properties": {
    "schema_version": {
      "$ref": "../common/primitives.schema.json#/$defs/schema_version"
    },
    "message_id": {
      "$ref": "../common/primitives.schema.json#/$defs/message_id"
    },
    "correlation_id": {
      "$ref": "../common/primitives.schema.json#/$defs/correlation_id"
    },
    "occurred_at": {
      "$ref": "../common/primitives.schema.json#/$defs/utc_timestamp"
    },
    "project_id": {
      "$ref": "../common/primitives.schema.json#/$defs/project_id"
    },
    "job_id": {
      "$ref": "../common/primitives.schema.json#/$defs/job_id"
    },
    "git_repository_id": {
      "$ref": "../common/primitives.schema.json#/$defs/git_repository_id"
    },
    "base_commit_sha": {
      "$ref": "../common/primitives.schema.json#/$defs/commit_sha"
    },
    "task": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    },
    "constraints": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 100,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "policy_ids": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 100,
      "items": {
        "$ref": "../common/primitives.schema.json#/$defs/policy_id"
      }
    },
    "skill_ids": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "$ref": "../common/primitives.schema.json#/$defs/skill_id"
      }
    }
  }
}
