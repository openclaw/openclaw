{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.openclaw.local/v1/executions/execution-completed-event.schema.json",
  "title": "ExecutionCompletedEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "message_id",
    "correlation_id",
    "causation_id",
    "occurred_at",
    "project_id",
    "job_id",
    "execution_id",
    "worktree_id",
    "commit_sha",
    "branch_name",
    "artifact_ids",
    "evidence_ids",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "$ref": "../common/primitives.schema.json#/$defs/schema_version"
    },
    "message_id": {
      "$ref": "../common/primitives.schema.json#/$defs/message_id"
    },
    "correlation_id": {
      "$ref": "../common/primitives.schema.json#/$defs/correlation_id"
    },
    "causation_id": {
      "$ref": "../common/primitives.schema.json#/$defs/causation_id"
    },
    "occurred_at": {
      "$ref": "../common/primitives.schema.json#/$defs/utc_timestamp"
    },
    "project_id": {
      "$ref": "../common/primitives.schema.json#/$defs/project_id"
    },
    "job_id": {
      "$ref": "../common/primitives.schema.json#/$defs/job_id"
    },
    "execution_id": {
      "$ref": "../common/primitives.schema.json#/$defs/execution_id"
    },
    "worktree_id": {
      "$ref": "../common/primitives.schema.json#/$defs/worktree_id"
    },
    "commit_sha": {
      "$ref": "../common/primitives.schema.json#/$defs/commit_sha"
    },
    "branch_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "artifact_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "../common/primitives.schema.json#/$defs/artifact_id"
      }
    },
    "evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "../common/primitives.schema.json#/$defs/evidence_id"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    }
  }
}
