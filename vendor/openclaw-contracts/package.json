{
  "name": "@openclaw/contracts",
  "version": "0.1.0",
  "description": "Versioned process-boundary contracts for OpenClaw Platform",
  "private": false,
  "type": "module",
  "main": "./src/index.mjs",
  "types": "./generated/types/index.d.ts",
  "sideEffects": false,
  "files": [
    "generated",
    "schemas",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./generated/types/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./schemas/*": "./schemas/*",
    "./openapi": "./generated/openapi/v1.openapi.json",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "build": "node scripts/generate.mjs",
    "check": "node scripts/generate.mjs --check && node --test && node scripts/check-pack.mjs",
    "check:compatibility": "node scripts/check-compatibility.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "pack:local": "node scripts/pack-local.mjs",
    "test": "node --test",
    "typecheck": "node scripts/generate.mjs --check"
  }
}