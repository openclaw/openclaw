{
  "openapi": "3.1.1",
  "info": {
    "title": "OpenClaw Platform API",
    "version": "1.0.0"
  },
  "paths": {
    "/v1/projects": {
      "post": {
        "operationId": "createProject",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            }
          },
          {
            "name": "X-Correlation-ID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../../schemas/v1/projects/create-project-request.schema.json"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Project accepted for provisioning",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/projects/project-accepted-response.schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/v1/jobs": {
      "post": {
        "operationId": "createJob",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../../schemas/v1/jobs/create-job-request.schema.json"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Job accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/jobs/job-accepted-response.schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/v1/executions": {
      "post": {
        "operationId": "startExecution",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../../schemas/v1/executions/start-execution-command.schema.json"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Execution command accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/executions/execution-accepted-response.schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/v1/reviews": {
      "post": {
        "operationId": "startReview",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../../schemas/v1/reviews/start-review-command.schema.json"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Review command accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/reviews/review-accepted-response.schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{project_id}": {
      "get": {
        "operationId": "getProject",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current project snapshot",
            "headers": {
              "ETag": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/v1/projects/project-response.schema.json"
                }
              }
            }
          },
          "304": {
            "description": "Project snapshot not modified"
          }
        }
      }
    },
    "/v1/projects/{project_id}/events": {
      "get": {
        "operationId": "streamProjectEvents",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Last-Event-ID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project event stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "410": {
            "description": "Event cursor expired"
          }
        }
      }
    }
  }
}
