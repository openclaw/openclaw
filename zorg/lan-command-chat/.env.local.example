# Copy this file to .env.local and tweak values for your LAN setup.
# The session key points at the OpenClaw conversation you want to expose.
GATEWAY_SESSION_KEY=agent:main:main

# Optional: cap how many messages the history endpoint returns per poll.
CHAT_HISTORY_LIMIT=50

# Optional: override CLI timeout (ms) for gateway calls.
GATEWAY_CALL_TIMEOUT_MS=15000

# APMT API credentials (client credentials flow).
APMT_CLIENT_ID=
APMT_CLIENT_SECRET=
# Optional: set to https://api.apmterminals.com for production.
APMT_BASE_URL=https://api-sandbox.apmterminals.com
