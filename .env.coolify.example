# OpenClaw - Coolify VPS Deployment
#
# Copy to Coolify's environment variables panel or to .env on your VPS.
# Generate a secure token: openssl rand -hex 32

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Persistence paths on host (Coolify will mount these)
OPENCLAW_CONFIG_DIR=/data/openclaw/config
OPENCLAW_WORKSPACE_DIR=/data/openclaw/workspace

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# -----------------------------------------------------------------------------
# Channels (only set what you use)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# OPENCLAW_GATEWAY_PORT=18789
# BRAVE_API_KEY=...
# ELEVENLABS_API_KEY=...
