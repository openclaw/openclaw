{
  "env": {
    "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": ["anthropic/claude-haiku-4-5-20251001"]
      },
      "workspace": "/data/.openclaw/sophia",
      "userTimezone": "Europe/Rome",
      "memorySearch": {
        "provider": "openai",
        "model": "text-embedding-3-small"
      },
      "heartbeat": {
        "every": "2h",
        "target": "whatsapp"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Sophia",
          "theme": "AI companion"
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "maxResults": 5,
        "cacheTtlMinutes": 15
      },
      "fetch": {
        "enabled": true,
        "maxChars": 50000,
        "cacheTtlMinutes": 15
      }
    }
  },
  "hooks": {
    "enabled": true,
    "gmail": {
      "enabled": true
    }
  },
  "skills": {
    "entries": {
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "sessionRetention": "24h"
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "plugins": {
    "load": {
      "paths": ["/app/sophia/.openclaw/extensions"]
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing",
      "allowFrom": ["+393894991082"],
      "groupPolicy": "allowlist"
    }
  }
}
