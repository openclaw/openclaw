{
  "env": {
    "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "workspace": "/data/.openclaw/sophia",
      "memorySearch": {
        "provider": "openai",
        "model": "text-embedding-3-small"
      },
      "heartbeat": {
        "every": "2h",
        "target": "whatsapp"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Sophia",
          "theme": "AI companion"
        }
      }
    ]
  },
  "cron": {
    "enabled": true
  },
  "logging": {
    "level": "debug",
    "consoleLevel": "debug",
    "consoleStyle": "json"
  },
  "diagnostics": {
    "cacheTrace": {
      "enabled": true,
      "filePath": "/data/.openclaw/logs/cache-trace.jsonl",
      "includeMessages": true,
      "includePrompt": true,
      "includeSystem": true
    }
  },
  "hooks": {
    "internal": {
      "enabled": true
    }
  },
  "plugins": {
    "enabled": true,
    "entries": {
      "prompt-observer": {
        "enabled": true,
        "config": {
          "mode": "full",
          "includeSystemPrompt": true,
          "includePrompt": true,
          "includeHistoryMessages": true,
          "includeLlmOutput": true,
          "includeToolResults": true,
          "includeBootstrapFiles": true,
          "redactSensitive": true,
          "maxCharsPerField": 8000,
          "maxHistoryMessages": 12,
          "toolNames": ["memory_search", "memory_get", "web_search", "web_fetch"]
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing",
      "allowFrom": ["+393894991082"],
      "groupPolicy": "allowlist"
    }
  }
}
