{
  "env": {
    "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}",
    "DEEPGRAM_API_KEY": "${DEEPGRAM_API_KEY}",
    "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "workspace": "/data/.openclaw/sophia",
      "memorySearch": {
        "provider": "openai",
        "model": "text-embedding-3-small"
      },
      "heartbeat": {
        "every": "2h",
        "target": "whatsapp"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Sophia",
          "theme": "AI companion"
        }
      }
    ]
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "scope": {
          "default": "allow",
          "rules": [
            { "action": "deny", "match": { "self": true } }
          ]
        },
        "language": "multi",
        "providerOptions": {
          "deepgram": {
            "smart_format": true
          }
        },
        "models": [
          {
            "provider": "deepgram",
            "model": "nova-3"
          }
        ]
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "inbound",
      "provider": "elevenlabs",
      "elevenlabs": {
        "voiceId": "aFueGIISJUmscc05ZNfD",
        "modelId": "eleven_multilingual_v2",
        "voiceSettings": {
          "speed": 0.92,
          "stability": 0.6,
          "similarityBoost": 0.82,
          "style": 0.0
        }
      }
    }
  },
  "cron": {
    "enabled": true
  },
  "logging": {
    "level": "debug",
    "consoleLevel": "debug",
    "consoleStyle": "json"
  },
  "diagnostics": {
    "cacheTrace": {
      "enabled": true,
      "filePath": "/data/.openclaw/logs/cache-trace.jsonl",
      "includeMessages": true,
      "includePrompt": true,
      "includeSystem": true
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": ["tone_skills.md"]
        }
      }
    }
  },
  "plugins": {
    "enabled": true,
    "entries": {
      "prompt-observer": {
        "enabled": true,
        "config": {
          "mode": "full",
          "includeSystemPrompt": true,
          "includePrompt": true,
          "includeHistoryMessages": true,
          "includeLlmOutput": true,
          "includeToolResults": true,
          "includeBootstrapFiles": true,
          "redactSensitive": true,
          "maxCharsPerField": 8000,
          "maxHistoryMessages": 12,
          "toolNames": ["memory_search", "memory_get", "web_search", "web_fetch"]
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "selfChatMode": true,
      "dmPolicy": "pairing",
      "allowFrom": ["+393894991082"],
      "groupPolicy": "allowlist",
      "ackReaction": {
        "emoji": "💙",
        "direct": true,
        "group": "mentions"
      }
    }
  }
}
