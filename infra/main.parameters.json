{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "westeurope"
    },
    "postgresAdminLogin": {
      "value": "alpacoreadmin"
    },
    "postgresAdminPassword": {
      "value": "${POSTGRES_ADMIN_PASSWORD}"
    },
    "postgresDatabaseName": {
      "value": "alpacoredb"
    },
    "baseContainerImage": {
      "value": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest"
    },
    "openClawImage": {
      "value": ""
    },
    "harvesterImage": {
      "value": ""
    },
    "alpaEngineImage": {
      "value": "${ALPA_ENGINE_IMAGE}"
    },
    "alpaCoreServiceImage": {
      "value": "${ALPACORE_SERVICE_IMAGE}"
    },
    "openWebUiImage": {
      "value": "ghcr.io/open-webui/open-webui:main"
    },
    "externalOllamaUrl": {
      "value": "${EXTERNAL_OLLAMA_URL}"
    },
    "openClawGatewayToken": {
      "value": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "webUiSecretKey": {
      "value": "${WEBUI_SECRET_KEY}"
    },
    "openAiApiKey": {
      "value": "${OPENAI_API_KEY}"
    },
    "shopifyApiSecret": {
      "value": "${SHOPIFY_API_SECRET}"
    },
    "stripeSecretKey": {
      "value": "${STRIPE_SECRET_KEY}"
    },
    "revolutClientId": {
      "value": "${REVOLUT_CLIENT_ID}"
    },
    "revolutClientSecret": {
      "value": "${REVOLUT_CLIENT_SECRET}"
    },
    "revolutSignerBaseUrl": {
        "value": "${REVOLUT_SIGNER_BASE_URL}"
    },
    "revolutSignerServiceToken": {
      "value": "${REVOLUT_SIGNER_SERVICE_TOKEN}"
    },
    "revolutRefreshToken": {
      "value": "${REVOLUT_REFRESH_TOKEN}"
    },
    "telegramBotToken": {
      "value": "${TELEGRAM_BOT_TOKEN}"
    },
    "openClawTimezone": {
      "value": "UTC"
    },
    "openClawDisableBonjour": {
      "value": "1"
    }
  }
}
