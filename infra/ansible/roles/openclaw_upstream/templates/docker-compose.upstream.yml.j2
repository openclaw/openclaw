# Managed by Ansible — do not edit manually
# Generated for {{ inventory_hostname }} ({{ openclaw_mode }} mode)
services:
  openclaw-upstream:
    image: {{ openclaw_image_name }}:{{ openclaw_image_tag }}
    container_name: openclaw-upstream
    environment:
      HOME: /home/node
      TERM: xterm-256color
      TZ: {{ openclaw_timezone }}
      OPENCLAW_GATEWAY_TOKEN: "${OPENCLAW_GATEWAY_TOKEN}"
{% if openclaw_mode == 'gateway' %}
      ANTHROPIC_API_KEY: "${ANTHROPIC_API_KEY}"
{% if openclaw_telegram_enabled %}
      TELEGRAM_BOT_TOKEN: "${TELEGRAM_BOT_TOKEN}"
{% endif %}
{% endif %}
{% if openclaw_ollama_host %}
      OLLAMA_HOST: "{{ openclaw_ollama_host }}"
{% endif %}
    env_file:
      - upstream.env
    volumes:
      - ./openclaw-data:/home/node/.openclaw
{% if openclaw_mode == 'gateway' %}
    ports:
      - "{{ openclaw_gateway_port }}:18789"
    command: >
      node dist/index.js gateway
      --bind {{ openclaw_gateway_bind | default('lan') }}
      --port 18789
    healthcheck:
      test:
        - CMD
        - node
        - -e
        - "fetch('http://127.0.0.1:18789/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 20s
{% endif %}
    init: true
    restart: unless-stopped
    networks:
      - {{ openclaw_docker_network }}

networks:
  {{ openclaw_docker_network }}:
    driver: bridge
