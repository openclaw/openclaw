# Managed by Ansible — do not edit manually
# Secrets for {{ inventory_hostname }} ({{ openclaw_mode }} mode)
# Decrypted from SOPS at deploy time

OPENCLAW_GATEWAY_TOKEN={{ openclaw_gateway_token }}
# Anthropic OAuth credentials are stored in auth-profiles.json (deployed via SOPS),
# not as env vars. ANTHROPIC_OAUTH_TOKEN can optionally be set here as a fallback.
{% if openclaw_anthropic_oauth_token | default('') %}
ANTHROPIC_OAUTH_TOKEN={{ openclaw_anthropic_oauth_token }}
{% endif %}
{% if openclaw_mode == 'gateway' %}
{% if openclaw_telegram_enabled | default(false) %}
TELEGRAM_BOT_TOKEN={{ openclaw_telegram_bot_token }}
{% endif %}
{% endif %}
{% if openclaw_ollama_host %}
OLLAMA_HOST={{ openclaw_ollama_host }}
{% endif %}
