# Managed by Ansible — do not edit manually
# Secrets for {{ inventory_hostname }} ({{ openclaw_mode }} mode)
# Decrypted from SOPS at deploy time
#
# ╔═══════════════════════════════════════════════════════════════════╗
# ║  CRITICAL: NO OPENAI_API_KEY variable here. All LLM traffic      ║
# ║  uses OpenAI OAuth (openai-codex provider). The only API key     ║
# ║  is OPENAI_EMBEDDINGS_API_KEY for text-embedding-3-small.        ║
# ║  DO NOT add OPENAI_API_KEY — it causes auth confusion.           ║
# ╚═══════════════════════════════════════════════════════════════════╝

OPENCLAW_GATEWAY_TOKEN={{ openclaw_gateway_token }}
{% if openclaw_openai_embeddings_api_key | default('') %}
# EMBEDDINGS ONLY — never used for chat/completions/responses
OPENAI_EMBEDDINGS_API_KEY={{ openclaw_openai_embeddings_api_key }}
{% endif %}
{% if openclaw_mode == 'gateway' %}
{% if openclaw_telegram_enabled | default(false) %}
TELEGRAM_BOT_TOKEN={{ openclaw_telegram_bot_token }}
{% endif %}
{% endif %}
{% if openclaw_ollama_host %}
OLLAMA_HOST={{ openclaw_ollama_host }}
{% endif %}
