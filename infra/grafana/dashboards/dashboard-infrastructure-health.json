          "expr": "((node_filesystem_size_bytes{cluster=\"$cluster\",mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_avail_bytes{cluster=\"$cluster\",mountpoint=\"/\",fstype!=\"tmpfs\"}) / node_filesystem_size_bytes{cluster=\"$cluster\",mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100",
          "interval": "",
          "legendFormat": "{{ device }}",
          "refId": "A"
        }
