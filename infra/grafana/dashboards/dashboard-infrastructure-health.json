      "pluginVersion": "9.0.0",
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes{cluster=\"$cluster\"} - node_memory_MemAvailable_bytes{cluster=\"$cluster\"}) / node_memory_MemTotal_bytes{cluster=\"$cluster\"}) * 100",
          "interval": "",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ],
      "title": "2. Node Memory %",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
