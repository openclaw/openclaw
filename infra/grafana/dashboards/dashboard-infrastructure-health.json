          "instant": true,
          "interval": "",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "9. Pod Restart Count (>3 in 1h)",
      "transformations": [
        {
          "id": "filterFieldByValue",
          "options": {
            "config": {
              "id": "restarts",
              "options": {
                "match": "gt",
                "value": "3"
              }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
