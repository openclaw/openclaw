        {
          "expr": "((kubelet_volume_stats_used_bytes{cluster=\"$cluster\",persistentvolumeclaim=~\".*prometheus.*|.*loki.*|.*grafana.*\"} / kubelet_volume_stats_capacity_bytes{cluster=\"$cluster\",persistentvolumeclaim=~\".*prometheus.*|.*loki.*|.*grafana.*\"}) * 100)",
          "interval": "",
          "legendFormat": "{{ persistentvolumeclaim }}",
          "refId": "A"
