  "tags": ["router", "performance", "latency", "debugging"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(clarityrouter_requests_total, cluster)",
        "hide": 0,
        "includeAll": false,
        "label": "Cluster",
        "multi": false,
        "name": "cluster",
        "options": [],
        "query": {
          "query": "label_values(clarityrouter_requests_total, cluster)",
