      "pluginVersion": "9.0.0",
      "targets": [
        {
          "expr": "topk(10, ((clarityrouter_errors_total{cluster=\"$cluster\"} / clarityrouter_requests_total{cluster=\"$cluster\"}) * 100) by (endpoint))",
          "interval": "",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ],
      "title": "4. Top 10 Highest Error Rate",
      "type": "bargauge"
    },
