_BRIDGE_TOKEN = None
_BRIDGE_TOKEN_LOADED = False

def _get_bridge_token():
    """Load bridge_token from config.json (cached)."""
    global _BRIDGE_TOKEN, _BRIDGE_TOKEN_LOADED
    if _BRIDGE_TOKEN_LOADED:
        return _BRIDGE_TOKEN
    _BRIDGE_TOKEN_LOADED = True
    cfg_path = Path(__file__).resolve().parent.parent.parent / "skills" / "telegram-userbot" / "config.json"
    try:
        cfg = json.loads(cfg_path.read_text())
        _BRIDGE_TOKEN = cfg.get("bridge_token")
    except Exception:
        pass
    return _BRIDGE_TOKEN

def _bridge_headers(extra=None):
    """Build request headers with auth token."""
    headers = {}
    if extra:
        headers.update(extra)
    token = _get_bridge_token()
    if token:
        headers["Authorization"] = f"Bearer {token}"
    return headers

BRIDGE_IDENTITY = {
    "andrew": "Andrew-Plat-D (G9/24Bet)",
    "dufu":   "杜甫-Data (BG666)",
    "eric":   "Eric (求職協議號)",
}


def _parse_schedule(val):
    """Parse schedule value → unix timestamp.

    Formats:
        30m / 1h / 2h30m  → relative delay
        18:00 / 14:30     → today at that time (or tomorrow if past)
        2026-03-09 10:00  → absolute datetime
    """
    from datetime import datetime, timedelta, timezone
    tz = timezone(timedelta(hours=8))
    now = datetime.now(tz)

    # Relative: 30m, 1h, 2h30m
    import re
    rel = re.match(r'^(?:(\d+)h)?(?:(\d+)m)?$', val)
    if rel and (rel.group(1) or rel.group(2)):
        hours = int(rel.group(1) or 0)
        mins = int(rel.group(2) or 0)
        ts = now + timedelta(hours=hours, minutes=mins)
        return int(ts.timestamp()), ts.strftime("%H:%M")

    # Time only: 18:00
    time_match = re.match(r'^(\d{1,2}):(\d{2})$', val)
    if time_match:
        h, m = int(time_match.group(1)), int(time_match.group(2))
        ts = now.replace(hour=h, minute=m, second=0, microsecond=0)
        if ts <= now:
            ts += timedelta(days=1)
        return int(ts.timestamp()), ts.strftime("%m/%d %H:%M")

    # Absolute: 2026-03-09 10:00
    try:
        ts = datetime.strptime(val, "%Y-%m-%d %H:%M").replace(tzinfo=tz)
        return int(ts.timestamp()), ts.strftime("%m/%d %H:%M")
    except ValueError:
        return None, None


def _no_proxy_opener():
    """Create urllib opener that bypasses system proxy for local connections."""
    import urllib.request
    return urllib.request.build_opener(urllib.request.ProxyHandler({}))


def _resolve_self_id(bridge_name):
    """Get the user_id of the bridge account (for Saved Messages)."""
    import urllib.request
    url = BRIDGE_URLS[bridge_name]
    try:
        req = urllib.request.Request(f"{url}/health")
        with _no_proxy_opener().open(req, timeout=5) as resp:
            result = json.loads(resp.read())
            return str(result.get("user_id", ""))
    except Exception:
        return None


def _tg_send(bridge_name, chat_id, text, file_path=None, schedule=None):
    """Send message via specified bridge. Returns (ok, result_dict)."""
    import urllib.request
    url = BRIDGE_URLS[bridge_name]
    # Resolve "me" to actual user_id
    if chat_id == "me":
        chat_id = _resolve_self_id(bridge_name)
        if not chat_id:
            return False, {"error": f"{bridge_name} bridge unreachable"}
    payload = {"chat": str(chat_id), "text": text}
    if file_path:
        payload["file"] = str(file_path)
    if schedule:
        payload["schedule"] = schedule
    data = json.dumps(payload).encode()
    req = urllib.request.Request(
        f"{url}/send", data=data,
        headers=_bridge_headers({"Content-Type": "application/json"}), method="POST"
    )
    try:
        with _no_proxy_opener().open(req, timeout=15) as resp:
            result = json.loads(resp.read())
            return result.get("ok", False), result
    except Exception as e:
        return False, {"error": str(e)}


def _resolve_contact(name):
    """Resolve contact alias → (chat_id, bridge_name) or None."""
    name_lower = name.lower()
    if name_lower in CONTACTS:
        return CONTACTS[name_lower]
    # Try matching from sentinel config groups
    try:
        config = json.loads((SENTINEL_ROOT / "config.json").read_text())
        for gid, info in config.get("groups", {}).items():
            if name_lower in info.get("name", "").lower():
                return (gid, info["bridge"])
        for uid, info in config.get("private_chats", {}).get("dufu", {}).items():
            if name_lower in info.get("name", "").lower():
                return (uid, "dufu")
    except Exception:
        pass
    return None


def _parse_msg_args(args, allow_bridge_flag=False):
    """Parse common args: --file, --at, [-d], message parts.

    Returns (file_path, schedule_ts, schedule_display, bridge_override, msg_parts).
    """
    file_path = None
    schedule_ts = None
    schedule_display = None
    bridge_override = None
    msg_parts = []

    i = 0
    while i < len(args):
        if allow_bridge_flag and args[i] == "-d":
            bridge_override = "dufu"
        elif args[i] == "--file" and i + 1 < len(args):
            file_path = args[i + 1]
            i += 1
        elif args[i] == "--at" and i + 1 < len(args):
            schedule_ts, schedule_display = _parse_schedule(args[i + 1])
            if schedule_ts is None:
                print(f"  Invalid schedule format: {args[i + 1]}")
                print("  Formats: 30m, 1h, 2h30m, 18:00, 2026-03-09 10:00")
                return None
            i += 1
        else:
            msg_parts.append(args[i])
        i += 1

    return file_path, schedule_ts, schedule_display, bridge_override, msg_parts


def cmd_sm(args):
    """wuji sm [-d] [--file F] [--at TIME] "message" — Draft to Saved Messages.
    Default: Andrew's SM. Use -d for 杜甫's SM."""
    parsed = _parse_msg_args(args, allow_bridge_flag=True)
    if parsed is None:
        return
    file_path, schedule_ts, schedule_display, bridge_override, msg_parts = parsed
    bridge = bridge_override or "andrew"

    if not msg_parts:
        print("Usage: wuji sm [-d] [--file F] [--at TIME] \"message\"")
        print("  -d          Use 杜甫 SM (BG666)")
        print("  --file F    Attach file")
        print("  --at TIME   Schedule: 30m, 1h, 18:00, 2026-03-09 10:00")
        return

    text = " ".join(msg_parts)
    sched_info = f" (scheduled: {schedule_display})" if schedule_ts else ""
    print(f"  Sending to {BRIDGE_IDENTITY[bridge]} Saved Messages...{sched_info}")
    ok, result = _tg_send(bridge, "me", text, file_path, schedule_ts)
    if ok:
        print(f"  OK  msg_id={result.get('message_id')}{sched_info}")
    else:
        print(f"  FAIL  {result.get('error', result)}")


def cmd_send(args):
    """wuji send <contact> [--file F] [--at TIME] "message" — Send to contact."""
    if len(args) < 2:
        print("Usage: wuji send <contact> [--file F] [--at TIME] \"message\"")
        print("  wuji send sm \"hello\"")
        print("  wuji send 考勤 --at 30m \"1\"             # 30分钟后发")
        print("  wuji send 項目組 --at 18:00 \"日报\"       # 今天18:00发")
        print("  wuji send sm --file report.csv \"see attached\"")
        print("  wuji contacts   — list available contacts")
        return

    target = args[0]
    resolved = _resolve_contact(target)
    if not resolved:
        print(f"  Unknown contact: {target}")
        print(f"  Run 'wuji contacts' to see available contacts.")
        return

    chat_id, bridge = resolved
    parsed = _parse_msg_args(args[1:])
    if parsed is None:
        return
    file_path, schedule_ts, schedule_display, _, msg_parts = parsed

    if not schedule_ts:
        print("  必须指定 --at 排程时间。直接发送已禁用。")
        print("  例: wuji tg send 項目組 --at 5m \"内容\"")
        return

    if not msg_parts:
        print("  No message provided.")
        return

    text = " ".join(msg_parts)
    sched_info = f" (scheduled: {schedule_display})"
    print(f"  [{BRIDGE_IDENTITY[bridge]}] → {target} ({chat_id}){sched_info}")
    ok, result = _tg_send(bridge, chat_id, text, file_path, schedule_ts)
    if ok:
        print(f"  OK  msg_id={result.get('message_id')}{sched_info}")
    else:
        print(f"  FAIL  {result.get('error', result)}")


def cmd_forward(args):
    """wuji forward <msg_id> <contact> — Forward SM message to contact."""
    if len(args) < 2:
        print("Usage: wuji forward <msg_id> <contact>")
        print("  Forward a Saved Message to a contact.")
        return

    msg_id = args[0]
    target = args[1]
    resolved = _resolve_contact(target)
    if not resolved:
        print(f"  Unknown contact: {target}")
        return

    chat_id, bridge = resolved
    # Read the SM message first, then re-send
    import urllib.request
    url = BRIDGE_URLS[bridge]
    try:
        req = urllib.request.Request(f"{url}/messages?chat=me&limit=50", headers=_bridge_headers())
        with _no_proxy_opener().open(req, timeout=10) as resp:
            messages = json.loads(resp.read())
        # Find the message by ID
        msg = None
        for m in messages:
            if str(m.get("id")) == str(msg_id):
                msg = m
                break
        if not msg:
            print(f"  Message {msg_id} not found in recent SM.")
            return

        text = msg.get("text", "")
        # Check for media/file
        file_path = None
        if msg.get("media"):
            # Download media first
            dl_req = urllib.request.Request(f"{url}/download?chat=me&msg={msg_id}", headers=_bridge_headers())
            with _no_proxy_opener().open(dl_req, timeout=30) as dl_resp:
                dl_result = json.loads(dl_resp.read())
                file_path = dl_result.get("path")

        print(f"  [{BRIDGE_IDENTITY[bridge]}] forwarding msg {msg_id} → {target} ({chat_id})")
        ok, result = _tg_send(bridge, chat_id, text, file_path)
        if ok:
            print(f"  OK  msg_id={result.get('message_id')}")
        else:
            print(f"  FAIL  {result.get('error', result)}")
    except Exception as e:
        print(f"  Error: {e}")


def cmd_tg(args):
    """wuji tg — Unified Telegram operations.

    Subcommands:
        list                     List synced chats
        search <query>           Search across all chats
        <chat> [N] [--my]        Show last N messages (--my = only mine)
        <chat> --search Q        Search in a specific chat
        sm [-d] [--file F] "msg" Draft to Saved Messages
        send <contact> "msg"     Send to contact
        forward <msg_id> <to>    Forward SM message
        contacts                 List contact aliases
    """
    if not args:
        print("  wuji tg — Telegram operations + knowledge digestion")
        print()
        print("  History:")
        print("    wuji tg list                 List synced chats")
        print("    wuji tg search <query>       Search across ALL chats")
        print("    wuji tg <chat> [N]           Show last N messages")
        print("    wuji tg <chat> --my          Show only MY messages")
        print("    wuji tg <chat> --search Q    Search in a chat")
        print()
        print("  Messaging:")
        print("    wuji tg sm \"msg\"              Draft to Andrew SM")
        print("    wuji tg sm -d \"msg\"            Draft to 杜甫 SM")
        print("    wuji tg send <contact> \"msg\"  Send to contact")
        print("    wuji tg send sm --at 18:00 \"test\"")
        print("    wuji tg forward <msg_id> <to>  Forward SM msg")
        print("    wuji tg contacts              List contacts + bridges")
        print()
        print("  River (knowledge digestion):")
        print("    wuji tg digest <river>       Digest a river's new messages")
        print("    wuji tg digest --all         Digest all active rivers")
        print("    wuji tg digest --date D <r>  Digest specific date")
        print("    wuji tg rivers               Show all rivers + status")
        print("    wuji tg atoms [river] [type] Show extracted atoms")
        print("    wuji tg entity [name]        Entity profile / list")
        print("    wuji tg think \"question\"      Cross-river reasoning")
        print("    wuji tg think --auto          Auto-detect contradictions")
        print("    wuji tg decisions [status]    Track decision lifecycle")
        return

    sub = args[0]

    # Messaging subcommands
    if sub == "sm":
        cmd_sm(args[1:])
        return
    if sub == "send":
        cmd_send(args[1:])
        return
    if sub == "forward":
        cmd_forward(args[1:])
        return
    if sub == "contacts":
        cmd_contacts(args[1:])
        return

    # River (knowledge digestion) subcommands
    RIVER_DIR = WORKSPACE / "river"
    if sub == "digest":
        subprocess.run([sys.executable, str(RIVER_DIR / "engine.py"), "digest"] + args[1:])
        return
    if sub == "rivers":
        subprocess.run([sys.executable, str(RIVER_DIR / "engine.py"), "status"])
        return
    if sub == "atoms":
        _tg_atoms(args[1:])
        return
    if sub == "entity":
        _tg_entity(args[1:])
        return
    if sub == "think":
        _tg_think(args[1:])
        return
    if sub == "decisions":
        _tg_decisions(args[1:])
        return
    if sub == "compress":
        RIVER_DIR = WORKSPACE / "river"
        subprocess.run([sys.executable, str(RIVER_DIR / "engine.py"), "compress"] + args[1:])
        return

    # Everything else → chat history query
    _tg_chat(args)


def _tg_atoms(args):
    """Show extracted atoms for a river."""
    import sqlite3 as _sqlite3
    db_path = WORKSPACE / "river" / "data" / "river.db"
    if not db_path.exists():
        print("  River DB not found. Run: wuji tg digest --all")
        return

    conn = _sqlite3.connect(str(db_path))
    conn.row_factory = _sqlite3.Row

    if not args:
        # Show recent atoms across all rivers
        rows = conn.execute(
            "SELECT * FROM atoms ORDER BY created_at DESC LIMIT 30"
        ).fetchall()
    else:
        river_id = args[0]
        atom_type = args[1] if len(args) > 1 else None
        q = "SELECT * FROM atoms WHERE river_id LIKE ?"
        params = [f"%{river_id}%"]
        if atom_type:
            q += " AND type = ?"
            params.append(atom_type)
        q += " ORDER BY created_at DESC LIMIT 50"
        rows = conn.execute(q, params).fetchall()

    if not rows:
        print("  No atoms found.")
        conn.close()
        return

    print(f"\n  {'Type':<10} {'Actor':<15} {'Content':<80} {'River'}")
    print(f"  {'─'*10} {'─'*15} {'─'*80} {'─'*20}")
    for r in rows:
        actor = (r["actor"] or "")[:14]
        content = (r["content"] or "").replace("\n", " ")[:79]
        print(f"  {r['type']:<10} {actor:<15} {content:<80} {r['river_id']}")
    conn.close()
    print()


def _tg_entity(args):
    """Show entity profile."""
    import sqlite3 as _sqlite3
    db_path = WORKSPACE / "river" / "data" / "river.db"
    if not db_path.exists():
        print("  River DB not found.")
        return
    conn = _sqlite3.connect(str(db_path))
    conn.row_factory = _sqlite3.Row

    if not args:
        # List all entities
        rows = conn.execute("SELECT * FROM entities ORDER BY last_seen DESC LIMIT 30").fetchall()
        if not rows:
            print("  No entities yet. Entities are built after atoms are extracted.")
            conn.close()
            return
        print(f"\n  {'Name':<20} {'Type':<12} {'First Seen':<12} {'Last Seen':<12} {'Summary'}")
        print(f"  {'─'*20} {'─'*12} {'─'*12} {'─'*12} {'─'*40}")
        for r in rows:
            fs = (r["first_seen"] or "")[:10]
            ls = (r["last_seen"] or "")[:10]
            summary = (r["summary"] or "")[:40]
            print(f"  {r['name']:<20} {r['type']:<12} {fs:<12} {ls:<12} {summary}")
    else:
        name = " ".join(args)
        rows = conn.execute(
            "SELECT * FROM entities WHERE name LIKE ? COLLATE NOCASE", (f"%{name}%",)
        ).fetchall()
        if not rows:
            print(f"  No entity matching: {name}")
        else:
            for r in rows:
                print(f"\n  Entity: {r['name']} ({r['type']})")
                print(f"  Summary: {r['summary'] or '(none)'}")
                print(f"  First seen: {r['first_seen'] or '?'}")
                print(f"  Last seen: {r['last_seen'] or '?'}")
                aliases = json.loads(r["aliases"])
                if aliases:
                    print(f"  Aliases: {', '.join(aliases)}")
                # Show related atoms
                atoms = conn.execute(
                    "SELECT * FROM atoms WHERE actor LIKE ? OR target LIKE ? ORDER BY created_at DESC LIMIT 10",
                    (f"%{r['name']}%", f"%{r['name']}%")
                ).fetchall()
                if atoms:
                    print(f"\n  Recent atoms:")
                    for a in atoms:
                        content = (a["content"] or "").replace("\n", " ")[:100]
                        print(f"    ({a['type']}) {content}")
    conn.close()
    print()


def _tg_think(args):
    """Cross-river reasoning."""
    RIVER_DIR = WORKSPACE / "river"
    if not args:
        print("  Usage:")
        print("    wuji tg think \"问题\"")
        print("    wuji tg think --auto")
        return
    subprocess.run([sys.executable, str(RIVER_DIR / "think.py")] + args)


def _tg_decisions(args):
    """Show tracked decisions."""
    import sqlite3 as _sqlite3
    db_path = WORKSPACE / "river" / "data" / "river.db"
    if not db_path.exists():
        print("  River DB not found.")
        return
    conn = _sqlite3.connect(str(db_path))
    conn.row_factory = _sqlite3.Row

    status_filter = args[0] if args else None
    q = "SELECT * FROM decisions"
    params = []
    if status_filter:
        q += " WHERE status = ?"
        params.append(status_filter)
    q += " ORDER BY created_at DESC LIMIT 30"

    rows = conn.execute(q, params).fetchall()
    if not rows:
        print("  No decisions tracked yet.")
        conn.close()
        return

    print(f"\n  {'Status':<12} {'By':<12} {'Title':<50} {'Date'}")
    print(f"  {'─'*12} {'─'*12} {'─'*50} {'─'*12}")
    for r in rows:
        dt = (r["proposed_at"] or r["created_at"] or "")[:10]
        by = (r["proposed_by"] or "?")[:11]
        title = (r["title"] or "")[:49]
        print(f"  {r['status']:<12} {by:<12} {title:<50} {dt}")
    conn.close()
    print()


def cmd_contacts(args=None):
    """wuji contacts — List all contact aliases."""
    print("  Contact aliases (hardcoded bridge binding):")
    print()
    print("  === Andrew (G9/24Bet) ===")
    for name, (cid, bridge) in sorted(CONTACTS.items()):
        if bridge == "andrew":
            print(f"    {name:12s} → {cid}")
    print()
    print("  === 杜甫 (BG666) ===")
    for name, (cid, bridge) in sorted(CONTACTS.items()):
        if bridge == "dufu":
            print(f"    {name:12s} → {cid}")
    print()
    print("  CRITICAL: Bridges are identity-bound. No cross-sending allowed.")


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        return

    # Top-level commands (no agent required)
    if args[0] == "list":
        cmd_list()
        return

    if args[0] == "overview":
        cmd_overview()
        return

    if args[0] == "search":
        query = " ".join(args[1:])
        cmd_search(query)
        return

    if args[0] == "radar":
        cmd_radar(args[1:])
        return

    if args[0] == "pulse":
        cmd_pulse()
        return

    if args[0] == "experience":
        cmd_experience(args[1:])
        return

    if args[0] == "digest":
        cmd_digest(args[1:])
        return

    if args[0] == "sessions":
        cmd_sessions(args[1:])
        return

    if args[0] == "audit":
        cmd_audit(args[1:])
        return

    if args[0] == "bulletin":
        cmd_bulletin(args[1:])
        return

    if args[0] == "dashboard":
        cmd_global_dashboard()
        return

    if args[0] == "tg":
        cmd_tg(args[1:])
        return

    if args[0] == "chat":
        cmd_chat(args[1:])
        return

    if args[0] == "db":
        cmd_db(args[1:])
        return

    if args[0] == "jarvis":
        subprocess.run([sys.executable, str(Path(__file__).parent / "jarvis-status")])
        return

    if args[0] == "sm":
        cmd_sm(args[1:])
        return

    if args[0] == "send":
        cmd_send(args[1:])
        return

    if args[0] == "forward":
        cmd_forward(args[1:])
        return

    if args[0] == "contacts":
        cmd_contacts(args[1:])
        return

    # Agent dispatch
    agent_id = args[0]
    agent = _find_agent(agent_id)
    if agent is None:
        print(f"  Unknown agent: {agent_id}")
        print(f"  Run 'wuji list' to see available agents.")
        sys.exit(1)

    command_args = args[1:]
    extra_commands = load_agent_cli(agent)

    if not command_args or command_args[0] in ("-h", "--help", "help"):
        print_agent_help(agent, extra_commands)
        return

    command = command_args[0]
    rest = command_args[1:]

    # Try generic first
    if command in GENERIC_COMMANDS:
        run_generic(agent, command, rest)
        return

    # Try agent-specific
    if extra_commands:
        handler, handler_args = resolve_command(extra_commands, command_args)
        if handler:
            handler(agent, handler_args)
            return

    print(f"  Unknown command: {command}")
    print_agent_help(agent, extra_commands)
    sys.exit(1)


if __name__ == "__main__":
    main()
