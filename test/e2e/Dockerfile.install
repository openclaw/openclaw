# Dockerfile for verifying Gemmaclaw installs from a clean Node-only environment.
#
# This validates the recommended install path from the README:
#   git clone → pnpm install → pnpm build → npm install -g .
#
# Usage:
#   docker build -f test/e2e/Dockerfile.install .
#
# The build succeeds only if all acceptance criteria pass:
#   1. git clone + pnpm install + pnpm build exits 0
#   2. npm install -g . exits 0
#   3. gemmaclaw --version prints a version string
#   4. gemmaclaw --help runs without error

FROM node:22-bookworm

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*
RUN npm config set fund false \
  && npm config set audit false

# Enable corepack for pnpm (ships with Node 22+).
RUN corepack enable

WORKDIR /build

# Clone from GitHub, install, build, and install globally.
RUN git clone --depth 1 https://github.com/gemmaclaw/gemmaclaw.git .
RUN pnpm install --frozen-lockfile
RUN pnpm build
RUN npm install -g .

# Verify the CLI works from a clean directory (not the repo).
WORKDIR /tmp
RUN gemmaclaw --version
RUN gemmaclaw --help > /dev/null
