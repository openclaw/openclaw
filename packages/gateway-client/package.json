{
  "name": "@openclaw/gateway-client",
  "version": "0.1.0",
  "description": "WebSocket client SDK for OpenClaw gateway with React hooks",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
