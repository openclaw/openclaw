{
  "name": "@openclaw/agent-sdk",
  "version": "0.0.0-private",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./test": {
      "types": "./dist/test.d.mts",
      "import": "./dist/test.mjs",
      "default": "./dist/test.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/hash.ts src/commands/validate.ts src/test.ts --no-config --platform node --format esm --dts --out-dir dist --clean"
  },
  "dependencies": {
    "@openclaw/agent-core": "workspace:*",
    "commander": "14.0.3"
  }
}
