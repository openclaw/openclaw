# ClaWorks Robot 配置文件示例
# 复制为 .env 并填写以下值：
#   cp .env.example .env

# === 机器人基础配置 ===
CLAWORKS_ROBOT_ID=my-robot
CLAWORKS_ROBOT_NAME=工厂助手
CLAWORKS_OWNER_USER_ID=         # 飞书用户 ID，机器人的主人

# === LLM 配置 ===
# 本地 Ollama（推荐）
OLLAMA_BASE_URL=http://localhost:11434
CLAWORKS_DEFAULT_MODEL=qwen2.5:7b

# 云端 API（可选，与 Ollama 二选一或并用）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# CLAWORKS_LLM_MODEL=gpt-4o-mini

# === 飞书配置（可选，不配置则不启用飞书 IM）===
# FEISHU_APP_ID=cli_...
# FEISHU_APP_SECRET=...
# FEISHU_VERIFICATION_TOKEN=...

# === 服务端口 ===
CLAWORKS_PORT=3100

# === 互联网搜索（可选）===
# SEARXNG_URL=http://localhost:8080  # 自托管 SearXNG
# BRAVE_SEARCH_API_KEY=              # Brave Search API Key
# SERPER_API_KEY=                    # Serper API Key

# === OpenClaw 集成（自动检测，通常不需要手动配置）===
# OPENCLAW_CONFIG_PATH=~/.openclaw/agents/my-agent

# === 高级配置（通常不需要修改）===
# CLAWORKS_GATEWAY_PORT=18800       # OpenClaw Gateway 端口（默认 18800）
# CLAWORKS_RATE_LIMIT_PER_MIN=120   # 速率限制（每分钟最大请求数）
# CLAWORKS_FORCE_ONBOARDING=1       # 强制重新执行开箱配置
# CLAWORKS_SKIP_ONBOARDING=1        # 跳过开箱配置（适用于测试）
# CLAWORKS_AUTONOMY_VERBOSE=1       # 自主引擎详细日志
