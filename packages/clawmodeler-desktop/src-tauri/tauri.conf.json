{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawModeler",
  "version": "0.1.0",
  "identifier": "ai.openclaw.clawmodeler",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm sidecar:build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../../../dist/clawmodeler-desktop"
  },
  "app": {
    "windows": [
      {
        "title": "ClawModeler",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["binaries/clawmodeler-engine"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"]
  }
}
