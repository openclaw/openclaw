{ 
   "name": "openclaw", 
   "version": "1.0.0", 
   "description": "OpenClaw Gateway with WebSocket support for Railway deployment", 
   "main": "openclaw.mjs", 
   "type": "module", 
   "scripts": { 
     "start": "node openclaw.mjs gateway --allow-unconfigured --bind 0.0.0.0 --port 18789 --config config.json", 
     "dev": "node --watch openclaw.mjs gateway --allow-unconfigured --bind 0.0.0.0 --port 18789 --config config.json", 
     "test": "echo \"Error: no test specified\" && exit 1" 
   }, 
   "dependencies": { 
     "ws": "^8.18.0", 
     "dotenv": "^16.4.5", 
     "node-fetch": "^3.3.2", 
     "http-proxy": "^1.18.1" 
   }, 
   "devDependencies": { 
     "nodemon": "^3.1.0" 
   }, 
   "engines": { 
     "node": ">=22.12.0" 
   }, 
   "keywords": ["openclaw", "websocket", "gateway", "railway"], 
   "author": "", 
   "license": "MIT" 
 }
