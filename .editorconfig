# EditorConfig is awesome: https://EditorConfig.org\n\n# top-most EditorConfig file\nroot = true\n\n# Unix-style newlines with a newline ending every file\n[*]\ncharset = utf-8\nend_of_line = lf\ninsert_final_newline = true\ntrim_trailing_whitespace = true\n\n# TypeScript, JavaScript, and JSON files\n[*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}]\nindent_style = space\nindent_size = 2\n\n# JSON files\n[*.json]\nindent_style = space\nindent_size = 2\n\n# YAML files\n[*.{yml,yaml}]\nindent_style = space\nindent_size = 2\n\n# Markdown files\n[*.md]\ntrim_trailing_whitespace = false\nindent_style = space\nindent_size = 2\n\n# HTML and CSS files\n[*.{html,css,scss,less}]\nindent_style = space\nindent_size = 2\n\n# XML and SVG files\n[*.{xml,svg}]\nindent_style = space\nindent_size = 2\n\n# Shell scripts\n[*.{sh,bash,zsh}]\nindent_style = space\nindent_size = 2\n\n# Python files\n[*.py]\nindent_style = space\nindent_size = 4\n\n# Go files\n[*.go]\nindent_style = tab\nindent_size = 4\n\n# Makefiles\n[{Makefile,makefile,*.mk}]\nindent_style = tab\nindent_size = 4\n\n# Docker files\n[{Dockerfile*,*.dockerfile}]\nindent_style = space\nindent_size = 2\n\n# Configuration files\n[*.{ini,cfg,conf,toml}]\nindent_style = space\nindent_size = 2\n\n# Package files\n[{package.json,package-lock.json,yarn.lock,pnpm-lock.yaml,bun.lock*}]\nindent_style = space\nindent_size = 2\n\n# Ignore binary files and generated content\n[*.{png,jpg,jpeg,gif,ico,svg,woff,woff2,eot,ttf,otf}]\ncharset = unset\nend_of_line = unset\ninsert_final_newline = unset\ntrim_trailing_whitespace = unset\n\n# Generated files and build artifacts\n[{dist/**,build/**,coverage/**,node_modules/**}]\ncharset = unset\nend_of_line = unset\ninsert_final_newline = unset\ntrim_trailing_whitespace = unset\n"