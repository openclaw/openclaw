      "placeholder": "memory_get",
      "advanced": true
    },
    "storeTool": {
      "label": "Store Tool",
      "placeholder": "memory_store",
      "advanced": true
    },
    "statusTool": {
      "label": "Status Tool",
      "placeholder": "memory_status",
      "advanced": true
    },
    "timeoutMs": {
