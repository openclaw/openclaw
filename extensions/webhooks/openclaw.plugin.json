{
  "id": "webhooks",
  "activation": {
    "onStartup": true
  },
  "name": "Webhooks",
  "description": "Authenticated inbound webhooks that bind external automation to OpenClaw TaskFlows.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "$defs": {
      "secretRef": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source": {
            "type": "string",
            "enum": ["env", "file", "exec"]
          },
          "provider": { "type": "string" },
          "id": { "type": "string" }
        },
        "required": ["source", "provider", "id"]
      },
      "secretInput": {
        "anyOf": [{ "type": "string", "minLength": 1 }, { "$ref": "#/$defs/secretRef" }]
      },
      "auth": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["bearer", "header", "hmac-sha256"]
          },
          "secret": { "$ref": "#/$defs/secretInput" },
          "header": { "type": "string", "minLength": 1 },
          "prefix": { "type": "string" }
        },
        "required": ["mode", "secret"]
      },
      "dispatch": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["ack", "taskflow"]
          }
        },
        "required": ["mode"]
      },
      "event": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "header": { "type": "string", "minLength": 1 },
          "payloadPath": { "type": "string", "minLength": 1 }
        }
      },
      "idempotency": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "header": { "type": "string", "minLength": 1 },
          "payloadPath": { "type": "string", "minLength": 1 },
          "ttlHours": { "type": "number", "exclusiveMinimum": 0 }
        }
      },
      "route": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "path": { "type": "string", "minLength": 1 },
          "sessionKey": { "type": "string", "minLength": 1 },
          "secret": { "$ref": "#/$defs/secretInput" },
          "auth": { "$ref": "#/$defs/auth" },
          "dispatch": { "$ref": "#/$defs/dispatch" },
          "events": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "event": { "$ref": "#/$defs/event" },
          "idempotency": { "$ref": "#/$defs/idempotency" },
          "controllerId": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "properties": {
      "routes": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/$defs/route"
        }
      }
    }
  }
}
