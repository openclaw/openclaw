{
  "name": "@mullusi/nextcloud-talk",
  "version": "2026.4.4",
  "description": "Mullusi Nextcloud Talk channel plugin",
  "type": "module",
  "devDependencies": {
    "mullusi": "workspace:*"
  },
  "peerDependencies": {
    "mullusi": ">=2026.4.4"
  },
  "peerDependenciesMeta": {
    "mullusi": {
      "optional": true
    }
  },
  "mullusi": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@mullusi/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.4"
    },
    "compat": {
      "pluginApi": ">=2026.4.4"
    },
    "build": {
      "mullusiVersion": "2026.4.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
