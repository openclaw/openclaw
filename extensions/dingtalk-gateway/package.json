        "dtgw"
      ],
      "order": 71
    },
    "install": {
      "npmSpec": "@openclaw/dingtalk-gateway",
      "localPath": "extensions/dingtalk-gateway",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {
    "dingtalk-stream": "^2.1.4",
    "kafkajs": "^2.2.4",
    "openclaw": "workspace:*"
  },
  "repository": "https://github.com/openclaw/openclaw.git"
}
