{
    "id": "claworks-robot",
    "name": "ClaWorks Robot",
    "description": "ClaWorks industrial robot runtime — EventKernel · DataPlane · OrchPlane · A2A",
    "version": "0.1.0-alpha",
    "activation": {
        "onStartup": true
    },
    "provides": [
        "service",
        "tools"
    ],
    "configSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "production_mode": {
                "type": "boolean",
                "description": "Production mode: stub Playbook steps fail-closed"
            },
            "api": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "api_key": { "type": "string" },
                    "require_api_key": { "type": "boolean" },
                    "mcp_require_auth": { "type": "boolean" }
                }
            },
            "security": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                    "require_https_a2a": { "type": "boolean" },
                    "ip_whitelist": {
                        "type": "array",
                        "items": { "type": "string" }
                    }
                }
            },
            "kernel": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                    "rate_limit_max_requests": { "type": "number" },
                    "rate_limit_window_ms": { "type": "number" },
                    "hitl_timeout_seconds": { "type": "number" }
                }
            },
            "robot": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "role": {
                        "type": "string",
                        "enum": [
                            "monolith",
                            "twin",
                            "ops",
                            "nexus"
                        ]
                    },
                    "port": {
                        "type": "number"
                    },
                    "host": {
                        "type": "string"
                    }
                }
            },
            "data": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                    "database_url": {
                        "type": "string"
                    },
                    "kb_path": {
                        "type": "string"
                    },
                    "kb_provider": {
                        "type": "string",
                        "enum": [
                            "stub",
                            "memory-core"
                        ]
                    },
                    "memory_agent_id": {
                        "type": "string"
                    },
                    "kb_embed_model": {
                        "type": "string"
                    }
                }
            },
            "model_router": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                    "default": { "type": "string" },
                    "fast": { "type": "string" },
                    "embed": { "type": "string" },
                    "chat": { "type": "string" },
                    "complete": { "type": "string" }
                }
            },
            "a2a": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                    "enabled": { "type": "boolean" },
                    "endpoint": { "type": "string" },
                    "peers": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "packs": {
                "type": "object",
                "additionalProperties": true
            },
            "notify": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "default_channel": {
                        "type": "string"
                    },
                    "targets": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "channel": {
                                    "type": "string"
                                },
                                "to": {
                                    "type": "string"
                                },
                                "accountId": {
                                    "type": "string"
                                },
                                "threadId": {}
                            },
                            "required": [
                                "channel",
                                "to"
                            ]
                        }
                    }
                }
            },
            "im_bridge": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "auto_on_message_received": {
                        "type": "boolean",
                        "description": "Route incoming IM messages into EventKernel intent classify"
                    }
                }
            },
            "connectors": {
                "type": "object",
                "additionalProperties": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                        "preset": {
                            "type": "string",
                            "enum": [
                                "echo",
                                "rest-poll",
                                "mqtt",
                                "opcua",
                                "modbus",
                                "filesystem-kb"
                            ]
                        },
                        "enabled": {
                            "type": "boolean"
                        },
                        "simulate": {
                            "type": "boolean",
                            "description": "Use simulate preset variant for dev/test (disabled when production_mode=true)"
                        },
                        "command": {
                            "type": "string"
                        },
                        "args": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "cwd": {
                            "type": "string"
                        },
                        "env": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        },
                        "auto_start": {
                            "oneOf": [
                                { "type": "boolean" },
                                {
                                    "type": "object",
                                    "additionalProperties": true,
                                    "properties": {
                                        "method": { "type": "string" },
                                        "params": { "type": "object" }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        }
    },
    "services": [
        {
            "id": "claworks-kernel",
            "description": "ClaWorks EventKernel — autonomous event loop and playbook execution"
        }
    ],
    "skills": [
        "./skills"
    ],
    "contracts": {
        "tools": [
            "cw_agent_chat",
            "cw_alarm_summary",
            "cw_bridge_im_message",
            "cw_create_object",
            "cw_define_object_type",
            "cw_doctor_run",
            "cw_get_identity",
            "cw_get_object",
            "cw_hitl_approve",
