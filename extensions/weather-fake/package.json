{
  "name": "@openclaw/weather-fake",
  "version": "2026.2.25",
  "description": "OpenClaw demo weather plugin with deterministic fake data",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@openclaw/weather-fake",
      "localPath": "extensions/weather-fake",
      "defaultChoice": "local"
    }
  }
}