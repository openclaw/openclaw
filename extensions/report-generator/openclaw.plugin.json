{
  "id": "report-generator",
  "name": "Report Generator",
  "description": "Generate舆情 reports from feed data with LLM and send via Mercure/SMTP.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "historyDb": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "host": { "type": "string" },
          "port": { "type": "number" },
          "user": { "type": "string" },
          "password": { "type": "string" },
          "database": { "type": "string" }
        },
        "required": ["host", "user", "password", "database"]
      },
      "mercure": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "hubUrl": { "type": "string" },
          "jwtSecret": { "type": "string" }
        },
        "required": ["hubUrl", "jwtSecret"]
      },
      "rabbitmq": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "host": { "type": "string" },
          "port": { "type": "number" },
          "user": { "type": "string" },
          "password": { "type": "string" },
          "queue": { "type": "string", "default": "ReportTask" }
        },
        "required": ["host", "user", "password"]
      },
      "smtp": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "host": { "type": "string" },
          "port": { "type": "number" },
          "user": { "type": "string" },
          "password": { "type": "string" },
          "from": { "type": "string" }
        }
      },
      "pollIntervalMs": {
        "type": "number",
        "default": 30000
      }
    },
    "required": ["historyDb", "mercure"]
  }
}
