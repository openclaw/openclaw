{
  "id": "memory-core",
  "activation": {
    "onStartup": false
  },
  "kind": "memory",
  "contracts": {
    "memoryEmbeddingProviders": ["local"]
  },
  "runtimeDependencies": {
    "localMemoryEmbedding": ["node-llama-cpp@3.18.1"]
  },
  "commandAliases": [
    {
      "name": "dreaming",
      "kind": "runtime-slash",
      "cliCommand": "memory"
    }
  ],
  "uiHints": {
    "dreaming.frequency": {
      "label": "Dreaming Frequency",
      "placeholder": "0 3 * * *",
      "help": "Optional cron cadence for the full dreaming sweep (light, REM, then deep)."
    },
    "dreaming.model": {
      "label": "Dreaming Model",
      "placeholder": "anthropic/claude-sonnet-4-6",
      "help": "Optional provider/model override for Dream Diary narrative subagent runs. Requires plugins.entries.memory-core.subagent.allowModelOverride."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dreaming": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "frequency": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "verboseLogging": {
            "type": "boolean"
          },
          "storage": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["inline", "separate", "both"]
              },
              "separateReports": {
                "type": "boolean"
              }
            }
          },
          "execution": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "defaults": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "model": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "phases": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "light": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "lookbackDays": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "dedupeSimilarity": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "execution": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "model": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "deep": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "minScore": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "minRecallCount": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "minUniqueQueries": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "recencyHalfLifeDays": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "maxAgeDays": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "execution": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "model": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "rem": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "lookbackDays": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "minPatternStrength": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "execution": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "model": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "sessionFilter": {
            "type": "object",
            "additionalProperties": false,
            "description": "Operator-facing exclusions applied during session-corpus ingestion before content is appended to memory/.dreams/session-corpus/<day>.txt.",
            "properties": {
              "excludeCronJobIds": {
                "type": "array",
                "description": "Skip transcripts whose session key carries any of these cron job ids in a cron:<cronJobId> segment. Match is global across all agents: adding \"sync\" drops agent:main:cron:sync:run:<runId> and agent:ops:cron:sync:run:<runId> alike. For per-agent scoping use excludeSessionKeyPrefixes with a fully qualified prefix such as \"agent:main:cron:sync:\".",
                "maxItems": 1024,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                }
              },
              "excludeSessionKeyPrefixes": {
                "type": "array",
                "description": "Skip transcripts whose session key starts with any of these prefixes, for example agent:main:cron: to skip every cron run for the main agent, or agent:ops: to skip one agent surface.",
                "maxItems": 1024,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                }
              },
              "excludeAgentIds": {
                "type": "array",
                "description": "Skip transcripts owned by any of these agent ids. This affects dreaming ingestion only; the agent still runs normally.",
                "maxItems": 1024,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                }
              },
              "excludeSourcePathRegex": {
                "type": "array",
                "description": "Skip transcripts whose normalized source path matches any of these regular expressions. The path is sessionPathForFile(absPath) output: sessions/<basename> with no agent prefix. For a live transcript that is sessions/<uuid>.jsonl; for a rotated artifact the basename keeps the rotation suffix, such as sessions/<uuid>.jsonl.deleted.<ts>, sessions/<uuid>.jsonl.reset.<ts>, or sessions/<uuid>.trajectory.jsonl.deleted.<ts>. Use a non-anchored pattern or \\.jsonl(?:\\.deleted\\.|\\.reset\\.|$) when matching live plus rotated files. Invalid or unsafe patterns are ignored at runtime with a count-only warning.",
                "maxItems": 32,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                }
              }
            }
          }
        }
      }
    }
  }
}
