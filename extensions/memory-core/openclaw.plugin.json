{
  "id": "memory-core",
  "activation": {
    "onStartup": false
  },
  "kind": "memory",
  "contracts": {
    "memoryEmbeddingProviders": ["local"],
    "tools": ["memory_get", "memory_search", "memory_audit_collect", "memory_audit_stage"]
  },
  "commandAliases": [
    {
      "name": "dreaming",
      "kind": "runtime-slash",
      "cliCommand": "memory"
    }
  ],
  "uiHints": {
    "dreaming.frequency": {
      "label": "Dreaming Frequency",
      "placeholder": "0 3 * * *",
      "help": "Optional cron cadence for the full dreaming sweep (light, REM, then deep)."
    },
    "dreaming.model": {
      "label": "Dreaming Model",
      "placeholder": "anthropic/claude-sonnet-4-6",
      "help": "Optional provider/model override for Dream Diary narrative subagent runs. Requires plugins.entries.memory-core.subagent.allowModelOverride."
    },
    "memoryAudit.agentId": {
      "label": "Memory Audit Agent",
      "placeholder": "main",
      "help": "Agent that receives managed memory audit cron runs and gets memory_audit_* tools."
    },
    "memoryAudit.daily.cron": {
      "label": "Daily Memory Audit Cron",
      "placeholder": "10 6 * * *",
      "help": "Optional daily memory audit review cadence."
    },
    "memoryAudit.weekly.cron": {
      "label": "Weekly Memory Audit Cron",
      "placeholder": "0 21 * * 0",
      "help": "Optional weekly broad memory audit review cadence."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "memoryAudit": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "agentId": {
            "type": "string"
          },
          "sessionTarget": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "delivery": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["none", "announce", "webhook"]
              },
              "channel": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "threadId": {
                "type": "string"
              },
              "accountId": {
                "type": "string"
              }
            }
          },
          "daily": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "cron": {
                "type": "string"
              }
            }
          },
          "weekly": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "cron": {
                "type": "string"
              }
            }
          }
        }
      },
      "dreaming": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "frequency": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "verboseLogging": {
            "type": "boolean"
          },
          "storage": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["inline", "separate", "both"]
              },
              "separateReports": {
                "type": "boolean"
              }
            }
          },
          "execution": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "defaults": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "model": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "phases": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "light": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "lookbackDays": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "dedupeSimilarity": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "execution": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "model": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "deep": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "minScore": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "minRecallCount": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "minUniqueQueries": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "recencyHalfLifeDays": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "maxAgeDays": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "maxPromotedSnippetTokens": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Maximum estimated token count for each short-term recall snippet promoted into MEMORY.md. Provenance metadata remains attached to the entry."
                  },
                  "execution": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "model": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "rem": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "lookbackDays": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "minPatternStrength": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "execution": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "model": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
