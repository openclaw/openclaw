# Development files\nsrc/\ntest/\ntests/\n*.test.ts\n*.test.js\n*.spec.ts\n*.spec.js\ntest-support/\ntest-helpers/\ntest-harness/\n\n# Build artifacts\ndist/\nbuild/\n.tsbuildinfo\n*.tgz\n\n# Dependencies\nnode_modules/\n**/node_modules/\n\n# IDE and editor files\n.vscode/\n.idea/\n*.swp\n*.swo\n*~\n\n# OS generated files\n.DS_Store\n.DS_Store?\n._*\n.Spotlight-V100\n.Trashes\nehthumbs.db\nThumbs.db\n\n# Logs\n*.log\nnpm-debug.log*\nyarn-debug.log*\nyarn-error.log*\nlogs/\n\n# Runtime data\npids\n*.pid\n*.seed\n*.pid.lock\n\n# Coverage and testing\ncoverage/\n.coverage\n.nyc_output\n.jest\n\n# Environment files\n.env\n.env.local\n.env.development.local\n.env.test.local\n.env.production.local\n\n# Package managers\npackage-lock.json\nyarn.lock\npnpm-lock.yaml\nbun.lock\nbun.lockb\n\n# Documentation source (include built docs)\ndocs/\n*.md.bak\n\n# Git\n.git\n.gitignore\n.gitattributes\n\n# CI/CD\n.github/\n.gitlab-ci.yml\n.travis.yml\n.circleci/\n\n# Local development\n.local\n.tmp\ntemp/\n"