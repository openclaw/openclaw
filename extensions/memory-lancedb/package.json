{
  "name": "@openclaw/memory-lancedb",
  "version": "2026.4.12",
  "description": "OpenClaw LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "keywords": [
    "openclaw",
    "memory",
    "lancedb",
    "vector-database",
    "plugin",
    "ai-memory",
    "recall"
  ],
  "author": "OpenClaw Contributors (https://github.com/openclaw/openclaw/graphs/contributors)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/openclaw.git",
    "directory": "extensions/memory-lancedb"
  },
  "bugs": {
    "url": "https://github.com/openclaw/openclaw/issues"
  },
  "homepage": "https://github.com/openclaw/openclaw/tree/main/extensions/memory-lancedb#readme",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@sinclair/typebox": "0.34.49",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@openclaw/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.12"
    },
    "build": {
      "openclawVersion": "2026.4.12"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
