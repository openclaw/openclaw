{
  "name": "@wayazi/rust-plugin",
  "version": "2026.4.1",
  "description": "High-performance OpenClaw plugin powered by Rust",
  "keywords": [
    "cryptography",
    "filesystem",
    "napi-rs",
    "native",
    "openclaw",
    "performance",
    "plugin",
    "rust"
  ],
  "homepage": "https://github.com/Wayazi/openclaw",
  "bugs": {
    "url": "https://github.com/Wayazi/openclaw/issues"
  },
  "license": "MIT",
  "author": "Wayazi",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wayazi/openclaw.git",
    "directory": "extensions/rust-plugin"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.d.ts",
  "files": [
    "src/",
    "native/",
    "index.linux-x64-gnu.node",
    "package.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release ./native",
    "build:debug": "napi build --platform ./native",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest run tests/",
    "test:watch": "vitest watch tests/",
    "version": "napi version"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "@wayazi/rust-plugin-darwin-x64": "2026.4.0",
    "@wayazi/rust-plugin-darwin-arm64": "2026.4.0",
    "@wayazi/rust-plugin-win32-x64-msvc": "2026.4.0",
    "@wayazi/rust-plugin-linux-x64-gnu": "2026.4.0",
    "@wayazi/rust-plugin-linux-x64-musl": "2026.4.0",
    "@wayazi/rust-plugin-linux-arm64-gnu": "2026.4.0",
    "@wayazi/rust-plugin-linux-arm64-musl": "2026.4.0"
  },
  "napi": {
    "name": "rust_plugin",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl"
      ]
    }
  },
  "engines": {
    "node": ">= 18"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "install": {
      "npmSpec": "@wayazi/rust-plugin",
      "localPath": "extensions/rust-plugin",
      "defaultChoice": "npm"
    },
    "release": {
      "publishToNpm": true
    }
  }
}