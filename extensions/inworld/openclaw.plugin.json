{
  "id": "inworld",
  "activation": {
    "onStartup": false
  },
  "enabledByDefault": true,
  "name": "Inworld",
  "description": "OpenClaw Inworld provider plugin for LLM routing and text-to-speech.",
  "providers": ["inworld"],
  "modelIdNormalization": {
    "providers": {
      "inworld": {
        "prefixWhenBare": "inworld"
      }
    }
  },
  "providerEndpoints": [
    {
      "endpointClass": "inworld",
      "hostSuffixes": ["api.inworld.ai"]
    }
  ],
  "providerRequest": {
    "providers": {
      "inworld": {
        "family": "openai"
      }
    }
  },
  "setup": {
    "providers": [
      {
        "id": "inworld",
        "envVars": ["INWORLD_API_KEY"]
      }
    ]
  },
  "providerAuthChoices": [
    {
      "provider": "inworld",
      "method": "api-key",
      "choiceId": "inworld-api-key",
      "choiceLabel": "Inworld API key",
      "groupId": "inworld",
      "groupLabel": "Inworld",
      "groupHint": "API key",
      "onboardingScopes": ["text-inference"],
      "optionKey": "inworldApiKey",
      "cliFlag": "--inworld-api-key",
      "cliOption": "--inworld-api-key <key>",
      "cliDescription": "Inworld API key"
    }
  ],
  "contracts": {
    "speechProviders": ["inworld"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Inworld API key. Must be the Base64 credential string from the Inworld dashboard (used as Authorization: Basic <apiKey>). Falls back to INWORLD_API_KEY env var."
      },
      "baseUrl": {
        "type": "string",
        "description": "Override Inworld API base URL (default https://api.inworld.ai)."
      },
      "voiceId": {
        "type": "string",
        "description": "Voice identifier (default Sarah)."
      },
      "modelId": {
        "type": "string",
        "description": "TTS model id (default inworld-tts-1.5-max)."
      },
      "temperature": {
        "type": "number",
        "minimum": 0,
        "maximum": 2,
        "description": "Sampling temperature 0..2."
      }
    }
  }
}
