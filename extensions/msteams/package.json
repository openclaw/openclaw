{
  "name": "@mullusi/msteams",
  "version": "2026.4.4",
  "description": "Mullusi Microsoft Teams channel plugin",
  "type": "module",
  "dependencies": {
    "@microsoft/teams.api": "2.0.6",
    "@microsoft/teams.apps": "2.0.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "mullusi": "workspace:*"
  },
  "peerDependencies": {
    "mullusi": ">=2026.4.4"
  },
  "peerDependenciesMeta": {
    "mullusi": {
      "optional": true
    }
  },
  "mullusi": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "msteams",
      "label": "Microsoft Teams",
      "selectionLabel": "Microsoft Teams (Teams SDK)",
      "docsPath": "/channels/msteams",
      "docsLabel": "msteams",
      "blurb": "Teams SDK; enterprise support.",
      "aliases": [
        "teams"
      ],
      "order": 60
    },
    "install": {
      "npmSpec": "@mullusi/msteams",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.4"
    },
    "compat": {
      "pluginApi": ">=2026.4.4"
    },
    "build": {
      "mullusiVersion": "2026.4.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
