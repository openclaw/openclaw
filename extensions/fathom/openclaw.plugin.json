      "help": "Fathom External API base URL override.",
      "placeholder": "https://api.fathom.ai/external/v1"
    }
  },
  "contracts": {
    "tools": [
      "fathom_list_meetings",
      "fathom_get_summary",
      "fathom_get_transcript",
      "fathom_list_teams",
      "fathom_list_team_members",
      "fathom_create_webhook",
      "fathom_delete_webhook"
    ]
  },
  "configSchema": {
