{
  "$schema": "https://openclaw.ai/schema/config.v1.json",
  "_comment": "OpenClaw 配置示例 - 安全模型锁定插件配置",
  "_docs": "https://docs.openclaw.ai/configuration",

  // ==========================================================================
  // 插件配置
  // 注意：插件配置必须放在 plugins.entries 下
  // ==========================================================================
  "plugins": {
    "entries": {
      // 启用安全模型锁定插件
      "security-model-lock": {
        // 是否启用插件（默认：true）
        "enabled": true,

        // 插件具体配置
        "config": {
          // 敏感 Skill 列表 - 当 LLM 读取这些 skill 的 SKILL.md 文件时会触发锁定
          // 插件会检测 read 工具的 file_path 参数
          "sensitiveSkills": ["weather"],

          // 安全模型配置 - 当敏感 skill 被调用时会自动切换到此模型
          "secureModel": {
            // Provider 可以是：ollama, openai, anthropic, local 等
            "provider": "ollama",
            // Model 是该 provider 下的具体模型名称
            "model": "llama3.3:8b"
          },

          // 可选：自定义锁定提示消息
          "lockNotice": "检测到敏感 skill 调用，已切换到安全模型。请重新发送消息。",

          // 可选：Skills 目录路径（默认自动检测当前目录和~/.openclaw/skills）
          "skillsDir": "/path/to/your/skills"
        }
      }
    }
  },

  // ==========================================================================
  // 其他 OpenClaw 配置...
  // ==========================================================================

  // 代理默认配置
  "agents": {
    "defaults": {
      // 默认模型（锁定触发前使用）
      "model": {
        "primary": "openai/gpt-4"
      }
    }
  },

  // Gateway 配置
  "gateway": {
    "port": 18789,
    "bind": "loopback"
  }
}
