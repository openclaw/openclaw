{
  "id": "serpapi-search",
  "name": "SerpApi Search",
  "description": "1 universal search tool covering web, news, flights, hotels, maps, shopping, YouTube, scholar, finance, events and 100+ engines via SerpApi",
  "activation": {
    "onStartup": false
  },
  "skills": ["./skills"],
  "providerAuthEnvVars": {
    "serpapi": ["SERPAPI_API_KEY"]
  },
  "setup": {
    "providers": [
      {
        "id": "serpapi",
        "authMethods": ["api-key"],
        "envVars": ["SERPAPI_API_KEY"]
      }
    ]
  },
  "uiHints": {
    "apiKey": {
      "label": "SerpApi API Key",
      "help": "SerpApi API key for all search engines (fallback: SERPAPI_API_KEY env var).",
      "sensitive": true,
      "placeholder": "..."
    },
    "hl": {
      "label": "Default Language",
      "help": "Default language code for all searches (e.g. en, de, uk). Defaults to en."
    }
  },
  "contracts": {
    "webSearchProviders": ["serpapi"],
    "tools": [
      "serpapi_news",
      "serpapi_scholar",
      "serpapi_maps",
      "serpapi_maps_reviews",
      "serpapi_shopping",
      "serpapi_ai_overview",
      "serpapi_amazon",
      "serpapi_amazon_product",
      "serpapi_bing",
      "serpapi_duckduckgo",
      "serpapi_ebay",
      "serpapi_immersive_product",
      "serpapi_jobs",
      "serpapi_lens",
      "serpapi_youtube",
      "serpapi_youtube_transcript",
      "serpapi_youtube_video",
      "serpapi_trends",
      "serpapi_tripadvisor",
      "serpapi_flights",
      "serpapi_hotels",
      "serpapi_events",
      "serpapi_facebook_profile",
      "serpapi_finance",
      "serpapi_yahoo",
      "serpapi_autocomplete"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string"
      },
      "hl": {
        "type": "string",
        "description": "Default language code for all searches (e.g. en, de, ja). Defaults to en."
      },
      "webSearch": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "apiKey": {
            "type": "string"
          }
        }
      }
    }
  }
}
