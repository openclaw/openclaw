# ── Google AI Studio (free: 250 RPD per project) ──
# Get key at https://aistudio.google.com/apikey
# Create multiple Google Cloud projects for higher limits (250 RPD each)
GOOGLE_AI_API_KEY=
# GOOGLE_AI_API_KEY_1=    # Key from project 2
# GOOGLE_AI_API_KEY_2=    # Key from project 3

# ── Groq (free: 14,400 RPD) ──
# Sign up at https://console.groq.com
GROQ_API_KEY=

# ── OpenRouter (free models: 50-1K RPD) ──
# Sign up at https://openrouter.ai
OPENROUTER_API_KEY=

# ── Cerebras (free: 1M tokens/day) ──
# Sign up at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# ── Optional: Anthropic (paid) ──
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Optional: Auto Key Generation ──
# Google Cloud service account for auto-creating API keys
# GOOGLE_SERVICE_ACCOUNT_PATH=~/.openclaw/google-service-account.json
# OpenRouter Management key for auto-creating child keys
# OPENROUTER_MANAGEMENT_KEY=

# ── Optional: Discord Bot ──
# DISCORD_BOT_TOKEN=

# ── Optional: YouTube upload ──
# YOUTUBE_CLIENT_SECRETS=client_secrets.json

# ── Optional: Facebook Page upload ──
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Optional: Zalo Bot ──
# ZALO_OA_ACCESS_TOKEN=
# ZALO_OA_SECRET_KEY=
