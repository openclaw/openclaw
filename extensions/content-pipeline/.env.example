# ── Required ──
# Google AI Studio API key (free) — get at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# ── Optional: Anthropic (only if using anthropic/ models) ──
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Optional: YouTube upload ──
# Path to OAuth2 client secrets JSON from Google Cloud Console
# YOUTUBE_CLIENT_SECRETS=client_secrets.json
# Auth code from OAuth flow (first run only)
# YOUTUBE_AUTH_CODE=

# ── Optional: Facebook Page upload ──
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Optional: Discord Bot ──
# Create bot at https://discord.com/developers/applications
# Enable MESSAGE CONTENT intent in Bot settings
# DISCORD_BOT_TOKEN=

# ── Optional: Zalo Bot ──
# ZALO_OA_ACCESS_TOKEN=
# ZALO_OA_SECRET_KEY=
# ZALO_APP_ID=
