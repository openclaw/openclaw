# ── Google AI Studio (3 projects for key rotation) ──
GOOGLE_AI_API_KEY=
# GOOGLE_AI_API_KEY_1=
# GOOGLE_AI_API_KEY_2=

# ── Groq (free: 14K RPD) ──
GROQ_API_KEY=

# ── OpenRouter (free models) ──
OPENROUTER_API_KEY=

# ── Cerebras (free: 1M tokens/day) ──
CEREBRAS_API_KEY=

# ── Mistral (free tier) ──
MISTRAL_API_KEY=

# ── YouTube OAuth ──
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── Facebook Page ──
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── TikTok (cookie-based upload) ──
# TIKTOK_COOKIES_PATH=~/.openclaw/tiktok-cookies.txt

# ── Cloudflare R2 Storage ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=openclaw-pipeline
R2_MAX_STORAGE_GB=8
R2_RETENTION_DAYS=30

# ── Discord Bot ──
DISCORD_BOT_TOKEN=

# ── Google Service Account (auto key generation) ──
# GOOGLE_SA_CLIENT_EMAIL=
# GOOGLE_SA_PRIVATE_KEY_B64=
# GOOGLE_SA_PROJECT_ID=

# ── Optional: Anthropic (paid) ──
# ANTHROPIC_API_KEY=
