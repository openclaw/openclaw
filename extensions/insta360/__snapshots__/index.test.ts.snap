exports[`insta360 plugin registration > tool schema matches snapshot 1`] = `
{
  "properties": {
    "action": {
      "description": "Camera action: info, status, photo, record_start, record_stop, settings, list_files, download, delete.",
      "enum": [
        "info",
        "status",
        "photo",
        "record_start",
        "record_stop",
        "settings",
        "list_files",
        "download",
        "delete",
      ],
      "type": "string",
    },
