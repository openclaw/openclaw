{
  "id": "rabbitmq-consumer",
  "name": "RabbitMQ Consumer",
  "description": "Consume chat messages from RabbitMQ, process them via OpenClaw subagent, and push responses via Mercure.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rabbitmq": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "host": { "type": "string" },
          "port": { "type": "number" },
          "user": { "type": "string" },
          "password": { "type": "string" },
          "queue": { "type": "string" },
          "reportTaskQueue": { "type": "string", "default": "ReportTask" }
        },
        "required": ["host", "user", "password"]
      },
      "historyDb": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "host": { "type": "string" },
          "port": { "type": "number" },
          "user": { "type": "string" },
          "password": { "type": "string" },
          "database": { "type": "string" }
        },
        "required": ["host", "user", "password", "database"]
      },
      "writerDb": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "host": { "type": "string" },
          "port": { "type": "number" },
          "user": { "type": "string" },
          "password": { "type": "string" },
          "database": { "type": "string" }
        },
        "required": ["host", "user", "password", "database"]
      },
      "mercure": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "hubUrl": { "type": "string" },
          "jwtSecret": { "type": "string" }
        },
        "required": ["hubUrl", "jwtSecret"]
      },
      "oss": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "accessKeyId": { "type": "string" },
          "accessKeySecret": { "type": "string" },
          "bucket": { "type": "string", "default": "leadingnews" },
          "endpoint": { "type": "string", "default": "oss-cn-beijing.aliyuncs.com" },
          "customDomain": { "type": "string", "default": "https://oss.ibtai.com" },
          "pathPrefix": { "type": "string", "default": "ibtai/assistant-agent/outputs" },
          "maxFileSizeMb": { "type": "number", "default": 100 },
          "allowedExtensions": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["accessKeyId", "accessKeySecret"]
      }
    },
    "required": ["rabbitmq", "historyDb", "mercure"]
  }
}
