{
  "name": "@openclaw/diffs",
  "displayName": "Diffs",
  "version": "2026.3.14",
  "private": true,
  "description": "OpenClaw diff viewer plugin",
  "homepage": "https://github.com/openclaw/openclaw/tree/main/extensions/diffs",
  "bugs": {
    "url": "https://github.com/openclaw/openclaw/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/openclaw.git",
    "directory": "extensions/diffs"
