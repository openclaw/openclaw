{
  "name": "@openclaw/copilot-sdk",
  "version": "2026.5.17",
  "description": "OpenClaw Copilot SDK harness plugin (registers a `copilot-sdk` AgentHarness backed by @github/copilot-sdk over JSON-RPC to the bundled GitHub Copilot CLI)",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/openclaw"
  },
  "type": "module",
  "dependencies": {
    "@github/copilot-sdk": "1.0.0-beta.4"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@openclaw/copilot-sdk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.1-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.5.14"
    },
    "build": {
      "openclawVersion": "2026.5.17"
    },
    "release": {
      "publishToClawHub": false,
      "publishToNpm": false
    }
  }
}
