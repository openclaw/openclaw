{
  "id": "workspaces",
  "name": "Workspaces",
  "description": "Agent-composable Workspaces document and control-plane backend.",
  "enabledByDefault": false,
  "activation": {
    "onStartup": true,
    "onCommands": [
      "workspaces"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "gallery": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "allowedOrigins": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "string",
              "maxLength": 2048,
              "pattern": "^https://"
            }
          }
        },
        "required": ["allowedOrigins"]
      }
    }
  },
  "contracts": {
    "tools": [
      "workspace_get",
      "workspace_tab_create",
      "workspace_tab_update",
      "workspace_tab_delete",
      "workspace_tabs_reorder",
      "workspace_widget_add",
      "workspace_widget_update",
      "workspace_widget_move",
      "workspace_widget_remove",
      "workspace_layout_set",
      "workspace_replace",
      "workspace_widget_scaffold",
      "workspace_undo",
      "workspace_data_read"
    ]
  }
}
