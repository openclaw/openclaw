{
  "name": "@openclaw/rcs",
  "version": "2026.6.2",
  "description": "OpenClaw RCS channel plugin for Twilio RCS Business Messaging.",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/openclaw"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*"
  },
  "openclaw": {
