{
  "name": "@openclaw/anthropic-provider",
  "version": "2026.5.26",
  "private": true,
  "description": "OpenClaw Anthropic provider plugin",
  "type": "module",
  "dependencies": {
    "@earendil-works/pi-ai": "0.75.5"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "build": {
      "staticAssets": [
        {
          "source": "./interactive-proxy/wrapper.ts",
          "output": "interactive-proxy/wrapper.ts"
        },
        {
          "source": "./interactive-proxy/mitm-server.ts",
          "output": "interactive-proxy/mitm-server.ts"
        },
        {
          "source": "./interactive-proxy/cert-manager.ts",
          "output": "interactive-proxy/cert-manager.ts"
        },
        {
          "source": "./interactive-proxy/tty-spoof.cjs",
          "output": "interactive-proxy/tty-spoof.cjs"
        }
      ]
    }
  }
}
