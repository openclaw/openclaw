{
  "name": "@mullusi/zalo",
  "version": "2026.4.4",
  "description": "Mullusi Zalo channel plugin",
  "type": "module",
  "dependencies": {
    "undici": "8.0.0"
  },
  "devDependencies": {
    "mullusi": "workspace:*"
  },
  "peerDependencies": {
    "mullusi": ">=2026.4.4"
  },
  "peerDependenciesMeta": {
    "mullusi": {
      "optional": true
    }
  },
  "mullusi": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalo",
      "label": "Zalo",
      "selectionLabel": "Zalo (Bot API)",
      "docsPath": "/channels/zalo",
      "docsLabel": "zalo",
      "blurb": "Vietnam-focused messaging platform with Bot API.",
      "aliases": [
        "zl"
      ],
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@mullusi/zalo",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.4"
    },
    "compat": {
      "pluginApi": ">=2026.4.4"
    },
    "build": {
      "mullusiVersion": "2026.4.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
