{
  "id": "smart-message-handler",
  "name": "Smart Message Handler",
  "version": "1.0.0",
  "description": "Intelligent message batching with dynamic debounce and semantic merging",
  "author": "henry",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable smart message handling"
      },
      "incompleteSignals": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["...", "，", ",", "、", "待续", "continue"],
        "description": "Signals that indicate incomplete input"
      },
      "completeSignals": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["。", "？", "?", "！", "!", " done", " 完了", " 就这些"],
        "description": "Signals that indicate complete input"
      },
      "baseDebounceMultiplier": {
        "type": "number",
        "default": 1.5,
        "description": "Multiplier for debounce when input appears incomplete"
      },
      "maxDebounceMultiplier": {
        "type": "number",
        "default": 3,
        "description": "Maximum debounce multiplier"
      },
      "minMessageLength": {
        "type": "number",
        "default": 3,
        "description": "Minimum message length to consider for completion check"
      },
      "debug": {
        "type": "boolean",
        "default": false,
        "description": "Enable debug logging"
      },
      "executionSignalEnabled": {
        "type": "boolean",
        "default": true,
        "description": "Inject execution-mode policy guidance for finalized task requests"
      },
      "disableForLocalMainSession": {
        "type": "boolean",
        "default": true,
        "description": "Skip smart prompt rewriting for the local agent:main:main CLI test session"
      },
      "shadowModeEnabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable shadow mode: run baseline classifier in parallel and log divergences"
      },
      "customPhrases": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "phrase": { "type": "string" },
            "kind": { "type": "string" }
          }
        },
        "default": [],
        "description": "User-defined intent phrases. Matched before keyword scoring."
      },
      "embeddingCacheEnabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable embedding cache for semantic classification via cosine similarity"
      },
      "embeddingCachePath": {
        "type": "string",
        "default": "",
        "description": "Path to the embedding cache JSON file generated by tools/generate-embeddings.ts"
      },
      "locale": {
        "type": "string",
        "enum": ["zh-CN", "en"],
        "default": "zh-CN",
        "description": "Language for execution signal instructions"
      },
      "scoreThreshold": {
        "type": "number",
        "default": 5.0,
        "description": "Minimum weighted score for a kind to win classification"
      },
      "modelRoutingEnabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable model routing based on classification tier (fast/standard/premium)"
      },
      "fastModel": {
        "type": "string",
        "default": "",
        "description": "Model identifier for fast-tier requests (chat, unknown)"
      },
      "premiumModel": {
        "type": "string",
        "default": "",
        "description": "Model identifier for premium-tier requests (install, run, write, debug)"
      }
    }
  },
  "uiHints": {
    "enabled": { "label": "Enable Plugin", "default": true },
    "incompleteSignals": { "label": "Incomplete Signals", "placeholder": "..., ，, ," },
    "completeSignals": { "label": "Complete Signals", "placeholder": "。, ?, !" },
    "baseDebounceMultiplier": { "label": "Debounce Multiplier", "placeholder": "1.5" },
    "debug": { "label": "Debug Mode" },
    "executionSignalEnabled": { "label": "Execution Signal" },
    "disableForLocalMainSession": { "label": "Disable For Local Main Session" },
    "shadowModeEnabled": { "label": "Shadow Mode" },
    "customPhrases": {
      "label": "Custom Intent Phrases",
      "placeholder": "[{\"phrase\": \"...\", \"kind\": \"debug\"}]"
    },
    "embeddingCacheEnabled": { "label": "Embedding Cache" },
    "embeddingCachePath": {
      "label": "Embedding Cache Path",
      "placeholder": "/path/to/embedding-cache.json"
    },
    "locale": { "label": "Language", "placeholder": "zh-CN" },
    "scoreThreshold": { "label": "Score Threshold", "placeholder": "5.0" },
    "modelRoutingEnabled": { "label": "Model Routing" },
    "fastModel": { "label": "Fast Model", "placeholder": "claude-haiku-4" },
    "premiumModel": { "label": "Premium Model", "placeholder": "claude-opus-4" }
  }
}
