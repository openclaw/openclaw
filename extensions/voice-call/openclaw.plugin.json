    },
    "skipSignatureVerification": {
      "label": "Skip Signature Verification",
      "advanced": true
    },
    "store": {
      "label": "Call Log Store Path",
      "advanced": true
    },
    "responseModel": {
      "label": "Response Model",
      "advanced": true
    },
    "escalationModel": {
      "label": "Escalation Model (for complex queries)",
      "advanced": true
    },
    "escalationEnabled": {
      "label": "Enable Automatic Model Escalation",
      "advanced": true
    },
    "calendarEnabled": {
      "label": "Enable Google Calendar Booking",
      "advanced": true
    },
    "calendarId": {
      "label": "Google Calendar ID",
      "advanced": true
    },
    "gmailSummaryEnabled": {
      "label": "Enable Gmail Post-Call Summaries",
      "advanced": true
    },
    "gmailSummaryRecipient": {
      "label": "Summary Email Recipient",
      "advanced": true
    },
    "healthCheckEnabled": {
      "label": "Enable Health Monitoring",
      "advanced": true
    },
    "healthCheckIntervalMin": {
      "label": "Health Check Interval (minutes)",
      "advanced": true
    },
    "healthCheckNtfyTopic": {
      "label": "ntfy Topic for Health Alerts",
      "advanced": true
    },
    "responseSystemPrompt": {
      "label": "Response System Prompt",
