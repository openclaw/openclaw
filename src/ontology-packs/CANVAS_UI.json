      },
      "layout_id": {
        "type": "string",
        "description": "Identifier of layout to update"
      },
      "changes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "target": {
              "type": "string"
            },
            "property": {
              "type": "string"
            },
            "value": {}
          }
        },
        "description": "List of layout changes to apply"
      },
      "event_handlers": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Event handler mappings"
      },
      "updates": {
        "type": "array",
        "items": {
          "type": "object"
        },
        "description": "Batch of UI updates"
      },
      "media_type": {
        "type": "string",
        "enum": ["image", "video", "audio", "iframe"],
        "description": "Type of media to embed"
      },
      "source_url": {
        "type": "string",
        "format": "uri",
        "description": "URL of media source"
      },
      "script_content": {
        "type": "string",
        "description": "JavaScript code to inject"
      },
      "execution_context": {
        "type": "string",
        "enum": ["isolated", "page", "privileged"],
        "description": "Context for script execution"
      },
      "takeover_type": {
        "type": "string",
        "enum": ["fullscreen", "modal", "overlay"],
        "description": "Type of screen takeover"
      },
      "duration": {
        "type": "integer",
        "minimum": 0,
        "description": "Duration of takeover in seconds"
      },
      "justification": {
        "type": "string",
        "description": "Reason for takeover request"
      },
      "animation": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "duration_ms": {
            "type": "integer"
          },
          "easing": {
            "type": "string"
          }
        },
        "description": "Animation configuration"
      },
      "accessibility": {
        "type": "object",
        "properties": {
          "aria_label": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "tabindex": {
            "type": "integer"
          }
        },
        "description": "Accessibility attributes"
      }
    },
    "required": ["element_type"]
