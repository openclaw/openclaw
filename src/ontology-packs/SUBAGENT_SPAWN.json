  "field_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "agent_type": {
        "type": "string",
        "description": "Type identifier for the agent to spawn"
      },
      "agent_name": {
        "type": "string",
        "description": "Optional human-readable name for the agent"
      },
      "ttl_seconds": {
        "type": "integer",
        "minimum": 1,
        "description": "Time-to-live in seconds for ephemeral agents"
      },
      "sandbox_profile": {
        "type": "string",
        "enum": ["strict", "moderate", "permissive"],
        "description": "Sandbox isolation profile"
      },
      "resource_quota": {
        "type": "object",
        "properties": {
          "memory_mb": {
            "type": "integer"
          },
          "cpu_percent": {
            "type": "number"
          },
          "disk_mb": {
            "type": "integer"
          }
        },
        "description": "Resource allocation limits"
      },
      "persistence_scope": {
        "type": "string",
        "enum": ["session", "task", "permanent"],
        "description": "How long agent state should persist"
      },
      "network_policy": {
        "type": "object",
        "properties": {
          "allow_outbound": {
            "type": "boolean"
          },
          "allow_inbound": {
            "type": "boolean"
          },
          "allowed_hosts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "description": "Network access policy for the agent"
      },
      "credential_scope": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of credential namespaces the agent can access"
      },
      "elevation_level": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3,
        "description": "Privilege elevation level"
      },
      "justification": {
        "type": "string",
        "description": "Reason for elevated or privileged spawn"
      },
      "privilege_set": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Set of privileges to grant"
      },
      "authorization": {
        "type": "string",
        "description": "Authorization token for privileged spawn"
      },
      "unrestricted_scope": {
        "type": "string",
        "description": "Scope for unrestricted agent operations"
      },
      "emergency_override": {
        "type": "string",
        "description": "Emergency override code"
      },
      "inherit_permissions": {
        "type": "boolean",
        "default": false,
        "description": "Whether to inherit parent agent permissions"
      },
      "max_children": {
        "type": "integer",
        "minimum": 0,
        "description": "Maximum number of child agents this agent can spawn"
      }
    },
    "required": ["agent_type"]
  }
}
