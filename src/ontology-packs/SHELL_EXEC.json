  "field_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "command": {
        "type": "string",
        "description": "Shell command to execute"
      },
      "args": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Command arguments"
      },
      "cwd": {
        "type": "string",
        "description": "Working directory for command execution"
      },
      "env": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Environment variables to set"
      },
      "allows_sudo": {
        "type": "boolean",
        "default": false,
        "description": "Whether sudo/elevated execution is permitted"
      },
      "pipeline": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of commands to pipe together"
      },
      "justification": {
        "type": "string",
        "description": "Reason for executing sensitive commands"
      },
      "daemon_mode": {
        "type": "boolean",
        "default": false,
        "description": "Run as background daemon"
      },
      "pid": {
        "type": "integer",
        "description": "Process ID for kill operations"
      },
      "signal": {
        "type": "string",
        "enum": ["SIGTERM", "SIGINT", "SIGKILL", "SIGHUP", "SIGUSR1", "SIGUSR2"],
        "description": "Signal to send to process"
      },
      "system_scope": {
        "type": "string",
        "enum": ["services", "packages", "network", "users", "kernel"],
        "description": "Category of system modification"
      },
      "authorization": {
        "type": "string",
        "description": "Authorization token for system-level commands"
      },
      "timeout_seconds": {
        "type": "integer",
        "minimum": 0,
        "description": "Command timeout in seconds"
      },
      "capture_output": {
        "type": "boolean",
        "default": true,
        "description": "Whether to capture stdout/stderr"
      },
      "shell": {
        "type": "string",
        "enum": ["bash", "sh", "zsh", "powershell", "cmd"],
        "description": "Shell to use for execution"
      },
      "interactive": {
        "type": "boolean",
        "default": false,
        "description": "Whether command requires interactive input"
      }
    },
    "required": ["command"]
  }
