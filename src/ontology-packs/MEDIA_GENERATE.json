  "field_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "source_ref": {
        "type": "string",
        "description": "Reference to source media asset"
      },
      "output_format": {
        "type": "string",
        "enum": ["png", "jpg", "webp", "gif", "svg", "mp3", "wav", "mp4", "webm"],
        "description": "Desired output format"
      },
      "target_format": {
        "type": "string",
        "description": "Target format for conversion"
      },
      "dimensions": {
        "type": "object",
        "properties": {
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "maintain_aspect": {
            "type": "boolean"
          }
        },
        "description": "Output dimensions"
      },
      "chart_type": {
        "type": "string",
        "enum": ["bar", "line", "pie", "scatter", "histogram", "heatmap"],
        "description": "Type of chart to generate"
      },
      "data": {
        "type": ["array", "object"],
        "description": "Data for chart generation"
      },
      "diagram_type": {
        "type": "string",
        "enum": ["flowchart", "sequence", "class", "state", "er", "gantt"],
        "description": "Type of diagram to generate"
      },
      "definition": {
        "type": "string",
        "description": "Diagram definition (e.g., Mermaid syntax)"
      },
      "audio_type": {
        "type": "string",
        "enum": ["tts", "music", "sfx", "ambient"],
        "description": "Type of audio to synthesize"
      },
      "parameters": {
        "type": "object",
        "description": "Generation parameters specific to media type"
      },
      "prompt": {
        "type": "string",
        "description": "Text prompt for AI generation"
      },
      "model": {
        "type": "string",
        "description": "AI model identifier for generation"
      },
      "duration_seconds": {
        "type": "number",
        "minimum": 0,
        "description": "Duration for audio/video generation"
      },
      "source_media": {
        "type": "string",
        "description": "Source media reference for deepfake"
      },
      "target_likeness": {
        "type": "string",
        "description": "Target likeness reference"
      },
      "consent_proof": {
        "type": "string",
        "description": "Proof of consent for likeness usage"
      },
      "authorization": {
        "type": "string",
        "description": "Authorization token for sensitive operations"
      },
      "bypass_reason": {
        "type": "string",
        "description": "Justification for bypassing content filters"
      },
      "media_type": {
        "type": "string",
        "enum": ["image", "audio", "video", "3d"],
        "description": "Type of media to generate"
      },
      "quality": {
        "type": "string",
        "enum": ["draft", "standard", "high", "maximum"],
        "description": "Output quality level"
      },
      "style": {
        "type": "string",
        "description": "Style preset or description"
      }
    },
    "required": ["output_format"]
  }
}
