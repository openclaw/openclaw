  "field_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "job_id": {
        "type": "string",
        "description": "Unique identifier for the scheduled job"
      },
      "job_name": {
        "type": "string",
        "description": "Human-readable name for the job"
      },
      "scope": {
        "type": "string",
        "enum": ["user", "project", "system"],
        "description": "Scope for listing jobs"
      },
      "schedule_time": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp for one-shot execution"
      },
      "cron_expression": {
        "type": "string",
        "pattern": "^[\\d\\*\\-\\/\\,]+\\s+[\\d\\*\\-\\/\\,]+\\s+[\\d\\*\\-\\/\\,]+\\s+[\\d\\*\\-\\/\\,]+\\s+[\\d\\*\\-\\/\\,]+",
        "description": "Cron expression (minute hour day month weekday)"
      },
      "action": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["http", "script", "function", "message"]
          },
          "target": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        },
        "required": ["type", "target"],
        "description": "Action to execute when job triggers"
      },
      "system_action": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "description": "System-level action for privileged jobs"
      },
      "privilege_level": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3,
        "description": "Required privilege level for job execution"
      },
      "authorization": {
        "type": "string",
        "description": "Authorization token for system jobs"
      },
      "reason": {
        "type": "string",
        "description": "Reason for job cancellation or modification"
      },
      "timezone": {
        "type": "string",
        "description": "Timezone for schedule interpretation"
      },
      "retry_policy": {
        "type": "object",
        "properties": {
          "max_retries": {
            "type": "integer"
          },
          "backoff_seconds": {
            "type": "integer"
          }
        },
        "description": "Retry configuration for failed executions"
      },
      "timeout_seconds": {
        "type": "integer",
        "minimum": 1,
        "description": "Maximum execution time for job"
      },
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Whether job is active"
      }
    },
    "required": ["job_name"]
  }
}
