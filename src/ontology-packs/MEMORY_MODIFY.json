  "field_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "key": {
        "type": "string",
        "description": "Memory entry key/identifier"
      },
      "value": {
        "type": ["string", "number", "boolean", "object", "array"],
        "description": "Value to store in memory"
      },
      "memory_scope": {
        "type": "string",
        "enum": ["session", "conversation", "user", "project", "global", "system"],
        "description": "Scope of memory operation"
      },
      "retention_policy": {
        "type": "object",
        "properties": {
          "ttl_days": {
            "type": "integer"
          },
          "auto_expire": {
            "type": "boolean"
          },
          "archive_on_expire": {
            "type": "boolean"
          }
        },
        "description": "How long to retain the memory"
      },
      "knowledge_id": {
        "type": "string",
        "description": "Identifier of knowledge entry to update"
      },
      "updates": {
        "type": "object",
        "description": "Fields to update in knowledge entry"
      },
      "source_attribution": {
        "type": "object",
        "properties": {
          "source_type": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "description": "Attribution for knowledge source"
      },
      "reason": {
        "type": "string",
        "description": "Reason for deletion or modification"
      },
      "operations": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["set", "delete", "update", "append"]
            },
            "key": {
              "type": "string"
            },
            "value": {}
          }
        },
        "description": "List of bulk operations"
      },
      "confirmation_token": {
        "type": "string",
        "description": "Token confirming destructive operation"
      },
      "justification": {
        "type": "string",
        "description": "Detailed justification for scope clear"
      },
      "identity_field": {
        "type": "string",
        "description": "Core identity field to modify"
      },
      "new_value": {
        "type": ["string", "object"],
        "description": "New value for identity field"
      },
      "authorization": {
        "type": "string",
        "description": "Authorization token for critical modifications"
      },
      "audit_reason": {
        "type": "string",
        "description": "Reason to record in audit log"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Tags for memory entry categorization"
      },
      "metadata": {
        "type": "object",
        "description": "Additional metadata for the memory entry"
      }
    },
    "required": ["memory_scope"]
  }
}
