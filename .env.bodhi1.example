# .env.bodhi1.example
# Copy to ~/.openclaw/.env on bodhi1 and fill in real values.
# This file is a reference only — never commit real values.
#
# Load on startup: add to ~/.bashrc or ~/.profile:
#   set -a; source ~/.openclaw/.env; set +a

# ── Telegram ──────────────────────────────────────────────────────────────────
# Your personal bot token from BotFather (NOT @openbodhibot)
TELEGRAM_BOT_TOKEN=your_personal_bot_token_here

# Your Telegram numeric user ID (message @userinfobot to get it)
BODHI_TELEGRAM_USER_ID=your_telegram_user_id_here

# ── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API key (set by `openclaw auth` — may already be set)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key (for free model fallbacks)
OPENROUTER_API_KEY=sk-or-...

# ── Vault ─────────────────────────────────────────────────────────────────────
# Path to your Obsidian vault (default: ~/.alfred/vault)
OBSIDIAN_VAULT_DIR=/home/bodhi/.alfred/vault

# ── S3 Backup (Hetzner hudadata bucket) ──────────────────────────────────────
# Credentials from Bitwarden: "Hetzner S3 / hudadata"
S3_ENDPOINT_URL=https://nbg1.your-objectstorage.com
S3_BACKUP_BUCKET=s3://hudadata/backups/obsidian
AWS_ACCESS_KEY_ID=your_hudadata_access_key
AWS_SECRET_ACCESS_KEY=your_hudadata_secret_key
