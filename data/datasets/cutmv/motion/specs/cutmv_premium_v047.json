  "transitionPresets": {},
  "elementMotionPresets": {},
  "id": "cutmv_premium_v047",
  "scenes": [
    {
      "id": "s1_hook",
      "type": "hookText",
      "from": 0,
      "duration": 90,
      "environment": {
        "type": "abstract_blob_noise",
        "seed": 47
      },
      "contextBadge": "BETA",
      "headlineLines": [
        {
          "text": "3 STEPS.",
          "emphasis": true
        },
        {
          "text": "DONE.",
          "emphasis": false
        }
      ],
      "subhead": "Upload → Choose outputs → Generate"
    },
    {
      "id": "s2_step",
      "type": "stepScene",
      "from": 90,
      "duration": 90,
      "environment": {
        "type": "abstract_blob_noise",
        "seed": 19
      },
      "contextBadge": "STEP 1",
      "step": {
        "label": "UPLOAD",
        "text": "Drop a music video once."
      },
      "support": "No nesting. No re-frame passes."
    },
    {
      "id": "s3_ui_configure",
