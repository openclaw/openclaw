{
  "spec_version": "1.0.0",
  "template_id": "higgsfield_saas_drop_v1",
  "brand": "cutmv",
  "format": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "duration_sec": 10,
    "total_frames": 300,
    "aspect_ratio": "9:16",
    "codec": "h264"
  },
  "style_profile": "clean_premium_saas",
  "design_philosophy": {
    "principles": [
      "Minimal and surgical",
      "Expensive energy — every element earns its place",
      "Elite controlled pacing",
      "Mask reveals over hard cuts",
      "Subtle green accent lines only"
    ],
    "use_case": "Premium SaaS product drop — brand authority, clean reveal"
  },
  "global_rules": {
    "aspect_ratio": "9:16",
    "all_caps": true,
    "high_contrast": true,
    "cta_required": true,
    "background": "#000000",
    "typography_color": "#FFFFFF",
    "accent_color": "#94F33F",
    "accent_usage": "subtle_line_accent_only"
