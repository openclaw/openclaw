# ClaWorks OPC-UA connector — copy to .env or source alongside claworks.json
# Live PLC mode requires: pip install asyncua
#
# Usage: set -a; source opcua.env; set +a; pnpm claworks:start
# Simulation (no real PLC): CLAWORKS_OPCUA_SIMULATE=1 (or simulate: true in connector config)

# OPC-UA server endpoint
CLAWORKS_OPCUA_ENDPOINT=opc.tcp://127.0.0.1:4840

# Optional: override python interpreter path
# CLAWORKS_PYTHON=python3

# Set to "1" to use built-in simulation.
# Leave unset or set to "0" for production (requires a reachable OPC-UA server).
# CLAWORKS_OPCUA_SIMULATE=0

# Connector identity (used in event source field)
CLAWORKS_CONNECTOR_ID=opcua
