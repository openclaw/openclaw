# Production overlay for personal_work profile.
# Copy alongside claworks-personal.env.example:
#   cp contrib/examples/claworks-personal.env.example ~/.claworks/personal.env
#   cat contrib/examples/claworks-personal-production.env.example >> ~/.claworks/personal.env
#   source ~/.claworks/personal.env && pnpm claworks:repair:personal

CLAWORKS_PRODUCTION=1
CLAWORKS_INIT_SECURE=1

# After repair: connectors.echo disabled; OT simulate presets stripped.
# Configure real OT connectors in claworks.json (MQTT/OPC UA/modbus).
