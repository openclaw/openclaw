# ClaWorks Modbus TCP connector — copy to .env or source alongside claworks.json
# Live PLC mode requires: pip install pymodbus
#
# Usage: set -a; source modbus.env; set +a; pnpm claworks:start
# Simulation (no real PLC): CLAWORKS_MODBUS_SIMULATE=1 (or simulate: true in connector config)

# Modbus TCP target
CLAWORKS_MODBUS_HOST=127.0.0.1
CLAWORKS_MODBUS_PORT=502

# Optional: override python interpreter path
# CLAWORKS_PYTHON=python3

# Set to "1" to use built-in simulation.
# Leave unset or set to "0" for production (requires a reachable Modbus TCP device).
# CLAWORKS_MODBUS_SIMULATE=0

# Connector identity (used in event source field)
CLAWORKS_CONNECTOR_ID=modbus
