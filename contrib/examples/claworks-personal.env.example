# Copy to ~/.claworks/personal.env and: set -a; source ~/.claworks/personal.env; set +a
# Self-hosted Qwen (OpenAI-compatible) — NOT Alibaba plugins/qwen
# Production hardening: append contrib/examples/claworks-personal-production.env.example

CLAWORKS_PRODUCT_PROFILE=personal_work
CLAWORKS_VECTOR_KB=1
CLAWORKS_INIT_PROFILE=enterprise

# Your Qwen inference server (must expose /v1/chat/completions and embeddings if using vector KB)
CLAWORKS_QWEN_BASE_URL=http://127.0.0.1:8000/v1
CLAWORKS_QWEN_API_KEY=local
CLAWORKS_QWEN_CHAT_MODEL=qwen3
CLAWORKS_QWEN_EMBED_MODEL=text-embedding-v3

# OpenClaw knowledge_base on iMac (SMB mount — adjust volume name via: ls /Volumes)
# SMB: smb://m的iMac._smb._tcp.local/Macintosh HD/
# iMac path: /Users/m/.openclaw/workspace/knowledge_base/
CLAWORKS_OPENCLAW_KB_ROOT=/Volumes/Macintosh HD/Users/m/.openclaw/workspace/knowledge_base

# KB folder watch (filesystem-kb connector) — watches content/ for new Markdown
CLAWORKS_KB_WATCH_DIRS=${CLAWORKS_OPENCLAW_KB_ROOT}/content
CLAWORKS_KB_WATCH_INTERVAL_MS=300000
# Auto-watch uses one namespace; per-category ingest uses scripts/claworks-kb-import-openclaw-workspace.mjs
CLAWORKS_KB_NAMESPACE=work

# Self-hosted OrioSearch (Tavily-compatible web search, port 8000 — NOT SearXNG 8080)
CLAWORKS_ORIOSEARCH_URL=http://127.0.0.1:8000
# CLAWORKS_ORIOSEARCH_API_KEY=orio-local   # optional; tavily plugin needs non-empty if Orio auth disabled
