# Copy to ~/.claworks/personal.env and: set -a; source ~/.claworks/personal.env; set +a
# Self-hosted Qwen (OpenAI-compatible) — NOT Alibaba plugins/qwen
# Production hardening: append contrib/examples/claworks-personal-production.env.example

CLAWORKS_PRODUCT_PROFILE=personal_work
CLAWORKS_VECTOR_KB=1
CLAWORKS_INIT_PROFILE=enterprise

# Your Qwen inference server (must expose /v1/chat/completions and embeddings if using vector KB)
CLAWORKS_QWEN_BASE_URL=http://127.0.0.1:8000/v1
CLAWORKS_QWEN_API_KEY=local
CLAWORKS_QWEN_CHAT_MODEL=qwen3
CLAWORKS_QWEN_EMBED_MODEL=text-embedding-v3

# KB folder watch (filesystem-kb connector)
CLAWORKS_KB_WATCH_DIRS=/Users/YOU/Projects/claworks/docs,/Users/YOU/Projects/claworks-packs
CLAWORKS_KB_WATCH_INTERVAL_MS=300000
CLAWORKS_KB_NAMESPACE=work
