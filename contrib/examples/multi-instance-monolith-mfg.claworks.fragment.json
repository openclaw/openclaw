{
  "gateway": {
    "port": 18800,
    "bind": "0.0.0.0"
  },
  "plugins": {
    "allow": ["claworks-robot", "feishu"],
    "entries": {
      "claworks-robot": {
        "enabled": true,
        "config": {
          "robot": {
            "name": "mfg-robot",
            "role": "monolith",
            "host": "127.0.0.1",
            "port": 18800
          },
          "data": {
            "database_url": "postgresql://claworks:password@localhost:5432/claworks_mfg"
          },
          "a2a": {
            "enabled": true,
            "endpoint": "http://127.0.0.1:18800",
            "peers": [
              {
                "name": "supply-robot",
                "url": "http://127.0.0.1:18801",
                "description": "供应链域 monolith — 独立 Gateway"
              }
            ]
          },
          "packs": {
            "paths": ["../claworks-packs"],
            "installed": ["base", "process-industry"]
          }
        }
      }
    }
  }
}
