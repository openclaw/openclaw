# ClaWorks MQTT connector — copy to .env or source alongside claworks.json
# Live broker mode requires: npm install mqtt  (in connectors/mqtt dir or globally)
#
# Usage: set -a; source mqtt.env; set +a; pnpm claworks:start
# Simulation (no real broker):  CLAWORKS_MQTT_SIMULATE=1 (or simulate: true in connector config)

# Broker endpoint
CLAWORKS_MQTT_URL=mqtt://127.0.0.1:1883

# Topic to subscribe (wildcards supported: claworks/alarms/#)
CLAWORKS_MQTT_TOPIC=claworks/alarms/#

# Event type emitted to the robot on each message
CLAWORKS_MQTT_EVENT_TYPE=alarm.created

# Set to "1" to use built-in simulation instead of connecting to a real broker.
# Leave unset or set to "0" for production.
# CLAWORKS_MQTT_SIMULATE=0
