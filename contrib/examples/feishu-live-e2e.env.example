# Feishu live E2E — copy to .env and fill before: pnpm claworks:feishu:live-e2e
#
# Prerequisites:
#   - Running Gateway (default http://127.0.0.1:18800)
#   - OpenClaw feishu channel configured for full roundtrip (optional)

FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Group chat id (oc_xxx) or user open_id for probe target
FEISHU_TEST_CHAT_ID=
# FEISHU_TEST_OPEN_ID=

# Optional override
# CLAWORKS_GATEWAY_URL=http://127.0.0.1:18800
