+
+.card,
+.stat,
+.agent-attention-center,
+.agent-issue-queue,
+.agent-room-detail,
+.project-panel {
+  position: relative;
+  overflow: hidden;
+  border-color: color-mix(in srgb, var(--mission-panel-line) 76%, transparent);
+  background:
+    linear-gradient(180deg, rgba(255, 255, 255, 0.055), transparent 42%),
+    linear-gradient(135deg, rgba(125, 227, 255, 0.07), transparent 48%),
+    color-mix(in srgb, var(--card) 92%, #000000);
+  box-shadow:
+    inset 0 1px 0 rgba(255, 255, 255, 0.07),
+    var(--mission-shadow-hard);
+}
+
+.card::after,
+.agent-attention-center::after,
+.agent-room-stage::after {
+  position: absolute;
+  inset: 0;
+  pointer-events: none;
+  content: "";
+}
+
+.card::after,
+.agent-attention-center::after {
+  background:
+    linear-gradient(90deg, transparent, rgba(125, 227, 255, 0.08), transparent 58%),
+    repeating-linear-gradient(0deg, transparent 0 17px, rgba(255, 255, 255, 0.025) 18px);
+  opacity: 0.34;
+}
+
+.card-title,
+.stat-label,
+.agent-room-project__label,
+.agent-issue-queue__header strong,
+.agent-attention-center__lead span,
+.agent-attention-actions__title,
+.project-panel__header .card-title {
+  font-family: var(--font-display);
+  font-weight: 950;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+.card-title,
+.agent-issue-queue__header strong,
+.agent-room-detail__title,
+.project-panel__header .card-title {
+  color: var(--mission-thrust);
+}
+
+.card-sub,
+.page-sub,
+.agent-issue-queue__header span,
+.agent-room-project__sub,
+.project-resource-row__preview,
+.project-context-block p {
+  color: var(--mission-readout);
+  font-weight: 720;
+}
+
+.stat,
+.stat-card,
+.project-stat {
+  position: relative;
+}
+
+.stat::before,
+.stat-card::before,
+.project-stat::before {
+  position: absolute;
+  top: 0;
+  left: 12px;
+  width: 44px;
+  height: 2px;
+  background: var(--mission-critical);
+  content: "";
+}
+
+.stat-value {
+  color: var(--mission-thrust);
+  font-family: var(--font-display);
+}
+
+.btn.primary,
+.topbar-search,
+.topbar-theme-mode,
+.project-mode-pill,
+.project-health,
+.project-resource-status {
+  border-color: color-mix(in srgb, var(--mission-panel-line) 82%, transparent);
+  box-shadow:
+    inset 0 1px 0 rgba(255, 255, 255, 0.08),
+    0 0 0 1px rgba(0, 0, 0, 0.28);
+}
+
+.btn.primary {
+  background:
+    linear-gradient(180deg, rgba(255, 255, 255, 0.16), transparent 50%), var(--mission-thrust);
+  color: #02050a;
+  font-weight: 900;
+}
+
+.agent-room-stage {
+  border-color: color-mix(in srgb, var(--mission-panel-line) 86%, transparent);
+  background:
+    repeating-linear-gradient(90deg, transparent 0 31px, rgba(125, 227, 255, 0.07) 32px),
+    repeating-linear-gradient(0deg, transparent 0 31px, rgba(125, 227, 255, 0.055) 32px),
+    linear-gradient(180deg, #07111d 0 34%, #2b465f 34% 35%, #0a121b 35% 100%);
+  box-shadow:
+    inset 0 0 0 1px rgba(255, 255, 255, 0.07),
+    inset 0 0 42px rgba(125, 227, 255, 0.07),
