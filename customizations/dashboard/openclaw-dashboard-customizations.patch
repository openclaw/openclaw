+  opacity: 0.42;
+}
+
+.agent-room-project {
+  border-color: #05070a;
+  background:
+    linear-gradient(90deg, rgba(255, 59, 48, 0.22) 0 4px, transparent 4px),
+    linear-gradient(180deg, rgba(125, 227, 255, 0.11) 0 24px, transparent 24px),
