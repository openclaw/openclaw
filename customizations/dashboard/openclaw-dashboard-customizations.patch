+        ...base,
+        state: fresh ? "working" : "waiting",
+        statusLabel: "Exposure watch",
+        cue: "monitoring paper exposure",
+        task: `Unresolved paper exposure: ${formatCompactUsd(metrics?.unresolved_paper_exposure_usd)}.`,
+        detail:
