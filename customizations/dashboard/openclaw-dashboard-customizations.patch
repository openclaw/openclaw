+}
+
+.agent-room-worker__status,
+.agent-room-worker__confidence {
+  background: #0d1722;
+  color: var(--mission-readout);
+}
+
+.agent-room-worker--working .agent-room-worker__status,
+.agent-room-worker--thinking .agent-room-worker__status,
+.agent-room-worker--running-tool .agent-room-worker__status,
+.agent-room-worker--reading .agent-room-worker__status,
+.agent-room-worker--writing .agent-room-worker__status,
+.agent-room-worker--waiting .agent-room-worker__status {
+  background: #fff0a8;
+  color: #181105;
+}
+
+.agent-room-worker--working .agent-room-worker__label,
+.agent-room-worker--thinking .agent-room-worker__label,
+.agent-room-worker--running-tool .agent-room-worker__label,
+.agent-room-worker--reading .agent-room-worker__label,
+.agent-room-worker--writing .agent-room-worker__label,
+.agent-room-worker--waiting .agent-room-worker__label {
+  color: #fff7d2;
+  text-shadow:
+    0 1px 0 #000000,
+    0 0 12px rgba(255, 189, 69, 0.48);
+}
+
+.agent-room-worker--working .agent-room-worker__task,
+.agent-room-worker--thinking .agent-room-worker__task,
+.agent-room-worker--running-tool .agent-room-worker__task,
+.agent-room-worker--reading .agent-room-worker__task,
+.agent-room-worker--writing .agent-room-worker__task,
+.agent-room-worker--waiting .agent-room-worker__task {
+  border-color: rgba(255, 189, 69, 0.74);
+  background: rgba(32, 20, 3, 0.82);
+  color: #fff7d2;
+}
+
+.agent-room-worker--supervising .agent-room-worker__status {
+  background: #d7ffb6;
+  color: #07130b;
+}
+
+.agent-room-worker--sleeping .agent-room-worker__status,
+.agent-room-worker--idle .agent-room-worker__status,
+.agent-room-worker--offline .agent-room-worker__status,
+.agent-room-worker--unknown .agent-room-worker__status {
+  background: #162436;
+  color: #c8d7e8;
+}
+
+.agent-issue-card,
+.agent-attention-action,
+.agent-room-history__list li,
+.agent-room-kv > div,
+.project-resource-row,
+.project-session-row,
+.project-context-block {
+  border-color: color-mix(in srgb, var(--mission-panel-line) 52%, transparent);
+  background:
+    linear-gradient(180deg, rgba(255, 255, 255, 0.045), transparent 44%), rgba(2, 5, 10, 0.7);
+}
+
+.agent-issue-card--critical,
+.agent-issue-card--high,
+.agent-attention-action--critical,
+.agent-attention-action--high,
+.project-health--attention,
+.project-resource-status--attention {
+  border-color: color-mix(in srgb, var(--mission-critical) 72%, var(--border));
+}
+
+.agent-issue-card--medium,
+.agent-attention-action--medium {
+  border-color: color-mix(in srgb, var(--mission-caution) 72%, var(--border));
+}
+
+.agent-issue-card__problem,
+.agent-room-kv dt,
+.agent-room-history__details summary,
+.agent-room-detail__task span,
+.agent-room-help__body strong {
+  color: #b8ff95;
+}
+
+.agent-room-resource__item,
+.agent-room-resource__breakdown,
+.agent-room-help {
+  border-color: color-mix(in srgb, var(--mission-panel-line) 62%, transparent);
+  background:
+    linear-gradient(180deg, rgba(255, 255, 255, 0.045), transparent 42%), rgba(2, 5, 10, 0.78);
+}
+
+.agent-room-resource__item strong,
+.agent-room-resource__breakdown-grid strong,
+.agent-room-resource__process-list strong {
+  color: var(--mission-thrust);
+}
+
+.project-cockpit,
+.projects-layout {
+  background:
+    radial-gradient(circle at top left, rgba(125, 227, 255, 0.08), transparent 30%),
+    linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent 20%);
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .card,
+  .stat,
+  .agent-room-worker,
+  .agent-room-worker__sprite,
+  .agent-room-worker__signal {
+    animation: none !important;
+    transition: none !important;
+  }
+}

