+  --kalshi-red: #d6433a;
+  --kalshi-green: #138a5b;
+  --kalshi-amber: #a86908;
+  --kalshi-blue: #1674d1;
+  --kalshi-violet: #7658d6;
+  --kalshi-shadow: 0 22px 70px rgba(35, 39, 47, 0.12);
+  display: grid;
+  gap: 22px;
+  width: 100%;
