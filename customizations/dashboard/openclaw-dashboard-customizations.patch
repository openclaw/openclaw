+function attentionConfidenceFromTimestamp(
+  timestamp: number | null | undefined,
+  now: number,
+  live = false,
+): AttentionConfidence {
+  if (live) {
+    return "Live";
+  }
+  if (!timestamp) {
+    return "Inferred";
+  }
+  if (now - timestamp > STALE_SIGNAL_MS) {
+    return "Stale";
+  }
+  if (now - timestamp > RECENT_ACTIVITY_MS) {
+    return "Recent";
+  }
+  return "Live";
+}
