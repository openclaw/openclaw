+
+  it("resolves the first executable Python candidate through symlinks", () => {
+    const resolved = __testing.resolveExecutable([
+      "/Users/openclaw/.venvs/kalshi-api/bin/python",
+      "/usr/bin/python3",
+    ]);
+
+    expect(resolved).toMatch(/python3(?:\.\d+)?$/);
