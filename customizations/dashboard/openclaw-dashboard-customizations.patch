+  display: grid;
+  gap: 8px;
+}
+
+.project-cockpit__actions {
+  display: grid;
+  align-content: start;
+  gap: 8px;
+}
+
+.project-cockpit__chips,
+.project-panel__actions,
+.project-resource-form__actions {
+  display: flex;
+  gap: 8px;
+  align-items: center;
+  flex-wrap: wrap;
+}
+
+.project-cockpit__stats {
+  grid-column: 1 / -1;
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  gap: 10px;
+}
+
+.project-stat {
+  display: grid;
+  gap: 4px;
+  border: 1px solid var(--border);
+  border-radius: var(--radius-md);
+  background: color-mix(in srgb, var(--bg) 55%, var(--surface));
+  padding: 12px;
+}
+
+.project-stat span,
+.project-eyebrow {
+  color: color-mix(in srgb, var(--fg) 74%, var(--muted));
+  font-size: 0.72rem;
+  font-weight: 850;
+  text-transform: uppercase;
+}
+
+.project-stat strong {
+  color: var(--fg);
+  font-size: 1.05rem;
+}
+
+.project-stat em {
+  color: color-mix(in srgb, var(--fg) 72%, var(--muted));
+  font-size: 0.8rem;
+  font-style: normal;
+}
+
+.project-stat--ready {
+  border-color: color-mix(in srgb, var(--success) 42%, var(--border));
+}
+
+.project-stat--attention {
+  border-color: color-mix(in srgb, var(--danger) 42%, var(--border));
+}
+
+.project-health,
+.project-mode-pill,
+.project-resource-status {
+  border: 1px solid color-mix(in srgb, var(--border-strong) 62%, transparent);
