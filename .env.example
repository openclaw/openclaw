# OpenClaw — variáveis de ambiente
# Copie para .env e preencha os valores

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:slim

# Token de autenticação do gateway (gere um valor aleatório seguro)
OPENCLAW_GATEWAY_TOKEN=seu_token_aqui

# Diretórios de persistência
OPENCLAW_CONFIG_DIR=/home/SEU_USUARIO/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/SEU_USUARIO/.openclaw/workspace

# Porta do gateway (padrão: 18789)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Bind mode: lan = acessível pelo host via 127.0.0.1
OPENCLAW_GATEWAY_BIND=lan

# Fuso horário
OPENCLAW_TZ=America/Sao_Paulo
