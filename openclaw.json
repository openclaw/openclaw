{
  "gateway": {
    "controlUi": {
      "enabled": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "path": "/hooks",
    "defaultSessionKey": "hook:ingress",
    "allowRequestSessionKey": false
  },
  "tools": {
    "alsoAllow": [
      "revenue-executor"
    ]
  },
  "plugins": {
    "entries": {
      "revenue-executor": {
        "enabled": true,
        "config": {
          "ghlApiKey": "${OPENCLAW_REVENUE_GHL_API_KEY}",
          "ghlLocationId": "${OPENCLAW_REVENUE_GHL_LOCATION_ID}",
          "ghlPipelineId": "${OPENCLAW_REVENUE_GHL_PIPELINE_ID}",
          "stripeSecretKey": "${OPENCLAW_REVENUE_STRIPE_SECRET_KEY}",
          "defaultTags": ["ai-coo", "telegram-lead"]
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "${OPENCLAW_AGENT_MODEL}"
      }
    }
  }
}
