{
  "gateway": {
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "https://openclaw-production-56fa.up.railway.app"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": false,
      "dangerouslyDisableDeviceAuth": false
    },
    "nodes": {
      "browser": {
        "mode": "manual",
        "node": "${OPENCLAW_BROWSER_NODE}"
      }
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "path": "/hooks",
    "defaultSessionKey": "hook:ingress",
    "allowRequestSessionKey": false
  },
  "tools": {
    "alsoAllow": [
      "revenue-executor"
    ]
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "browser": {
          "allowHostControl": true
        }
      },
      "model": {
        "primary": "${OPENCLAW_AGENT_MODEL}"
      }
    }
  },
  "plugins": {
    "entries": {
      "revenue-executor": {
        "enabled": true,
        "config": {
          "ghlApiKey": "${GHL_API_KEY}",
          "ghlLocationId": "${GHL_LOCATION_ID}",
          "ghlPipelineId": "${GHL_PIPELINE_ID}",
          "stripeSecretKey": "${STRIPE_SECRET_KEY}",
          "defaultTags": [
            "ai-coo",
            "telegram-lead"
          ]
        }
      }
    }
  }
}
