{
  "logging": { "level": "info" },
  "gateway": { "mode": "local" },

  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-6",
      "workspace": "~/.openclaw/workspace",
      "thinkingDefault": "low",
      "timeoutSeconds": 300,
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "params": { "cacheRetention": "short" }
        },
        "anthropic/claude-haiku-4-5": {
          "params": { "cacheRetention": "short" }
        },
        "anthropic/claude-opus-4-6": {
          "params": { "cacheRetention": "short" }
        }
      }
    },
    "list": [
      {
        "id": "bodhi",
        "name": "Bodhi",
        "default": true,
        "workspace": "~/openbodhi/souls/bodhi",
        "identity": {
          "name": "Bodhi",
          "avatar": "🪷",
          "bio": "Thinking partner. Socratic companion. Asks better questions. Warm, reflective, curious. Default mode."
        },
        "skills": [
          "bodhi-pm",
          "bodhi-budget",
          "bodhi-model-switch",
          "bodhi-switch"
        ]
      },
      {
        "id": "bo",
        "name": "Bo",
        "workspace": "~/openbodhi/souls/bo",
        "identity": {
          "name": "Bo",
          "avatar": "🧘",
          "bio": "Wellness criticality monitor and goal coach. Buddhist writer. Calm, precise, never prescriptive. Surfaces patterns."
        },
        "skills": [
          "bodhi-curator",
          "bodhi-enricher",
          "bodhi-distiller",
          "bodhi-surveyor",
          "bodhi-janitor",
          "bodhi-nudge",
          "bodhi-substack",
          "bodhi-viz",
          "bodhi-checkin",
          "bodhi-tasks",
          "bodhi-calendar",
          "bodhi-accountability",
          "bodhi-query",
          "bodhi-switch"
        ]
      },
      {
        "id": "qenjin",
        "name": "Qenjin",
        "workspace": "~/openbodhi/souls/qenjin",
        "identity": {
          "name": "Qenjin",
          "avatar": "⚙️",
          "bio": "Business operator for qenjin.io. Clipped, military-brief, zero filler. Executes, reports, escalates."
        },
        "skills": [
          "qenjin-crm",
          "qenjin-content",
          "qenjin-outreach",
          "qenjin-n8n",
          "qenjin-osint",
          "qenjin-video",
          "qenjin-mautic",
          "qenjin-analytics",
          "qenjin-security",
          "bodhi-switch"
        ]
      },
      {
        "id": "moonman",
        "name": "Moonman",
        "workspace": "~/openbodhi/souls/moonman",
        "identity": {
          "name": "Moonman",
          "avatar": "🌙",
          "bio": "Trading bot. Edge hunter. Casual quant. Numbers first, thesis second, feelings never. Paper first, always."
        },
        "skills": [
          "trader-scan",
          "trader-backtest",
          "trader-polymarket",
          "trader-wallet",
          "trader-ta",
          "trader-signals",
          "trader-cron",
          "trader-risk",
          "trader-dashboard",
          "bodhi-switch"
        ]
      }
    ]
  },

  "channels": {
    "telegram": {
      "dmPolicy": "allowlist",
      "allowFrom": ["${BODHI_TELEGRAM_USER_ID}"]
    }
  },

  "skills": {
    "load": {
      "extraDirs": [
        "skills/bodhi-curator",
        "skills/bodhi-enricher",
        "skills/bodhi-distiller",
        "skills/bodhi-surveyor",
        "skills/bodhi-janitor",
        "skills/bodhi-budget",
        "skills/bodhi-pm",
        "skills/bodhi-model-switch",
        "skills/bodhi-nudge",
        "skills/bodhi-substack",
        "skills/bodhi-viz",
        "skills/bodhi-switch",
        "skills/qenjin-crm",
        "skills/qenjin-content",
        "skills/qenjin-outreach",
        "skills/qenjin-n8n",
        "skills/qenjin-osint",
        "skills/qenjin-video",
        "skills/qenjin-mautic",
        "skills/qenjin-analytics",
        "skills/qenjin-security",
        "skills/trader-scan",
        "skills/trader-backtest",
        "skills/trader-polymarket",
        "skills/trader-wallet",
        "skills/trader-ta",
        "skills/trader-signals",
        "skills/trader-cron",
        "skills/trader-risk",
        "skills/trader-dashboard",
        "skills/bodhi-checkin",
        "skills/bodhi-tasks",
        "skills/bodhi-calendar",
        "skills/bodhi-accountability",
        "skills/bodhi-query"
      ],
      "watch": false
    }
  },

  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1,
    "sessionRetention": "48h",
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [30000, 60000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "jobs": [
      {
        "id": "nudge-daily",
        "schedule": "0 10 * * *",
        "agent": "bo",
        "prompt": "Run /nudge — check vault clusters for criticality and deliver any pending nudges.",
        "recurring": true
      },
      {
        "id": "viz-export-hourly",
        "schedule": "0 * * * *",
        "agent": "bo",
        "prompt": "Run: cd ~/openbodhi && python3 -m bodhi_viz.export — refresh visualization data from latest vault nodes. No message needed, just confirm success.",
        "recurring": true
      },
      {
        "id": "morning-checkin",
        "schedule": "7 8 * * *",
        "agent": "bo",
        "prompt": "Send the morning check-in ritual. Run /morning",
        "recurring": true
      },
      {
        "id": "evening-checkin",
        "schedule": "3 21 * * *",
        "agent": "bo",
        "prompt": "Send the evening check-in ritual. Run /evening",
        "recurring": true
      },
      {
        "id": "budget-reset-notify",
        "schedule": "1 0 * * *",
        "agent": "bodhi",
        "prompt": "Budget has reset for the new day. Run /usage and send a brief one-line status: today's spend ($0.00) and daily limit. No extra commentary.",
        "recurring": true
      },
      {
        "id": "health-ping",
        "schedule": "*/30 * * * *",
        "agent": "bodhi",
        "prompt": "Silent health check. Run: python3 -c \"import pathlib, json, os; p=pathlib.Path(os.path.expanduser('~/.openclaw/health.json')); import datetime; d={'ts': datetime.datetime.utcnow().isoformat(), 'ok': True}; p.write_text(json.dumps(d))\" — write timestamp to health.json. No Telegram message.",
        "recurring": true
      },
      {
        "id": "tailscale-check",
        "schedule": "*/15 * * * *",
        "agent": "bodhi",
        "prompt": "Silent Tailscale check. Run: bash ~/openbodhi/docs/bodhi/scripts/tailscale-watchdog.sh — alert via Telegram only if Tailscale is down. No message if healthy.",
        "recurring": true
      },
      {
        "id": "vault-backup-weekly",
        "schedule": "0 3 * * 0",
        "agent": "bodhi",
        "prompt": "Run vault backup: bash ~/openbodhi/docs/bodhi/scripts/vault-backup.sh — send result as Telegram message. Format: 'Vault backup: [OK/FAIL] — N nodes synced to S3.'",
        "recurring": true
      },
      {
        "id": "janitor-weekly",
        "schedule": "30 3 * * 0",
        "agent": "bo",
        "prompt": "Run /janitor — weekly vault hygiene check. Scan for orphans, duplicates, broken edges. Report only, no auto-cleanup.",
        "recurring": true
      },
      {
        "id": "qenjin-weekly-report",
        "schedule": "0 9 * * 5",
        "agent": "qenjin",
        "prompt": "Run /q analytics weekly — compile and send the weekly business report: pipeline value, outreach funnel metrics, content performance, AI spend.",
        "recurring": true
      },
      {
        "id": "qenjin-content-calendar",
        "schedule": "0 7 * * 2",
        "agent": "qenjin",
        "prompt": "Run /q content plan — send this week's content calendar reminder: what to publish, what clips to record, what to schedule.",
        "recurring": true
      },
      {
        "id": "qenjin-followup-check",
        "schedule": "0 14 * * 1-5",
        "agent": "qenjin",
        "prompt": "Run /q outreach today — check CRM for LinkedIn connections accepted 24-48h ago and generate personalized DMs for owner review.",
        "recurring": true
      },
      {
        "id": "moonman-morning-brief",
        "schedule": "0 9 * * 1-5",
        "agent": "moonman",
        "prompt": "Run /t market update — send the morning trading brief: BTC overview, top alt signals, Polymarket hot markets.",
        "recurring": true
      },
      {
        "id": "moonman-eod-review",
        "schedule": "0 16 * * 1-5",
        "agent": "moonman",
        "prompt": "Run /t signals — end-of-day signal check. Any strategies triggered today? Paper trade P&L update.",
        "recurring": true
      },
      {
        "id": "moonman-strategy-review",
        "schedule": "0 10 * * 0",
        "agent": "moonman",
        "prompt": "Run /t risk report — weekly strategy performance review: win rate, expectancy, drawdown, edge decay check.",
        "recurring": true
      },
      {
        "id": "disk-monitor-daily",
        "schedule": "0 7 * * *",
        "agent": "bodhi",
        "prompt": "Run: bash ~/openbodhi/docs/bodhi/scripts/disk-monitor.sh — send alert only if output starts with DISK_WARN or DISK_CRITICAL. Silent if healthy.",
        "recurring": true
      },
      {
        "id": "secrets-audit-monthly",
        "schedule": "0 9 1 * *",
        "agent": "bodhi",
        "prompt": "Run: bash ~/openbodhi/docs/bodhi/scripts/secrets-audit.sh — send the full output as a Telegram message. This is the monthly security audit reminder.",
        "recurring": true
      }
      {
        "id": "surveyor-weekly",
        "schedule": "0 2 * * 6",
        "agent": "bo",
        "prompt": "Run the weekly vault survey. Run /surveyor — cluster all vault nodes, detect bridges, surface SOC signals, and send the weekly digest.",
        "recurring": true
      },
      {
        "id": "distiller-daily",
        "schedule": "0 6 * * *",
        "agent": "bo",
        "prompt": "Run the daily digest. Run /distiller — query last 7 days of vault nodes and send morning synthesis.",
        "recurring": true
      }
    ]
  },

  "session": {
    "scope": "per-sender",
    "resetTriggers": ["/new", "/reset"],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 1440
    }
  }
}
