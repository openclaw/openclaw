{
  "$schema": "https://openclaw.ai/schema/config.json",
  "name": "finclaw-starter",
  "description": "FinClaw starter workspace with finance-focused defaults",
  "tools": {
    "profile": "coding",
    "alsoAllow": ["read", "exec", "write", "edit"]
  },
  "skills": {
    "autoDiscover": true,
    "skillsDir": "./skills",
    "load": {
      "extraDirs": ["skills", "commons/skills"]
    }
  },
  "plugins": {
    "entries": {
      "fin-backtest-remote": {
        "enabled": true
      }
    }
  }
}
