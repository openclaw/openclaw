{
  "logging": { "level": "info" },
  "gateway": { "mode": "local" },

  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-6",
      "workspace": "~/.openclaw/workspace",
      "thinkingDefault": "low",
      "timeoutSeconds": 300,
      "heartbeat": { "every": "0m" },
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "params": { "cacheRetention": "short" }
        },
        "anthropic/claude-haiku-4-5": {
          "params": { "cacheRetention": "short" }
        },
        "anthropic/claude-opus-4-6": {
          "params": { "cacheRetention": "short" }
        }
      }
    }
  },

  "budget": {
    "dailyDollars": 2.00,
    "weeklyDollars": 10.00,
    "alertAt": 0.80,
    "hardStop": true,
    "persistPath": "~/.openclaw/budget-state.json"
  },

  "channels": {
    "telegram": {
      "dmPolicy": "allowlist",
      "allowFrom": ["$BODHI_TELEGRAM_USER_ID"]
    }
  },

  "skills": {
    "load": {
      "extraDirs": [
        "skills/bodhi-curator",
        "skills/bodhi-enricher",
        "skills/bodhi-distiller",
        "skills/bodhi-surveyor",
        "skills/bodhi-janitor",
        "skills/bodhi-budget",
        "skills/bodhi-pm",
        "skills/bodhi-model-switch"
      ],
      "watch": false
    }
  },

  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1,
    "sessionRetention": "48h",
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [30000, 60000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    }
  },

  "session": {
    "scope": "per-sender",
    "resetTriggers": ["/new", "/reset"],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 1440
    }
  }
}
