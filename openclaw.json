{
  "logging": { "level": "info" },
  "gateway": { "mode": "local" },

  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-6",
      "workspace": "~/.openclaw/workspace",
      "thinkingDefault": "low",
      "timeoutSeconds": 300,
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "params": { "cacheRetention": "short" }
        },
        "anthropic/claude-haiku-4-5": {
          "params": { "cacheRetention": "short" }
        },
        "anthropic/claude-opus-4-6": {
          "params": { "cacheRetention": "short" }
        }
      }
    },
    "list": [
      {
        "id": "bodhi",
        "name": "Bodhi",
        "default": true,
        "workspace": "~/openbodhi/souls/bodhi",
        "identity": {
          "name": "Bodhi",
          "avatar": "🪷",
          "bio": "Thinking partner. Socratic companion. Asks better questions. Warm, reflective, curious. Default mode."
        },
        "skills": [
          "bodhi-pm",
          "bodhi-budget",
          "bodhi-model-switch",
          "bodhi-switch"
        ]
      },
      {
        "id": "bo",
        "name": "Bo",
        "workspace": "~/openbodhi/souls/bo",
        "identity": {
          "name": "Bo",
          "avatar": "🧘",
          "bio": "Wellness criticality monitor and goal coach. Buddhist writer. Calm, precise, never prescriptive. Surfaces patterns."
        },
        "skills": [
          "bodhi-curator",
          "bodhi-enricher",
          "bodhi-distiller",
          "bodhi-surveyor",
          "bodhi-janitor",
          "bodhi-nudge",
          "bodhi-substack",
          "bodhi-viz",
          "bodhi-checkin",
          "bodhi-tasks",
          "bodhi-calendar",
          "bodhi-accountability",
          "bodhi-switch"
        ]
      },
      {
        "id": "qenjin",
        "name": "Qenjin",
        "workspace": "~/openbodhi/souls/qenjin",
        "identity": {
          "name": "Qenjin",
          "avatar": "⚙️",
          "bio": "Business operator for qenjin.io. Clipped, military-brief, zero filler. Executes, reports, escalates."
        },
        "skills": [
          "qenjin-crm",
          "qenjin-content",
          "qenjin-outreach",
          "qenjin-n8n",
          "qenjin-osint",
          "qenjin-video",
          "qenjin-mautic",
          "qenjin-analytics",
          "qenjin-security",
          "bodhi-switch"
        ]
      },
      {
        "id": "moonman",
        "name": "Moonman",
        "workspace": "~/openbodhi/souls/moonman",
        "identity": {
          "name": "Moonman",
          "avatar": "🌙",
          "bio": "Trading bot. Edge hunter. Casual quant. Numbers first, thesis second, feelings never. Paper first, always."
        },
        "skills": [
          "trader-scan",
          "trader-backtest",
          "trader-polymarket",
          "trader-wallet",
          "trader-ta",
          "trader-signals",
          "trader-cron",
          "trader-risk",
          "trader-dashboard",
          "bodhi-switch"
        ]
      }
    ]
  },

  "channels": {
    "telegram": {
      "dmPolicy": "allowlist",
      "allowFrom": ["${BODHI_TELEGRAM_USER_ID}"]
    }
  },

  "skills": {
    "load": {
      "extraDirs": [
        "skills/bodhi-curator",
        "skills/bodhi-enricher",
        "skills/bodhi-distiller",
        "skills/bodhi-surveyor",
        "skills/bodhi-janitor",
        "skills/bodhi-budget",
        "skills/bodhi-pm",
        "skills/bodhi-model-switch",
        "skills/bodhi-nudge",
        "skills/bodhi-substack",
        "skills/bodhi-viz",
        "skills/bodhi-switch",
        "skills/qenjin-crm",
        "skills/qenjin-content",
        "skills/qenjin-outreach",
        "skills/qenjin-n8n",
        "skills/qenjin-osint",
        "skills/qenjin-video",
        "skills/qenjin-mautic",
        "skills/qenjin-analytics",
        "skills/qenjin-security",
        "skills/trader-scan",
        "skills/trader-backtest",
        "skills/trader-polymarket",
        "skills/trader-wallet",
        "skills/trader-ta",
        "skills/trader-signals",
        "skills/trader-cron",
        "skills/trader-risk",
        "skills/trader-dashboard",
        "skills/bodhi-checkin",
        "skills/bodhi-tasks",
        "skills/bodhi-calendar",
        "skills/bodhi-accountability"
      ],
      "watch": false
    }
  },

  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1,
    "sessionRetention": "48h",
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [30000, 60000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    }
  },

  "session": {
    "scope": "per-sender",
    "resetTriggers": ["/new", "/reset"],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 1440
    }
  }
}
