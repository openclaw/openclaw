{
    "version": "0.2.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "pnpm build",
            "problemMatcher": []
        },
        {
            "label": "Build with sourcemap",
            "type": "shell",
            "command": "npx tsdown"
        }
    ],
    "configurations": [
        {
            "name": "Gateway (tsx)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "node",
            "program": "${workspaceFolder}/src/entry.ts",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "args": [
                "gateway",
                "--verbose",
                "--allow-unconfigured"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/src/**",
                "${workspaceFolder}/dist/**/*.js"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "NODE_ENV": "development",
                "OPENCLAW_SKIP_CHANNELS": "0",
                "OPENCLAW_SKIP_PROVIDERS": "0"
            }
        },
        {
            "name": "Gateway (built)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "node",
            "program": "${workspaceFolder}/dist/entry.js",
            "args": [
                "gateway",
                "--verbose",
                "--allow-unconfigured"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "sourceMaps": true,
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ],
            "env": {
                "NODE_ENV": "development",
                "OPENCLAW_SKIP_CHANNELS": "0",
                "OPENCLAW_SKIP_PROVIDERS": "0"
            },
            "preLaunchTask": "Build"
        },
        {
            "name": "Attach to Gateway",
            "type": "node",
            "request": "attach",
            "port": 18789,
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ]
        }
    ]
}
