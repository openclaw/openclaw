{
  "meta": {
    "lastTouchedVersion": "2026.3.2"
  },
  "ui": {
    "assistant": {
      "name": "Rick Prime Agent",
      "avatar": "🦞"
    }
  },
  "diagnostics": {
    "enabled": true,
    "stuckSessionWarnMs": 90000
  },
  "plugins": {
    "enabled": true,
    "allow": ["acpx"],
    "entries": {
      "acpx": {
        "enabled": true
      }
    }
  },
  "gateway": {
    "bind": "loopback",
    "channelHealthCheckMinutes": 3,
    "tools": {
      "deny": ["sessions_spawn", "sessions_send", "gateway", "whatsapp_login"]
    },
    "controlUi": {
      "enabled": true
    }
  },
  "tools": {
    "profile": "coding",
    "alsoAllow": ["pdf", "sessions_spawn"],
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 8,
      "criticalThreshold": 14,
      "globalCircuitBreakerThreshold": 24
    },
    "sessions": {
      "visibility": "tree"
    },
    "subagents": {
      "tools": {
        "allow": [
          "read",
          "write",
          "edit",
          "grep",
          "glob",
          "ls",
          "sessions_send",
          "sessions_history",
          "sessions_list"
        ],
        "deny": ["gateway", "cron"]
      }
    },
    "web": {
      "search": {
        "enabled": true,
        "provider": "perplexity",
        "maxResults": 8
      },
      "fetch": {
        "enabled": true,
        "maxChars": 30000
      }
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "searchMode": "search",
      "includeDefaultMemory": true,
      "sessions": {
        "enabled": true,
        "exportDir": "${OPENCLAW_WORKSPACE}/memory/sessions",
        "retentionDays": 45
      },
      "update": {
        "onBoot": true,
        "waitForBootSync": false,
        "interval": "15m",
        "embedInterval": "30m",
        "debounceMs": 1500
      },
      "limits": {
        "maxResults": 14,
        "maxSnippetChars": 900,
        "maxInjectedChars": 5500,
        "timeoutMs": 18000
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "${OPENCLAW_WORKSPACE}",
      "model": {
        "primary": "openai/gpt-5",
        "fallbacks": ["anthropic/claude-opus-4-1", "google/gemini-2.5-pro"]
      },
      "pdfModel": {
        "primary": "anthropic/claude-opus-4-1",
        "fallbacks": ["google/gemini-2.5-pro"]
      },
      "pdfMaxBytesMb": 20,
      "pdfMaxPages": 50,
      "thinkingDefault": "high",
      "verboseDefault": "on",
      "maxConcurrent": 2,
      "heartbeat": {
        "every": "30m",
        "target": "none",
        "lightContext": true
      },
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {
          "enabled": true,
          "forceFlushTranscriptBytes": "2mb",
          "prompt": "Before compaction, extract durable preferences, constraints, and active commitments into memory files with clear timestamps.",
          "systemPrompt": "Preserve user intent, operating constraints, and unresolved tasks. Reject redundant or low-signal memory writes."
        }
      },
      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "fallback": "mistral",
        "sources": ["memory", "sessions"],
        "experimental": {
          "sessionMemory": true
        },
        "sync": {
          "onSessionStart": true,
          "onSearch": true,
          "watch": true,
          "watchDebounceMs": 1200,
          "intervalMinutes": 20,
          "sessions": {
            "deltaBytes": 2200,
            "deltaMessages": 8
          }
        },
        "query": {
          "maxResults": 10,
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.65,
            "textWeight": 0.35,
            "candidateMultiplier": 5,
            "mmr": {
              "enabled": true,
              "lambda": 0.62
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 20
            }
          }
        },
        "remote": {
          "batch": {
            "enabled": true,
            "wait": true,
            "concurrency": 2,
            "pollIntervalMs": 5000,
            "timeoutMinutes": 45
          }
        }
      },
      "subagents": {
        "maxConcurrent": 6,
        "maxSpawnDepth": 3,
        "maxChildrenPerAgent": 8,
        "archiveAfterMinutes": 45,
        "thinking": "medium",
        "runTimeoutSeconds": 1200,
        "announceTimeoutMs": 90000,
        "model": {
          "primary": "openai/gpt-5-mini",
          "fallbacks": ["anthropic/claude-sonnet-4"]
        }
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Orchestrator",
        "identity": {
          "name": "Rick Prime",
          "emoji": "🧠",
          "theme": "systems"
        },
        "tools": {
          "profile": "coding"
        },
        "subagents": {
          "allowAgents": ["researcher", "builder", "critic"]
        }
      },
      {
        "id": "researcher",
        "name": "Research Specialist",
        "tools": {
          "profile": "full",
          "allow": ["web_search", "web_fetch", "read", "grep", "glob", "ls"],
          "deny": ["write", "edit", "exec"]
        }
      },
      {
        "id": "builder",
        "name": "Implementation Specialist",
        "tools": {
          "profile": "coding",
          "allow": ["read", "write", "edit", "grep", "glob", "ls", "exec", "run_tests"],
          "deny": ["gateway"]
        }
      },
      {
        "id": "critic",
        "name": "Verification Specialist",
        "tools": {
          "profile": "coding",
          "allow": ["read", "grep", "glob", "ls", "run_tests", "sessions_history"],
          "deny": ["write", "edit"]
        }
      }
    ]
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "codex",
    "allowedAgents": ["codex", "claude-code", "gemini-cli"],
    "maxConcurrentSessions": 4,
    "runtime": {
      "ttlMinutes": 120,
      "installCommand": "pnpm acpx --help"
    },
    "stream": {
      "deliveryMode": "live",
      "coalesceIdleMs": 300,
      "maxChunkChars": 1200,
      "repeatSuppression": true
    }
  },
  "messages": {
    "responsePrefix": "auto",
    "ackReactionScope": "group-mentions",
    "statusReactions": {
      "enabled": true
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "text": true,
    "config": true,
    "debug": true
  },
  "hooks": {
    "enabled": true,
    "defaultSessionKey": "agent:main:main",
    "allowRequestSessionKey": false,
    "allowedSessionKeyPrefixes": ["agent:"],
    "allowedAgentIds": ["main", "researcher", "builder", "critic"],
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true,
          "messages": 25,
          "llmSlug": true
        },
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": [
            "agent-kit/personality/SOUL.md",
            "agent-kit/personality/IDENTITY.md",
            "agent-kit/personality/TOOLS.md",
            "agent-kit/personality/USER.md",
            "agent-kit/personality/HEARTBEAT.md"
          ]
        },
        "command-logger": {
          "enabled": true
        },
        "boot-md": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "streaming": true,
      "reactionLevel": "minimal",
      "commands": {
        "native": "auto",
        "nativeSkills": "auto"
      },
      "network": {
        "autoSelectFamily": true,
        "dnsResultOrder": "ipv4first"
      },
      "retry": {
        "attempts": 3
      }
    }
  }
}
