{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "overrides": [
    {
      "files": ["extensions/feishu/src/monitor.card-action.lifecycle.test.ts"],
      "options": {
        // Vitest vi.mock in lifecycle.test-support must load before ./card-action.ts (pulls ./send.js).
        "sortImports": false,
      },
    },
  ],
  "sortImports": {
    "newlinesBetween": false,
  },
  "sortPackageJson": {
    "sortScripts": true,
  },
  "tabWidth": 2,
  "useTabs": false,
  "ignorePatterns": [
    "apps/",
    "assets/",
    "CLAUDE.md",
    "docker-compose.yml",
    "dist/",
    "docs/_layouts/",
    "node_modules/",
    "patches/",
    "pnpm-lock.yaml/",
    "src/gateway/server-methods/CLAUDE.md",
    "src/auto-reply/reply/export-html/",
    "src/canvas-host/a2ui/a2ui.bundle.js",
    "Swabble/",
    "vendor/",
  ],
}
