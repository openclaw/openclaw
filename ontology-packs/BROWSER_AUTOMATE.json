{
  "pack_id": "openclawd.BROWSER_AUTOMATE",
  "pack_version": "1.0.0",
  "stage_id": "BROWSER_AUTOMATE",
  "description": "Governs automated browser interactions including navigation, DOM manipulation, and form submissions. Controls access to sensitive browser capabilities like credential input and script execution.",
  "thresholds": {
    "min_confidence_T": 0,
    "dominance_margin_Delta": 0
  },
  "contracts": [
    {
      "contract_id": "BROWSER_NAVIGATE_PUBLIC",
      "risk_class": "LOW",
      "required_fields": [
        "url"
      ],
      "limits": {},
      "needs_confirmation": false,
      "deny_by_default": false,
      "capability_requirements": []
    },
    {
      "contract_id": "BROWSER_SCREENSHOT",
      "risk_class": "LOW",
      "required_fields": [
        "action"
      ],
      "limits": {},
