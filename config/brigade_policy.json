{
  "brigades": {
    "OpenClaw": {
      "root_path": "./",
      "permissions": {
        "can_modify_framework": true,
        "can_modify_dmarket": true,
        "can_execute_system_commands": true,
        "restricted_namespaces": []
      },
      "roles": {
        "Security_Auditor": "Monitors Dmarket agents for unauthorized sandbox escapes (e.g., os.system calls outside allowed paths)."
      }
    },
    "Dmarket": {
      "root_path": "../Dmarket_bot/",
      "permissions": {
        "can_modify_framework": false,
        "can_modify_dmarket": true,
        "can_execute_system_commands": false,
        "restricted_namespaces": ["os.system", "subprocess", "openclaw_bot.core"]
      },
      "roles": {
        "Security_Auditor": "Checks Dmarket bot code for API key leaks and sensitive data exposure."
      }
    }
  }
}
