# Copy to deploy/.env on the VPS and fill in. deploy/.env is gitignored.

# ---- Anthropic ------------------------------------------------------------
# The key the gateway uses to call Claude. Set this on the VPS only — never
# commit it.
ANTHROPIC_API_KEY=

# ---- Embeddings -----------------------------------------------------------
# Used by memory-supabase for vector search. text-embedding-3-small is fine.
OPENAI_API_KEY=

# ---- Supabase -------------------------------------------------------------
# From your Supabase project settings. Service-role key is backend-only.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Used only for one-shot psql migration runs:
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ---- Google OAuth (Desktop client) ---------------------------------------
# One client + refresh token covers BOTH Gmail (inbox-triage) and Calendar
# (calendar plugin). The auth helper requests both scopes by default.
GMAIL_USER=you@gmail.com
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Generate via: node extensions/inbox-triage/scripts/gmail-auth.mjs
GMAIL_OAUTH_REFRESH_TOKEN=

# ---- WhatsApp ------------------------------------------------------------
# Your own JID — used as the "self" target for the morning brief.
# Format: <countrycode><number>@s.whatsapp.net  e.g. 447712345678@s.whatsapp.net
OPENCLAW_WHATSAPP_SELF_JID=

# ---- Gateway -------------------------------------------------------------
# Random 32-byte hex token if you want the Caddyfile bearer gate enabled.
# openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ---- Misc ----------------------------------------------------------------
TZ=Europe/London
