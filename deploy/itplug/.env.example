# Copy this file to deploy/itplug/.env for local use or to /opt/openclaw-itplug/.env on the VPS.
# Keep the real .env out of git. The Cloudflare route should target the shared network namespace
# used by cloudflared and openclaw-gateway, so OpenClaw stays private and is not published on a host port.

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_TZ=Europe/London

# Host paths on the Ubuntu VPS
OPENCLAW_CONFIG_DIR=/opt/openclaw-itplug/config
OPENCLAW_WORKSPACE_DIR=/opt/openclaw-itplug/workspace
OPENCLAW_CONTROL_UI_DIR=/opt/openclaw-itplug/control-ui

# Keep the gateway internal-only. Cloudflared reaches 127.0.0.1:18789 through the
# shared container network namespace, so no Docker port publishing is required.
OPENCLAW_GATEWAY_BIND=loopback

# Set a strong random token before deployment.
OPENCLAW_GATEWAY_TOKEN=replace-with-strong-random-token

# Paste the rotated Cloudflare tunnel token here before starting cloudflared.
CLOUDFLARE_TUNNEL_TOKEN=replace-with-rotated-cloudflare-tunnel-token

# Auto-update timer settings (used by /usr/local/bin/openclaw-itplug-update)
OPENCLAW_REPO_DIR=/opt/openclaw-itplug
OPENCLAW_GIT_BRANCH=main
OPENCLAW_ENV_FILE=.env
