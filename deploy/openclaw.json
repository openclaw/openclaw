{
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"]
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.22",
    "lastTouchedAt": "2026-04-23T10:40:42.567Z"
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "open",
      "groupPolicy": "open",
      "debounceMs": 0,
      "mediaMaxMb": 50,
      "capabilities": [],
      "allowFrom": ["*"],
      "groupAllowFrom": ["*"],
      "dms": {
        "custom-1": {}
      },
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "models": {
    "mode": "merge"
  },
  "plugins": {
    "entries": {
      "memory-core": {
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      },
      "whatsapp": {
        "config": {}
      },
      "google": {
        "enabled": true
      },
      "skill-workshop": {
        "enabled": false
      },
      "acpx": {
        "enabled": true,
        "config": {
          "permissionMode": "approve-all",
          "mcpServers": {
            "github": {
              "command": "npx",
              "args": ["-y", "@modelcontextprotocol/server-github"],
              "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
              }
            }
          }
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "contextInjection": "continuation-skip",
      "bootstrapMaxChars": 10000,
      "bootstrapTotalMaxChars": 80000,
      "thinkingDefault": "off",
      "model": {
        "primary": "google/gemini-2.5-flash"
      }
    },
    "list": [
      {
        "id": "main",
        "tools": {
          "deny": ["code_execution"]
        },
        "groupChat": {
          "historyLimit": 20,
          "mentionPatterns": ["@?[Bb]ucky", "bucky"]
        }
      }
    ]
  }
}
