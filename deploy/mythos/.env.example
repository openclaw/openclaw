# Environment variables for Mythos-Class Docker deployment
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway Authentication
# ═══════════════════════════════════════════════════════════════════════════════
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# Model Provider API Keys
# ═══════════════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Channel Tokens
# ═══════════════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# GitHub
# ═══════════════════════════════════════════════════════════════════════════════
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# PostgreSQL
# ═══════════════════════════════════════════════════════════════════════════════
PG_USER=openclaw
PG_PASSWORD=changeme
PG_DATABASE=mythos

# ═══════════════════════════════════════════════════════════════════════════════
# Observability
# ═══════════════════════════════════════════════════════════════════════════════
# OpenTelemetry endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# ═══════════════════════════════════════════════════════════════════════════════
# Ports
# ═══════════════════════════════════════════════════════════════════════════════
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_CANVAS_PORT=18793

# ═══════════════════════════════════════════════════════════════════════════════
# Timezone
# ═══════════════════════════════════════════════════════════════════════════════
TZ=UTC
