ri version"]},"_hasShrinkwrap":false,"devDependencies":{"jest":"^29.5.0","dts-cli":"^2.0.5","typescript":"^5.0.4","@types/jest":"^29.5.1"},"_npmOperationalInternal":{"tmp":"tmp/nockjs_1.6.0_1747424175846_0.8270617782685925","host":"s3://npm-registry-packages-npm-production"}}},"time":{"created":"2022-10-13T21:40:10.262Z","modified":"2025-11-19T15:33:30.493Z","0.0.1":"2022-10-13T21:40:10.499Z","1.0.0":"2023-09-11T15:50:19.960Z","1.0.1":"2023-09-11T15:56:30.151Z","1.1.0":"2023-09-11T17:21:16.779Z","1.2.0":"2024-04-30T14:11:41.934Z","1.3.0":"2024-04-30T22:54:06.087Z","1.4.0-dev":"2024-05-06T18:49:09.293Z","1.4.0-dev1":"2024-05-06T19:04:55.388Z","1.4.0-dev2":"2024-07-13T21:34:42.381Z","1.4.0-dev3":"2024-07-18T12:04:59.942Z","1.4.0-dev4":"2024-07-18T12:08:48.769Z","1.4.0":"2024-11-12T16:37:03.563Z","1.5.0":"2025-03-12T14:29:25.441Z","1.6.0":"2025-05-16T19:36:16.061Z"},"bugs":{"url":"https://github.com/urbit/nockjs/issues"},"author":{"name":"frodwith, joemfb, iamwillkim, tomholford, polwex, palfun-foslup, nocsyx-lassul"},"license":"MIT","homepage":"https://github.com/urbit/nockjs#readme","keywords":["urbit","nock","js","ts"],"repository":{"url":"git+https://github.com/urbit/nockjs.git","type":"git"},"description":"Javascript urbit runtime","maintainers":[{"email":"yosoyubik@gmail.com","name":"yosoyubik"},{"email":"t@fust.us","name":"tylershuster"},{"email":"josh@urbit.org","name":"wolref-podlex"},{"email":"liam.fitzgerald@tlon.io","name":"liam-fitzgerald"},{"email":"matilde.park@urbit.org","name":"matildepark_"},{"email":"mwvdavidson@gmail.com","name":"mwvd"},{"email":"james.muturi@tlon.io","name":"_waiyaki_"},{"email":"hunter@tlon.io","name":"nocsyx-lassul"},{"email":"gordon@hey.com","name":"gordoncc"},{"email":"mark@tlon.io","name":"plfn-tlon"}],"readme":"# nockjs\n\nA Javascript implementation of [Nock](https://developers.urbit.org/reference/nock).\n\n## Install\n\n```\nnpm install @urbit/nockjs\n```\n\n## Usage\n\nPresently, primarily for dealing with nouns as Javascript objects.\n\n- A `Noun` is an `Atom` or a `Cell`.\n- `Atom.fromString('123', 10)`, `Atom.fromInt(123)`, `Atom.fromCord('{')` all create a new `Atom` object. Uses `bigint` internally, can construct with `new Atom(someBigint)`.\n- `new Cell(a, b)`.\n- `dwim(...)` does a best-effort attempt of interpreting the arguments into a `Noun`.\n- `enjs` contains `Noun => Json` conversions and conversion builders.\n- `dejs`contains `Json => Noun` conversions for idiomatic noun shapes.\n\n### Immutability\n\nWhen working with Noun objects, it is important to treat them as immutable,\nand not assign to their properties or otherwise modify them directly. The\nTypeScript `readonly` property should prevent you from doing so, and you\nmust not ignore this.\n\nThis library implements unifying equality, deduplicating identical nouns in\nmemory whenever they are detected. This means that one `Noun` object might be\na sub-noun to many other `Noun`s, and changing the one sub-noun could change it\nfor all nouns it is used in. Additionally, the `Noun` object keeps a mug cache,\nwhich does not get cleared when illicitly changing the noun's contents.\n","readmeFilename":"README.md"}