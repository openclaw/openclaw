prefix=/opt/homebrew/Cellar/xz/5.8.3
exec_prefix=/opt/homebrew/Cellar/xz/5.8.3
libdir=/opt/homebrew/Cellar/xz/5.8.3/lib
includedir=/opt/homebrew/Cellar/xz/5.8.3/include

Name: liblzma
Description: General purpose data compression library
License: 0BSD
URL: https://tukaani.org/xz/
Version: 5.8.3
Cflags: -I${includedir}
Cflags.private: -DLZMA_API_STATIC
Libs: -L${libdir} -llzma
Libs.private: -pthread -lpthread 
