prefix=/opt/homebrew/Cellar/ffmpeg/8.1
exec_prefix=${prefix}
libdir=/opt/homebrew/Cellar/ffmpeg/8.1/lib
includedir=/opt/homebrew/Cellar/ffmpeg/8.1/include

Name: libswresample
Description: FFmpeg audio resampling library
Version: 6.3.100
Requires: 
Requires.private: libavutil >= 60.26.100
Conflicts:
Libs: -L${libdir}  -lswresample 
Libs.private: -lm
Cflags: -I${includedir}
