     1	#!/usr/bin/env node
     2	/**
     3	 * install.mjs — Install / reconcile bench-reflective-dreaming.
     4	 *
     5	 * Idempotent:
     6	 *   1. Copies assets/prompts/*.md into the vault concepts dir (only if content
     7	 *      differs by sha256, so re-runs are cheap and don't needlessly touch mtimes).
     8	 *   2. Migrates any un-tagged "dream-<agent>" / "fleet-canon" / "memory-consolidation"
     9	 *      cron jobs (the orphan ones created before this extension existed) into
    10	 *      plugin-managed ones by recreating them with the managed-by tag in the
    11	 *      description.
    12	 *   3. Reconciles managed cron jobs from defaults/cron-schedule.json: adds what's
    13	 *      missing, updates what's changed, removes what's no longer in defaults.
    14	 *
    15	 * Run it from anywhere:
    16	 *   node scripts/install.mjs
    17	 *
    18	 * Or via the bash wrapper:
    19	 *   bash scripts/install.sh
    20	 */
