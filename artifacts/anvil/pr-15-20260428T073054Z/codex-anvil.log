      await removeCronJob(job.id);
      removed += 1;
      continue;
    }
    if (seen.has(job.name)) {
      console.log(`[reflective-dreaming] removing duplicate cron ${job.name} (${job.id})`);
      await removeCronJob(job.id);
      removed += 1;
      continue;
