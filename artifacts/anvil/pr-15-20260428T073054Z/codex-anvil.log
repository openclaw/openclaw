   148	export function listBundledPluginPackArtifacts(params = {}) {
   149	  const entries = collectBundledPluginBuildEntries(params).filter(
   150	    ({ id }) => !NON_PACKAGED_BUNDLED_PLUGIN_DIRS.has(id),
   151	  );
   152	  const artifacts = new Set();
   153	
   154	  for (const { id, hasManifest, hasPackageJson, sourceEntries } of entries) {
   155	    if (hasManifest) {
   156	      artifacts.add(bundledDistPluginFile(id, "openclaw.plugin.json"));
   157	    }
   158	    if (hasPackageJson) {
   159	      artifacts.add(bundledDistPluginFile(id, "package.json"));
   160	    }
   161	    for (const entry of sourceEntries) {
   162	      const normalizedEntry = entry.replace(/^\.\//, "").replace(/\.[^.]+$/u, "");
   163	      artifacts.add(bundledDistPluginFile(id, `${normalizedEntry}.js`));
   164	    }
   165	  }
   166	
   167	  return [...artifacts].toSorted((left, right) => left.localeCompare(right));
   168	}
