           report: 0,
+          canon: 0,
         },
         sourceCounts: {
           native: 0,
           bridge: 0,
           bridgeEvents: 0,
           unsafeLocal: 0,
           other: 0,
         },
       };
 
   return {
     vaultMode: config.vaultMode,
     renderMode: config.vault.renderMode,
     vaultPath: config.vault.path,
     vaultExists,
     bridge: config.bridge,
