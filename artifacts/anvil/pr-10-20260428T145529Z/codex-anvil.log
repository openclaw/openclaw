   278	export function buildMemoryWikiDoctorReport(status: MemoryWikiStatus): MemoryWikiDoctorReport {
   279	  const fixes = status.warnings.map((warning) => ({
   280	    code: warning.code,
   281	    message:
   282	      warning.code === "vault-missing"
   283	        ? "Run `openclaw wiki init` to create the vault layout."
   284	        : warning.code === "obsidian-cli-missing"
   285	          ? "Install the official Obsidian CLI or disable `obsidian.useOfficialCli`."
   286	          : warning.code === "bridge-disabled"
   287	            ? "Enable `plugins.entries.memory-wiki.config.bridge.enabled` or switch vaultMode away from `bridge`."
   288	            : warning.code === "bridge-artifacts-missing"
   289	              ? "Use a memory plugin that exports public artifacts, create/import memory artifacts first, or switch the wiki back to isolated mode."
   290	              : warning.code === "unsafe-local-disabled"
   291	                ? "Enable `unsafeLocal.allowPrivateMemoryCoreAccess` or switch vaultMode away from `unsafe-local`."
   292	                : warning.code === "unsafe-local-paths-missing"
   293	                  ? "Add explicit `unsafeLocal.paths` entries before running unsafe-local imports."
   294	                  : "Disable private memory-core access unless you explicitly want unsafe-local mode.",
   295	  }));
   296	  return {
   297	    healthy: status.warnings.length === 0,
   298	    warningCount: status.warnings.length,
   299	    status,
   300	    fixes,
   301	  };
   302	}
