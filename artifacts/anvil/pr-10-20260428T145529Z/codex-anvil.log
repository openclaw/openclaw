   const normalized = relativePath.split(path.sep).join("/");
   if (normalized.startsWith("entities/")) {
     return "entity";
   }
   if (normalized.startsWith("concepts/")) {
     return "concept";
   }
   if (normalized.startsWith("sources/")) {
