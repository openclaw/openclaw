   278	      const metadataLower = normalizeLowercaseStringOrEmpty(
   279	        buildDigestPageSearchText(page, claims),
   280	      );
   281	      if (!metadataLower.includes(queryLower)) {
   282	        return { path: page.path, score: 0 };
   283	      }
   284	      let score = 1;
   285	      const titleLower = normalizeLowercaseStringOrEmpty(page.title);
   286	      const pathLower = normalizeLowercaseStringOrEmpty(page.path);
   287	      const idLower = normalizeLowercaseStringOrEmpty(page.id);
   288	      if (titleLower === queryLower) {
   289	        score += 50;
   290	      } else if (titleLower.includes(queryLower)) {
   291	        score += 20;
   292	      }
   293	      if (pathLower.includes(queryLower)) {
   294	        score += 10;
   295	      }
   296	      if (idLower.includes(queryLower)) {
   297	        score += 20;
   298	      }
   299	      if (
