   233	function scoreDigestClaimMatch(claim: QueryDigestClaim, queryLower: string): number {
   234	  let score = 0;
   235	  if (normalizeLowercaseStringOrEmpty(claim.text).includes(queryLower)) {
   236	    score += 25;
   237	  }
   238	  if (normalizeLowercaseStringOrEmpty(claim.id).includes(queryLower)) {
   239	    score += 10;
   240	  }
   241	  if (typeof claim.confidence === "number") {
   242	    score += Math.round(claim.confidence * 10);
   243	  }
   244	  switch (claim.freshnessLevel) {
   245	    case "fresh":
   246	      score += 8;
   247	      break;
   248	    case "aging":
   249	      score += 4;
   250	      break;
   251	    case "stale":
   252	      score -= 2;
   253	      break;
   254	    case "unknown":
   255	      score -= 4;
   256	      break;
   257	  }
   258	  score += isClaimContestedStatus(claim.status) ? -6 : 4;
   259	  return score;
   260	}
