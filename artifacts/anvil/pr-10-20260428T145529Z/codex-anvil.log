   157	async function listPagePaths(rootDir: string): Promise<string[]> {
   158	  const collected: string[] = [];
   159	  for (const { dir } of PAGE_DIRS) {
   160	    const entries = await fs
   161	      .readdir(path.join(rootDir, dir), { withFileTypes: true })
   162	      .catch(() => []);
   163	    for (const entry of entries) {
