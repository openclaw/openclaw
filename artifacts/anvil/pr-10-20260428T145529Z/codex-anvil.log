   310	          }
   311	          return normalizeLowercaseStringOrEmpty(claim.id).includes(queryLower);
   312	        })
   313	        .toSorted(
   314	          (left, right) =>
   315	            scoreDigestClaimMatch(right, queryLower) - scoreDigestClaimMatch(left, queryLower),
   316	        );
   317	      if (matchingClaims.length > 0) {
