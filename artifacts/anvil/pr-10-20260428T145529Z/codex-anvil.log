   304	export function renderMemoryWikiStatus(status: MemoryWikiStatus): string {
   305	  const lines = [
   306	    `Wiki vault mode: ${status.vaultMode}`,
   307	    `Vault: ${status.vaultExists ? "ready" : "missing"} (${status.vaultPath})`,
   308	    `Render mode: ${status.renderMode}`,
   309	    `Obsidian CLI: ${status.obsidianCli.available ? "available" : "missing"}${status.obsidianCli.requested ? " (requested)" : ""}`,
   310	    `Bridge: ${status.bridge.enabled ? "enabled" : "disabled"}${typeof status.bridgePublicArtifactCount === "number" ? ` (${status.bridgePublicArtifactCount} exported artifact${status.bridgePublicArtifactCount === 1 ? "" : "s"})` : ""}`,
   311	    `Unsafe local: ${status.unsafeLocal.allowPrivateMemoryCoreAccess ? `enabled (${status.unsafeLocal.pathCount} paths)` : "disabled"}`,
   312	    `Pages: ${status.pageCounts.source} sources, ${status.pageCounts.entity} entities, ${status.pageCounts.concept} concepts, ${status.pageCounts.synthesis} syntheses, ${status.pageCounts.report} reports`,
   313	    `Source provenance: ${status.sourceCounts.native} native, ${status.sourceCounts.bridge} bridge, ${status.sourceCounts.bridgeEvents} bridge-events, ${status.sourceCounts.unsafeLocal} unsafe-local, ${status.sourceCounts.other} other`,
   314	  ];
   315	
   316	  if (status.warnings.length > 0) {
   317	    lines.push("", "Warnings:");
   318	    for (const warning of status.warnings) {
   319	      lines.push(`- ${warning.message}`);
   320	    }
   321	  }
   322	
   323	  return lines.join("\n");
   324	}
