   262	function buildDigestCandidatePaths(params: {
   263	  digest: QueryDigestBundle;
   264	  query: string;
   265	  maxResults: number;
   266	}): string[] {
   267	  const queryLower = normalizeLowercaseStringOrEmpty(params.query);
   268	  const claimsByPage = new Map<string, QueryDigestClaim[]>();
   269	  for (const claim of params.digest.claims) {
   270	    const current = claimsByPage.get(claim.pagePath) ?? [];
   271	    current.push(claim);
   272	    claimsByPage.set(claim.pagePath, current);
   273	  }
   274	
