   215	export async function resolveMemoryWikiStatus(
   216	  config: ResolvedMemoryWikiConfig,
   217	  deps?: ResolveMemoryWikiStatusDeps,
   218	): Promise<MemoryWikiStatus> {
   219	  const exists = deps?.pathExists ?? pathExists;
   220	  const vaultExists = await exists(config.vault.path);
   221	  const bridgePublicArtifactCount =
   222	    deps?.appConfig && config.vaultMode === "bridge" && config.bridge.enabled
   223	      ? (
   224	          await (deps.listPublicArtifacts ?? listActiveMemoryPublicArtifacts)({
   225	            cfg: deps.appConfig,
   226	          })
   227	        ).length
   228	      : null;
   229	  const obsidianProbe = await probeObsidianCli({ resolveCommand: deps?.resolveCommand });
   230	  const counts = vaultExists
   231	    ? await collectVaultCounts(config.vault.path)
   232	    : {
   233	        pageCounts: {
   234	          entity: 0,
   235	          concept: 0,
   236	          source: 0,
   237	          synthesis: 0,
   238	          report: 0,
   239	          canon: 0,
   240	        },
   241	        sourceCounts: {
   242	          native: 0,
   243	          bridge: 0,
   244	          bridgeEvents: 0,
   245	          unsafeLocal: 0,
   246	          other: 0,
   247	        },
   248	      };
   249	
   250	  return {
   251	    vaultMode: config.vaultMode,
   252	    renderMode: config.vault.renderMode,
   253	    vaultPath: config.vault.path,
   254	    vaultExists,
   255	    bridge: config.bridge,
   256	    bridgePublicArtifactCount,
   257	    obsidianCli: {
   258	      enabled: config.obsidian.enabled,
   259	      requested: config.obsidian.enabled && config.obsidian.useOfficialCli,
   260	      available: obsidianProbe.available,
   261	      command: obsidianProbe.command,
   262	    },
   263	    unsafeLocal: {
   264	      allowPrivateMemoryCoreAccess: config.unsafeLocal.allowPrivateMemoryCoreAccess,
   265	      pathCount: config.unsafeLocal.paths.length,
   266	    },
   267	    pageCounts: counts.pageCounts,
   268	    sourceCounts: counts.sourceCounts,
   269	    warnings: buildWarnings({
   270	      config,
   271	      bridgePublicArtifactCount,
   272	      vaultExists,
   273	      obsidianCommand: obsidianProbe.command,
   274	    }),
   275	  };
   276	}
