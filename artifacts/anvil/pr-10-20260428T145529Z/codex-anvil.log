    77	async function collectVaultCounts(vaultPath: string): Promise<{
    78	  pageCounts: Record<WikiPageKind, number>;
    79	  sourceCounts: MemoryWikiStatus["sourceCounts"];
    80	}> {
    81	  const pageCounts: Record<WikiPageKind, number> = {
    82	    entity: 0,
    83	    concept: 0,
    84	    source: 0,
    85	    synthesis: 0,
    86	    report: 0,
    87	    canon: 0,
    88	  };
    89	  const sourceCounts: MemoryWikiStatus["sourceCounts"] = {
    90	    native: 0,
    91	    bridge: 0,
    92	    bridgeEvents: 0,
    93	    unsafeLocal: 0,
    94	    other: 0,
    95	  };
    96	  const dirs = ["entities", "concepts", "sources", "syntheses", "reports", "canon"] as const;
    97	  for (const dir of dirs) {
    98	    const entries = await fs
    99	      .readdir(path.join(vaultPath, dir), { withFileTypes: true })
   100	      .catch(() => []);
   101	    for (const entry of entries) {
   102	      if (!entry.isFile() || !entry.name.endsWith(".md") || entry.name === "index.md") {
   103	        continue;
   104	      }
   105	      const kind = inferWikiPageKind(path.join(dir, entry.name));
   106	      if (kind) {
   107	        pageCounts[kind] += 1;
   108	      }
   109	      if (dir === "sources") {
   110	        const absolutePath = path.join(vaultPath, dir, entry.name);
   111	        const raw = await fs.readFile(absolutePath, "utf8").catch(() => null);
   112	        if (!raw) {
   113	          continue;
   114	        }
   115	        const page = toWikiPageSummary({
   116	          absolutePath,
   117	          relativePath: path.join(dir, entry.name),
   118	          raw,
   119	        });
   120	        if (!page) {
   121	          continue;
   122	        }
   123	        if (page.sourceType === "memory-bridge-events") {
   124	          sourceCounts.bridgeEvents += 1;
   125	        } else if (page.sourceType === "memory-bridge") {
   126	          sourceCounts.bridge += 1;
   127	        } else if (
   128	          page.provenanceMode === "unsafe-local" ||
   129	          page.sourceType === "memory-unsafe-local"
   130	        ) {
   131	          sourceCounts.unsafeLocal += 1;
   132	        } else if (!page.sourceType) {
   133	          sourceCounts.native += 1;
   134	        } else {
   135	          sourceCounts.other += 1;
   136	        }
   137	      }
   138	    }
   139	  }
   140	  return { pageCounts, sourceCounts };
   141	}
