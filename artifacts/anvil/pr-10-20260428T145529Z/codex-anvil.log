   176	/**
   177	 * Walk the vault and apply deterministic structure repairs:
   178	 *  - Inject missing `id`, `pageType`, `title`, `updatedAt` on every content page.
   179	 *  - Optionally remove orphan source shells (files whose only content is an empty Related block).
   180	 *
   181	 * The function never rewrites human-authored body text and never overwrites existing
   182	 * frontmatter values.
   183	 */
   184	export async function repairMemoryWikiVault(
   185	  config: ResolvedMemoryWikiConfig,
   186	  options: RepairMemoryWikiOptions = {},
   187	): Promise<RepairMemoryWikiResult> {
   188	  const rootDir = config.vault.path;
   189	  const nowIso = new Date(options.nowMs ?? Date.now()).toISOString();
   190	  const pagePaths = await listPagePaths(rootDir);
   191	  const pages: RepairedPage[] = [];
   192	  let backfilled = 0;
   193	  let orphansRemoved = 0;
   194	
   195	  for (const relativePath of pagePaths) {
   196	    const absolutePath = path.join(rootDir, relativePath);
   197	    const raw = await fs.readFile(absolutePath, "utf8").catch(() => null);
   198	    if (raw === null) {
   199	      pages.push({
   200	        relativePath,
   201	        operation: "skipped",
   202	        fieldsAdded: [],
   203	        reason: "file disappeared",
   204	      });
   205	      continue;
   206	    }
   207	    const parsed = parseWikiMarkdown(raw);
   208	    const hasFrontmatter = Object.keys(parsed.frontmatter).length > 0;
   209	    const emptyBody = !parsed.body.trim() || looksLikeOrphanShell(parsed.body);
   210	    const isOrphan = !hasFrontmatter && emptyBody && relativePath.startsWith("sources/");
   211	
   212	    if (isOrphan) {
   213	      if (options.removeOrphans) {
   214	        await fs.rm(absolutePath, { force: true }).catch(() => undefined);
   215	        pages.push({
   216	          relativePath,
   217	          operation: "removed-orphan",
   218	          fieldsAdded: [],
   219	          reason: "no frontmatter + empty body",
   220	        });
   221	        orphansRemoved += 1;
   222	      } else {
   223	        pages.push({
   224	          relativePath,
   225	          operation: "skipped",
   226	          fieldsAdded: [],
   227	          reason: "orphan shell — pass --remove-orphans to delete",
   228	        });
   229	      }
   230	      continue;
   231	    }
   232	
   233	    const result = await ensurePageStructure({ rootDir, relativePath, nowIso });
   234	    pages.push(result);
   235	    if (result.operation === "backfilled-structure") {
   236	      backfilled += 1;
   237	    }
   238	  }
   239	
   240	  if (backfilled > 0 || orphansRemoved > 0) {
   241	    await appendMemoryWikiLog(rootDir, {
   242	      type: "repair",
   243	      timestamp: nowIso,
   244	      details: {
   245	        scanned: pagePaths.length,
   246	        backfilled,
   247	        orphansRemoved,
   248	      },
   249	    });
   250	  }
   251	
   252	  return {
   253	    vaultRoot: rootDir,
   254	    scanned: pagePaths.length,
   255	    backfilled,
   256	    orphansRemoved,
   257	    pages,
   258	  };
   259	}
