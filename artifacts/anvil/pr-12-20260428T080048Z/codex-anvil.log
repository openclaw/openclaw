async function mergeEnvAndConfig() {
  const config = loadRelayConfigFile();
  const relayId = process.env.RELAY_ID || config.relayId || RELAY_ID;
  await migrateRelaySecretsToKeychain(relayId, config);
  const keychainSecrets = await readRelaySecretsFromKeychain(relayId);
  const envSessionToken = typeof process.env.RELAY_SESSION_TOKEN === 'string' && process.env.RELAY_SESSION_TOKEN.trim()
    ? process.env.RELAY_SESSION_TOKEN.trim()
    : null;
  const envSessionExpiresAt = typeof process.env.RELAY_SESSION_EXPIRES_AT === 'string' && process.env.RELAY_SESSION_EXPIRES_AT.trim()
    ? process.env.RELAY_SESSION_EXPIRES_AT.trim()
    : null;
  const keychainSessionToken = typeof keychainSecrets?.sessionToken === 'string' && keychainSecrets.sessionToken.trim()
    ? keychainSecrets.sessionToken.trim()
    : null;
  const keychainSessionExpiresAt = typeof keychainSecrets?.sessionExpiresAt === 'string' && keychainSecrets.sessionExpiresAt.trim()
    ? keychainSecrets.sessionExpiresAt.trim()
    : null;

  if (keychainSessionToken && envSessionToken && envSessionToken !== keychainSessionToken) {
    log('warn', 'Ignoring env-pinned relay session token because keychain session is present', { relayId });
  }

  const resolvedSessionToken = keychainSessionToken || envSessionToken || config.sessionToken || null;
  const resolvedSessionExpiresAt = keychainSessionToken
    ? keychainSessionExpiresAt || config.sessionExpiresAt || null
    : keychainSessionExpiresAt || envSessionExpiresAt || config.sessionExpiresAt || null;

  return {
    bootstrapToken: process.env.RELAY_BOOTSTRAP_TOKEN || config.bootstrapToken || null,
    installId: process.env.RELAY_INSTALL_ID || config.installId || null,
    instanceId: process.env.INSTANCE_ID || config.instanceId || null,
    agentId: process.env.AGENT_ID || config.agentId || 'aurelius',
    relayId,
    gatewayUrl: process.env.GATEWAY_URL || config.gatewayUrl || 'http://localhost:18789',
    gatewayToken: process.env.GATEWAY_TOKEN || config.gatewayToken || null,
    relayApiBaseUrl: process.env.RELAY_API_BASE_URL || config.relayApiBaseUrl || RELAY_API_BASE_URL,
    machineLabel: process.env.RELAY_MACHINE_LABEL || config.machineLabel || os.hostname(),
    authMode: process.env.RELAY_AUTH_MODE || keychainSecrets?.authMode || config.authMode || null,
    sessionToken: resolvedSessionToken,
    sessionExpiresAt: resolvedSessionExpiresAt,
    firebase: keychainSecrets?.firebase || config.firebase || null,
  };
}

const RELAY_FETCH_TIMEOUT_MS = 30_000;

async function postRelayLifecycle(pathname, body, sessionToken = null) {
  const response = await fetch(`${RELAY_API_BASE_URL.replace(/\/$/, '')}${pathname}`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Connection': 'close',
      ...(sessionToken ? { Authorization: `Bearer ${sessionToken}` } : {}),
    },
    body: JSON.stringify(body),
    signal: AbortSignal.timeout(RELAY_FETCH_TIMEOUT_MS),
    keepalive: false,
  });

  const payload = await response.json().catch(() => ({}));
  if (!response.ok) {
    const detail = payload?.detail || payload?.error || `${response.status} ${response.statusText}`;
    throw new Error(detail);
  }

  return payload;
}

async function applyBenchRuntimeResponse(runtime) {
  RELAY_INSTALL_ID = runtime.installId || RELAY_INSTALL_ID;
  INSTANCE_ID = runtime.instanceId || INSTANCE_ID;
  AGENT_ID = runtime.agentId || AGENT_ID;
  RELAY_ID = runtime.relayId || RELAY_ID;
  GATEWAY_URL = runtime.gatewayUrl || GATEWAY_URL;
  RELAY_API_BASE_URL = runtime.relayApiBaseUrl || RELAY_API_BASE_URL;
  RELAY_AUTH_MODE = runtime.authMode || RELAY_AUTH_MODE;
  RELAY_SESSION_TOKEN = runtime.sessionToken || RELAY_SESSION_TOKEN;
  RELAY_SESSION_EXPIRES_AT = runtime.sessionExpiresAt || RELAY_SESSION_EXPIRES_AT;
  RELAY_SERVER_LEASE_DURATION_MS = Number.isFinite(runtime.controlPlane?.leaseDurationMs)
    ? Number(runtime.controlPlane.leaseDurationMs)
    : RELAY_SERVER_LEASE_DURATION_MS;
  RELAY_SERVER_MAX_ATTEMPTS = Number.isFinite(runtime.controlPlane?.maxAttempts)
    ? Number(runtime.controlPlane.maxAttempts)
    : RELAY_SERVER_MAX_ATTEMPTS;

  process.env.LEASE_DURATION_MS = `${RELAY_SERVER_LEASE_DURATION_MS}`;
  process.env.MAX_ATTEMPTS = `${RELAY_SERVER_MAX_ATTEMPTS}`;

  relayRuntimeState.lastBackendAuthRefreshAt = new Date().toISOString();
  clearRuntimeError();

  const secretState = {
    sessionToken: RELAY_SESSION_TOKEN,
    sessionExpiresAt: RELAY_SESSION_EXPIRES_AT,
    authMode: RELAY_AUTH_MODE,
  };

  let keychainStored = false;
  try {
    await writeRelaySecretsToKeychain(RELAY_ID, secretState);
    keychainStored = true;
  } catch (error) {
    log('warn', 'Failed to store relay secrets in macOS Keychain; falling back to local config', {
      relayId: RELAY_ID,
      error: error.message,
    });
  }

  persistRelayConfigPatch({
    bootstrapToken: null,
    installId: RELAY_INSTALL_ID,
    instanceId: INSTANCE_ID,
    agentId: AGENT_ID,
    relayId: RELAY_ID,
    gatewayUrl: GATEWAY_URL,
    relayApiBaseUrl: RELAY_API_BASE_URL,
    machineLabel: os.hostname(),
    authMode: RELAY_AUTH_MODE,
    firebaseAuthSource: runtime.firebase?.serviceAccountKey || runtime.firebase?.accessToken
