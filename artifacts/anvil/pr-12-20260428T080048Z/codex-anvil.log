async function getBaselineAssistantTimestamp(historyArgs, execOptions, runId) {
  let baselineAssistantTimestamp = 0;
  try {
    const { stdout } = await execFileAsync(OPENCLAW_BIN, historyArgs, execOptions);
    const payload = parseJsonTail(stdout);
    const messages = Array.isArray(payload?.messages) ? payload.messages : [];
    baselineAssistantTimestamp = messages
      .filter((entry) => entry?.role === 'assistant')
      .reduce((latest, entry) => Math.max(latest, getMessageTimestamp(entry)), 0);
  } catch (error) {
    log('warn', 'Initial OpenClaw history read failed', { runId, error: error.message });
  }
  return baselineAssistantTimestamp;
}

function buildGatewayStatusArgs() {
  return [
    'gateway',
    'call',
    'status',
    '--json',
  ];
}

function buildGatewayHealthArgs() {
  return [
    'gateway',
    'call',
    'health',
    '--json',
  ];
}

function getCanonicalGatewaySessionKey(run) {
  const { clawAgentId, sessionId } = getGatewayContext(run);
  return `agent:${clawAgentId}:${sessionId}`.toLowerCase();
}

function normalizeGatewaySessionCandidate(candidate) {
  if (!candidate || typeof candidate !== 'object') {
    return null;
  }

  const key = typeof candidate.key === 'string' ? candidate.key.toLowerCase() : null;
  if (!key) {
    return null;
  }

  return {
    key,
    updatedAt: Number(candidate.updatedAt || 0),
    model: typeof candidate.model === 'string' ? candidate.model : null,
    abortedLastRun: candidate.abortedLastRun === true,
  };
}

async function getGatewaySessionSnapshot(run, execOptions) {
  const targetKey = getCanonicalGatewaySessionKey(run);
  let healthOk = true;
  let session = null;

  try {
    const { stdout } = await execFileAsync(OPENCLAW_BIN, buildGatewayHealthArgs(), execOptions);
    const payload = parseJsonTail(stdout);
    healthOk = payload?.ok !== false;
  } catch (error) {
    healthOk = false;
    log('warn', 'Gateway health check failed during reconciliation', {
      runId: run.id,
      error: error.message,
    });
  }

  try {
    const { stdout } = await execFileAsync(OPENCLAW_BIN, buildGatewayStatusArgs(), execOptions);
    const payload = parseJsonTail(stdout);
    const sessions = Array.isArray(payload?.sessions?.recent)
      ? payload.sessions.recent
      : [];
    session = sessions
      .map(normalizeGatewaySessionCandidate)
      .find((candidate) => candidate?.key === targetKey) || null;
  } catch (error) {
    log('warn', 'Gateway status read failed during reconciliation', {
      runId: run.id,
      error: error.message,
    });
  }

  return {
    healthOk,
    session,
  };
}

function getLatestObservedMessageTimestamp(messages) {
  return messages.reduce((latest, message) => Math.max(latest, getMessageTimestamp(message)), 0);
}

