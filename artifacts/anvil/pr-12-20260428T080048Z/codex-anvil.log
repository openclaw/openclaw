 *
 * Agent chassis sends periodic health reports. Updates lastHeartbeat
 * on the chassis deployment document and stores the heartbeat data
 * for historical tracking.
 *
 * Body:
 * {
 *   tokenUsage: { inputTokens: number, outputTokens: number, estimatedCostUsd?: number }
 *   activeAgents: string[]         — names of currently active agents
 *   errors: Array<{ message, code?, timestamp, agentName? }>
 *   sessions: Array<{ id, agentName, channel, active, startedAt }>
 *   version?: string               — chassis software version
 *   runtimeVersion?: string        — normalized runtime/build version
 *   manifestVersion?: number       — desired-state manifest version currently applied
 *   capabilityHash?: string        — stable hash of the effective capability set
 *   queueDepth?: number            — current queue depth on the chassis
 *   latencyMs?: number             — measured control-plane latency
 *   metrics?: { memoryUsageMb?, cpuPercent?, uptimeSeconds? }
 * }
 *
 * Rate limiting: Consider limiting to 1 heartbeat per chassis per 30 seconds.
 */

import { NextRequest, NextResponse } from 'next/server';
