    61	          viewCount: FieldValue.increment(1),
    62	          lastViewedAt: FieldValue.serverTimestamp(),
    63	        })
    64	        .catch((err) => {
    65	          console.error(`[Wiki GET] view-tracking write failed for ${slug}:`, err);
    66	        });
    67	    }
    68	
    69	    return NextResponse.json({
    70	      entry: {
    71	        slug: entry.slug,
    72	        title: entry.title,
    73	        markdown: entry.markdown,
    74	        frontmatter: entry.frontmatter,
    75	        rarityRequired: entry.rarityRequired,
    76	        syncedAt: entry.syncedAt.toISOString(),
    77	        syncedVersion: entry.syncedVersion,
    78	      },
    79	    });
    80	  }

