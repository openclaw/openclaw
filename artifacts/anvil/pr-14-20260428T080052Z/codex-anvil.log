      HOME: home,
      BENCH_WIKI_INGEST_KEY: 'local-test-key',
      BENCH_WIKI_INGEST_URL: "'`http://127.0.0.1:${port}/ingest`,
      BENCH_WIKI_MIRROR_DEBOUNCE_MS: '"'10',
    },
    stdio: ['ignore', 'pipe', 'pipe'],
  });
  let stdout = '';
  let stderr = '';
  child.stdout.on('data', (chunk) => { stdout += chunk; });
  child.stderr.on('data', (chunk) => { stderr += chunk; });

  const { parsed } = await requestPromise;
  assert.equal(parsed.entries.length, 1);
  const entry = parsed.entries[0];
  assert.equal(entry.slug, 'alpha');
  assert.equal(entry.title, 'Alpha');
  assert.equal(entry.sourceInstanceId, 'test-shard');
  assert.equal(entry.sourcePath, 'test-shard/alpha.md');

  const statePath = path.join(home, '.openclaw', 'state', 'wiki-mirror.test-shard.json');
  for (let i = 0; i < 50; i += 1) {
    try {
      await fs.access(statePath);
      break;
    } catch {
      await new Promise((resolve) => setTimeout(resolve, 50));
    }
  }
  const state = JSON.parse(await fs.readFile(statePath, 'utf8'));
  assert.equal(typeof state.hashes.alpha, 'string');
  await assert.rejects(fs.access(path.join(home, '.openclaw', 'state', 'wiki-mirror.json')));
  assert.match(stdout, /\"instanceId\":\"test-shard\"/);
  assert.equal(stderr, '');
  console.log('cloud-mirror scoped smoke ok');
} finally {
  if (child && "'!child.killed) child.kill('"'SIGTERM');
  if (server) await new Promise((resolve) => server.close(resolve));
  await fs.rm(home, { recursive: true, force: true });
}
