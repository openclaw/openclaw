     1	/**
     2	 * GET /api/v1/wiki/[slug] — Fetch one approved wiki entry if the caller may read it.
     3	 *
     4	 * Returns 404 (not 403) for unauthorized or unapproved entries so rarity
     5	 * information is not leaked to callers below the required tier.
     6	 *
     7	 * Side-effect: on a successful read of an approved entry, kicks off a
     8	 * fire-and-forget Firestore update that increments `viewCount` and stamps
     9	 * `lastViewedAt`. The write is intentionally NOT awaited — view tracking
    10	 * must never slow the response. Super-admin (`auth.rank === 'orange'`)
    11	 * reads and reads by the entry's `approvedBy` author are skipped so the
    12	 * signal reflects member-tier + anonymous traffic, not authoring noise.
    13	 * 404 paths (missing entry, rank-gated, cross-tenant) never increment.
    14	 */
    15	
    16	import { NextResponse } from 'next/server';
    17	import { withAuth } from '@/lib/auth/route-auth';
    18	import { readWikiEntry } from '@/lib/relay/agent-wiki';
    19	import { rankAtLeast } from '@/lib/auth/authority';
    20	import { getAdminFirestore } from '@/lib/firebase-admin';
    21	import { FieldValue } from 'firebase-admin/firestore';
    22	
    23	export const runtime = 'nodejs';
    24	
    25	export const GET = withAuth(
    26	  { requiredRole: 'member', requireInstance: false, allowApiKeys: true },
    27	  async (_request, auth, context) => {
    28	    const { slug } = await context.params;
    29	    if (!slug) {
    30	      return NextResponse.json({ error: 'slug required' }, { status: 400 });
    31	    }
    32	
    33	    const entry = await readWikiEntry(slug);
    34	    if (!entry || entry.approvalStatus !== 'approved') {
    35	      return NextResponse.json({ error: 'Not found' }, { status: 404 });
    36	    }
    37	    if (!rankAtLeast(auth.rank, entry.rarityRequired)) {
    38	      return NextResponse.json({ error: 'Not found' }, { status: 404 });
    39	    }
    40	    // Tenant scoping: super_admin bypasses; everyone else sees only global
    41	    // (null-instance) entries plus their own tenant's. Return 404 (not 403)
    42	    // so cross-tenant slugs don't leak existence.
    43	    if (
    44	      auth.role !== 'super_admin' &&
    45	      entry.sourceInstanceId !== null &&
    46	      entry.sourceInstanceId !== auth.instanceId
    47	    ) {
    48	      return NextResponse.json({ error: 'Not found' }, { status: 404 });
    49	    }
    50	
    51	    // Fire-and-forget view tracking. Skip super_admin (orange) and the entry's
    52	    // own approver so the count reflects member-tier consumption, not authoring
    53	    // noise. Failures log but never crash or slow the request path.
    54	    const isSuperAdminRead = auth.rank === 'orange';
    55	    const isApproverRead =
    56	      entry.approvedBy !== null && entry.approvedBy === auth.userId;
    57	    if (!isSuperAdminRead && !isApproverRead) {
    58	      void getAdminFirestore()
    59	        .doc(`wikiEntries/${slug}`)
