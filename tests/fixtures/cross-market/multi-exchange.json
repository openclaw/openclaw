    "setup": {
      "exchangeId": "binance-testnet",
      "exchangeConfig": {
        "exchange": "binance",
        "apiKey": "test-api-key",
        "secret": "test-secret",
        "testnet": true
      },
      "riskConfig": {
        "enabled": true,
        "maxAutoTradeUsd": 100,
        "confirmThresholdUsd": 500,
        "maxDailyLossUsd": 1000,
        "maxPositionPct": 25,
        "maxLeverage": 3
      },
      "mockTicker": {
        "symbol": "BTC/USDT",
        "last": 67000,
        "bid": 66990,
        "ask": 67010
      },
      "currentTime": "2026-03-03T10:00:00Z"
    },
    "input": {
      "tool": "fin_place_order",
      "params": {
        "symbol": "BTC/USDT",
        "side": "buy",
        "type": "limit",
        "amount": 0.001,
        "price": 67000
      }
