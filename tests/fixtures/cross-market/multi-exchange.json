[
  {
    "id": "cross-dual-exchange",
    "category": "cross-market",
    "name": "Dual exchange specific selection",
    "description": "Two exchanges configured (binance-testnet + okx-testnet), explicitly specifying okx-testnet for the order",
    "market": "crypto",
    "setup": {
      "exchangeId": "okx-testnet",
      "exchangeConfig": {
        "exchange": "okx",
        "apiKey": "test-api-key-okx",
        "secret": "test-secret-okx",
        "testnet": true,
        "passphrase": "test-passphrase"
      },
      "riskConfig": {
        "enabled": true,
        "maxAutoTradeUsd": 100,
        "confirmThresholdUsd": 500,
        "maxDailyLossUsd": 1000,
        "maxPositionPct": 25,
        "maxLeverage": 3
      },
      "mockTicker": {
        "symbol": "ETH/USDT",
        "last": 3500,
        "bid": 3499,
        "ask": 3501
      },
      "currentTime": "2026-03-03T10:00:00Z"
    },
    "input": {
      "tool": "fin_place_order",
      "params": {
        "symbol": "ETH/USDT",
        "side": "buy",
        "type": "limit",
        "amount": 0.02,
        "price": 3500,
        "exchangeId": "okx-testnet"
      }
    },
    "expected": {
      "success": true,
      "blocked": false,
      "requiresConfirmation": false,
      "estimatedValueUsdRange": [65, 75],
      "customAssertions": [
        {
          "path": "order.exchangeId",
          "operator": "eq",
          "value": "okx-testnet"
        }
      ]
    },
    "tags": ["cross-market", "multi-exchange"]
  },
  {
    "id": "cross-default-fallback",
