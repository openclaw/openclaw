[
  {
    "id": "cn-market-buy-to-limit",
    "category": "cn-a-share",
    "name": "Market buy converts to aggressive limit",
    "description": "Market buy 100 shares of 000001.SZ — A-share does not support true market orders, converts to aggressive limit at price * 1.005",
    "market": "cn-a-share",
    "setup": {
      "exchangeId": "openctp-sim",
      "exchangeConfig": {
        "exchange": "openctp",
        "apiKey": "test-user",
        "secret": "test-pass",
        "testnet": true,
        "ctpBrokerId": "9999",
        "ctpFrontAddr": "tcp://180.168.146.187:10130"
      },
      "riskConfig": {
        "enabled": true,
        "maxAutoTradeUsd": 100,
        "confirmThresholdUsd": 500,
        "maxDailyLossUsd": 1000,
        "maxPositionPct": 25,
        "maxLeverage": 3
      },
      "mockTicker": {
        "symbol": "000001.SZ",
        "last": 12,
        "bid": 11.99,
        "ask": 12.01
      },
      "currentTime": "2026-03-03T02:00:00Z"
    },
    "input": {
      "tool": "fin_place_order",
      "params": {
        "symbol": "000001.SZ",
        "side": "buy",
        "type": "market",
        "amount": 100,
        "exchangeId": "openctp-sim"
      }
    },
    "expected": {
      "success": true,
      "blocked": false,
      "estimatedValueUsdRange": [155, 175],
      "customAssertions": [
        {
          "path": "order.type",
          "operator": "eq",
          "value": "limit"
        },
        {
          "path": "order.price",
          "operator": "gte",
          "value": 12.06
        }
      ]
    },
    "tags": ["market-order", "conversion"],
    "notes": "Market orders in A-share are converted to aggressive limit orders: buy at ask * 1.005"
  },
