{
  "id": "grayswan-cygnal-guardrail",
  "name": "Gray Swan Cygnal Guardrail",
  "description": "Evaluates full before_tool_call model context with Gray Swan Cygnal /monitor.",
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "sensitive": true,
      "help": "Gray Swan Cygnal API key. Uses GRAYSWAN_API_KEY when omitted."
    },
    "apiBase": {
      "label": "API Base URL",
      "advanced": true,
      "help": "Override Gray Swan API base URL."
    },
    "policyId": {
      "label": "Policy ID",
      "help": "Optional Gray Swan policy id."
    },
    "reasoningMode": {
      "label": "Reasoning Mode",
      "advanced": true,
      "help": "Optional reasoning mode forwarded to /monitor."
    },
    "violationThreshold": {
      "label": "Violation Threshold",
      "help": "Default block threshold in [0,1]."
    },
    "timeoutMs": {
      "label": "Timeout (ms)",
      "advanced": true,
      "help": "Cygnal request timeout in milliseconds."
    },
    "failOpen": {
      "label": "Fail Open",
      "help": "Allow tool execution when Cygnal request fails."
    },
    "cygnalBypass": {
      "label": "Cygnal Bypass",
      "help": "Sends metadata.cygnal_bypass=true for monitor-only bypass mode."
    },
    "beforeToolCall.enabled": {
      "label": "Enable Before Tool Call",
      "help": "Enable Cygnal checks at before_tool_call."
    },
    "beforeToolCall.mode": {
      "label": "Before Tool Call Mode",
      "help": "Use block to block tool execution, or monitor for observe-only."
    },
    "beforeToolCall.violationThreshold": {
      "label": "Before Tool Call Threshold",
      "help": "Stage-specific threshold in [0,1]."
    },
    "beforeToolCall.blockOnMutation": {
      "label": "Block on Mutation",
      "help": "Block when Cygnal reports mutation=true."
    },
    "beforeToolCall.blockOnIpi": {
      "label": "Block on IPI",
      "help": "Block when Cygnal reports ipi=true."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": { "type": "string" },
      "apiBase": { "type": "string" },
      "policyId": { "type": "string" },
      "categories": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      },
      "reasoningMode": {
        "type": "string",
        "enum": ["off", "hybrid", "thinking"]
      },
      "violationThreshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1000
      },
      "failOpen": { "type": "boolean" },
      "cygnalBypass": { "type": "boolean" },
      "beforeToolCall": { "$ref": "#/$defs/stageConfig" }
    },
    "$defs": {
      "stageConfig": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "mode": {
            "type": "string",
            "enum": ["block", "monitor"]
          },
          "violationThreshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "blockOnMutation": { "type": "boolean" },
          "blockOnIpi": { "type": "boolean" }
        }
      }
    }
  }
}
