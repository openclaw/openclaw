# Qdrant sidecar memory integration for OpenClaw
# Copy to: qdrant-setup/qdrant-memory.env

# Enable/disable sidecar
OPENCLAW_QDRANT_MEMORY_ENABLED=false

# Qdrant settings
OPENCLAW_QDRANT_URL=http://127.0.0.1:6333
OPENCLAW_QDRANT_API_KEY=
OPENCLAW_QDRANT_COLLECTION=openclaw_memory

# Embedding API (OpenAI-compatible endpoint)
OPENCLAW_QDRANT_EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
OPENCLAW_QDRANT_EMBEDDING_API_KEY=
OPENCLAW_QDRANT_EMBEDDING_MODEL=text-embedding-3-small
OPENCLAW_QDRANT_EMBEDDING_DIM=1536

# Index settings
OPENCLAW_QDRANT_CHUNK_CHARS=1200
OPENCLAW_QDRANT_BATCH_SIZE=32
OPENCLAW_QDRANT_INDEX_INTERVAL_SEC=21600
OPENCLAW_QDRANT_QUERY_LIMIT=5

# Codebase indexing (multi-project)
OPENCLAW_QDRANT_CODE_INDEX_ENABLED=false
OPENCLAW_QDRANT_CODE_PROJECTS_FILE=./qdrant-setup/projects.json
# Optional inline list instead of projects file:
# OPENCLAW_QDRANT_CODE_PROJECT_PATHS=/root/clawd/app-builder,/root/clawd/CBT-App
OPENCLAW_QDRANT_CODE_EXTENSIONS=.ts,.tsx,.js,.jsx,.mjs,.cjs,.py,.go,.rs,.java,.kt,.swift,.dart,.sql,.sh,.yaml,.yml,.json,.md
OPENCLAW_QDRANT_CODE_IGNORE_DIRS=node_modules,.git,dist,build,.next,.nuxt,.pnpm-store,coverage,.turbo,.cache,vendor,tmp
OPENCLAW_QDRANT_CODE_MAX_FILE_BYTES=262144
OPENCLAW_QDRANT_CODE_MAX_FILES=5000

# Retrieval policy (reversible)
OPENCLAW_QDRANT_VECTOR_QUERY_FIRST=false
OPENCLAW_QDRANT_NATIVE_FALLBACK=true
OPENCLAW_QDRANT_NATIVE_FALLBACK_MAX_HITS=8
OPENCLAW_QDRANT_ACTIVE_PROJECT=
