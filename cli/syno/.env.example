# Synology DSM connection settings
# Copy this file to .env and fill in your values

# DSM host address
SYNO_HOST=192.168.1.1
# DSM port (default: 5000 for HTTP, 5001 for HTTPS)
SYNO_PORT=5000
# Use HTTPS (true/false)
SYNO_HTTPS=false

# Authentication credentials (used for auto-login)
SYNO_USERNAME=your_username
SYNO_PASSWORD=your_password
