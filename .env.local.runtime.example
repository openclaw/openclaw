# Local runtime override example
#
# Copy to `projects/openclaw/.env.local.runtime` only when you need
# machine-specific local runtime overrides.
#
# Do not put long-lived secrets here. Canonical secret location stays:
#   ~/.openclaw/.env
#
# This file is for local path and container-runtime overrides only.

# -----------------------------------------------------------------------------
# Gateway runtime defaults
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_TZ=America/New_York

# -----------------------------------------------------------------------------
# Local host path contract
# -----------------------------------------------------------------------------
OPENCLAW_CONFIG_DIR=/Users/franco/.openclaw
OPENCLAW_SHARED_WORKSPACE_HOST=/Users/franco/.openclaw/workspace
OPENCLAW_AGENT_HOME_TONY_HOST=/Users/franco/.openclaw/workspace-tony
OPENCLAW_AGENT_HOME_BOBBY_DIGITAL_HOST=/Users/franco/.openclaw/workspace-bobby-digital
OPENCLAW_AGENT_HOME_ANGELA_HOST=/Users/franco/.openclaw/workspace-angela
OPENCLAW_AGENT_HOME_REVEREND_RUN_HOST=/Users/franco/.openclaw/workspace-reverend-run

# -----------------------------------------------------------------------------
# Optional runtime toggles
# -----------------------------------------------------------------------------
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
