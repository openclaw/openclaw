{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ceviz.local/contracts/solidworks-bridge-result-envelope-v1.json",
  "title": "SolidWorksBridgeResultEnvelopeV1",
  "type": "object",
  "required": [
    "schemaVersion",
    "requestId",
    "kind",
    "status",
    "startedAtUtc",
    "finishedAtUtc",
    "host",
    "handler",
    "output",
    "error"
  ],
  "properties": {
    "schemaVersion": {
      "const": "solidworks-bridge-result-envelope-v1"
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "ping",
        "capabilities",
        "get-active-document",
        "get-document-metadata",
        "get-selection-context",
        "get-assembly-summary",
        "extract-poc-context"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["succeeded", "failed"]
    },
    "startedAtUtc": {
      "type": "string"
    },
    "finishedAtUtc": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "handler": {
      "type": "string"
    },
    "output": {
      "type": ["object", "null"]
    },
    "error": {
      "type": ["object", "null"]
    }
  },
  "additionalProperties": false
}
