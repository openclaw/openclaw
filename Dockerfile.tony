ARG OPENCLAW_TONY_BASE_IMAGE=openclaw:local
FROM ${OPENCLAW_TONY_BASE_IMAGE}
USER root

# ─── Core system tools + Docker CLI ──────────────────────────────────────────
ARG OPENCLAW_DOCKER_GPG_FINGERPRINT="9DC858229FC7DD38854AE2D88D81803C0EBFCD88"
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    openssh-client \
    ca-certificates \
    gnupg \
  && install -m 0755 -d /etc/apt/keyrings \
  && curl -fsSL https://download.docker.com/linux/debian/gpg -o /tmp/docker.gpg.asc \
  && expected_fingerprint="$(printf '%s' "$OPENCLAW_DOCKER_GPG_FINGERPRINT" | tr '[:lower:]' '[:upper:]' | tr -d '[:space:]')" \
  && actual_fingerprint="$(gpg --batch --show-keys --with-colons /tmp/docker.gpg.asc | awk -F: '$1 == "fpr" { print toupper($10); exit }')" \
  && if [ -z "$actual_fingerprint" ] || [ "$actual_fingerprint" != "$expected_fingerprint" ]; then \
       echo "ERROR: Docker apt key fingerprint mismatch (expected $expected_fingerprint, got ${actual_fingerprint:-<empty>})" >&2; \
       exit 1; \
     fi \
  && gpg --dearmor -o /etc/apt/keyrings/docker.gpg /tmp/docker.gpg.asc \
  && rm -f /tmp/docker.gpg.asc \
  && chmod a+r /etc/apt/keyrings/docker.gpg \
  && printf 'deb [arch=%s signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian bookworm stable\n' \
       "$(dpkg --print-architecture)" > /etc/apt/sources.list.d/docker.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends docker-ce-cli \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

# ─── Ruby, Python3, and gateway utilities ────────────────────────────────────
# Ruby   — Deb kanban scripts (deb.rb, sprint-sync.sh etc.)
# Python3 / pip — slither, utility scripts (Streetlife, Masta Killa)
# jq     — JSON parsing in shell scripts
# socat  — port forwarding / debug tunnels
# make   — Makefile targets (make deb-status, make tests, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ruby \
    ruby-dev \
    python3 \
    python3-pip \
    jq \
    socat \
    make \
    build-essential \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

# ─── Python packages (persistent across container restarts) ──────────────────
# requests — memory-autosync.py, API calls
# openai   — LLM extraction in memory pipeline
ARG OPENCLAW_TONY_PIP_PACKAGES="requests openai"
RUN pip3 install --break-system-packages ${OPENCLAW_TONY_PIP_PACKAGES}

# ─── Homebrew (Linuxbrew — skill installer, package management) ──────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    procps \
    file \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*
ENV NONINTERACTIVE=1
RUN /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" \
  || true
ENV PATH="/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:${PATH}"
ENV HOMEBREW_NO_AUTO_UPDATE=1

# ─── acpx CLI (ACP runtime bridge) ───────────────────────────────────────────
ARG OPENCLAW_ACPX_VERSION=0.1.15
ARG OPENCLAW_TONY_NPM_PACKAGES="vercel"
RUN npm install -g "acpx@${OPENCLAW_ACPX_VERSION}" ${OPENCLAW_TONY_NPM_PACKAGES} \
  && acpx --version
# ─── kubectl ─────────────────────────────────────────────────────────────────
ARG OPENCLAW_KUBECTL_VERSION=1.30.0
RUN set -eux; \
    ARCH="$(dpkg --print-architecture)"; \
    curl -LO "https://dl.k8s.io/release/v${OPENCLAW_KUBECTL_VERSION}/bin/linux/${ARCH}/kubectl" \
  && install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl \
  && rm kubectl

# ─── kustomize ───────────────────────────────────────────────────────────────
ARG OPENCLAW_KUSTOMIZE_VERSION=5.4.1
RUN set -eux; \
    ARCH="$(dpkg --print-architecture)"; \
    curl -Lo kustomize.tar.gz "https://github.com/kubernetes-sigs/kustomize/releases/download/kustomize%2Fv${OPENCLAW_KUSTOMIZE_VERSION}/kustomize_v${OPENCLAW_KUSTOMIZE_VERSION}_linux_${ARCH}.tar.gz" \
  && tar xzf kustomize.tar.gz \
  && install kustomize /usr/local/bin/kustomize \
  && rm kustomize kustomize.tar.gz

# =============================================================================
# TOOL VERIFICATION MAP (for maintainers)
# =============================================================================
# Run inside container to confirm gateway tools are present:
#
#   docker run --rm openclaw-tony:local \
#     sh -c 'for t in docker kubectl kustomize ruby python3 pip3 jq socat make acpx; do \
#       command -v $t && echo "✅ $t" || echo "❌ $t MISSING"; done'
#
# Expected output: 10x ✅
# =============================================================================
