# OpenClaw Gateway Environment
# Copy to .env and fill in values

# ── Core ──
ENVIRONMENT=dev
GATEWAY_PORT=18789
GATEWAY_HOST=0.0.0.0

# ── Telegram ──
TELEGRAM_BOT_TOKEN=replace
TELEGRAM_ALLOWED_CHAT_IDS=123,456
TELEGRAM_WEBHOOK_SECRET=replace

# ── Telegram Channel Bindings (Full Digital) ──
TELEGRAM_FD_OPS_CHAT_ID=replace
TELEGRAM_FD_SALES_CHAT_ID=replace
TELEGRAM_FD_CONTENT_CHAT_ID=replace
TELEGRAM_FD_FINANCE_CHAT_ID=replace

# ── Telegram Channel Bindings (CUTMV) ──
TELEGRAM_CUTMV_OPS_CHAT_ID=replace
TELEGRAM_CUTMV_SUPPORT_CHAT_ID=replace
TELEGRAM_CUTMV_GROWTH_CHAT_ID=replace

# ── Discord (optional) ──
DISCORD_BOT_TOKEN=
DISCORD_GUILD_IDS=

# ── Slack (optional) ──
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ── Ollama (M1 primary) ──
OLLAMA_PRIMARY_HOST=http://10.0.0.145:11434
OLLAMA_FALLBACK_HOST=http://10.0.0.10:11434

# ── Claude API (cloud fallback) ──
ANTHROPIC_API_KEY=
