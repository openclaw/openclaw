# syntax=docker/dockerfile:1.7

ARG OPENCLAW_DEBIAN_SLIM_IMAGE="debian:12-slim@sha256:f06537653ac770703bc45b4b113475bd402f451e85223f0f2837acbf89ab020a"
ARG OPENCLAW_DEBIAN_SLIM_DIGEST="sha256:f06537653ac770703bc45b4b113475bd402f451e85223f0f2837acbf89ab020a"
ARG WHISPER_CPP_VERSION="v1.8.3"
ARG WHISPER_MODEL_URL="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-tiny.bin"
ARG FFMPEG_URL="https://johnvansickle.com/ffmpeg/releases/ffmpeg-release-amd64-static.tar.xz"
ARG MC_URL="https://dl.min.io/client/mc/release/linux-amd64/mc"

FROM ${OPENCLAW_DEBIAN_SLIM_IMAGE}
ARG OPENCLAW_DEBIAN_SLIM_DIGEST
ARG WHISPER_CPP_VERSION
ARG WHISPER_MODEL_URL
ARG FFMPEG_URL
ARG MC_URL

LABEL org.opencontainers.image.source="https://github.com/mctlhq/openclaw" \
  org.opencontainers.image.title="OpenClaw Whisper Cache Builder" \
  org.opencontainers.image.description="Prebuilt ffmpeg + whisper-cli + ggml-tiny.bin + mc for OpenClaw init fallback" \
  org.opencontainers.image.base.name="docker.io/library/debian:12-slim" \
  org.opencontainers.image.base.digest="${OPENCLAW_DEBIAN_SLIM_DIGEST}"

ENV WHISPER_ASSETS_DIR=/opt/whisper-assets

RUN set -eux; \
    apt-get update; \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ca-certificates \
      wget \
      xz-utils \
      build-essential \
      cmake \
      git; \
    mkdir -p "${WHISPER_ASSETS_DIR}"; \
    wget -q "${MC_URL}" -O /usr/local/bin/mc; \
    chmod +x /usr/local/bin/mc; \
    wget -q "${FFMPEG_URL}" -O /tmp/ffmpeg.tar.xz; \
    tar -xJf /tmp/ffmpeg.tar.xz -C "${WHISPER_ASSETS_DIR}" --strip-components=1 --wildcards "*/ffmpeg"; \
    chmod +x "${WHISPER_ASSETS_DIR}/ffmpeg"; \
    rm -f /tmp/ffmpeg.tar.xz; \
    wget -q "${WHISPER_MODEL_URL}" -O "${WHISPER_ASSETS_DIR}/ggml-tiny.bin"; \
    git clone --depth 1 --branch "${WHISPER_CPP_VERSION}" https://github.com/ggml-org/whisper.cpp.git /tmp/whispersrc; \
    cmake -B /tmp/whispersrc/build -S /tmp/whispersrc \
      -DCMAKE_BUILD_TYPE=Release \
      -DWHISPER_BUILD_EXAMPLES=ON \
      -DWHISPER_BUILD_TESTS=OFF \
      -DGGML_NATIVE=OFF \
      -DGGML_AVX512=OFF \
      -DGGML_AVX512_VBMI=OFF \
      -DGGML_AVX512_VNNI=OFF \
      -DGGML_AVX512_BF16=OFF; \
    make -C /tmp/whispersrc/build whisper-cli -j"$(nproc)"; \
    WHISPER_SO="$(find /tmp/whispersrc/build -type f -name 'libwhisper.so*' | sort | head -n1)"; \
    GGML_SO="$(find /tmp/whispersrc/build -type f -name 'libggml.so*' | sort | head -n1)"; \
    test -n "${WHISPER_SO}"; \
    test -n "${GGML_SO}"; \
    cp /tmp/whispersrc/build/bin/whisper-cli "${WHISPER_ASSETS_DIR}/whisper-cli"; \
    cp "${WHISPER_SO}" "${WHISPER_ASSETS_DIR}/libwhisper.so.1"; \
    cp "${GGML_SO}" "${WHISPER_ASSETS_DIR}/libggml.so.0"; \
    chmod +x "${WHISPER_ASSETS_DIR}/whisper-cli"; \
    printf '%s\n' \
      '#!/bin/sh' \
      'export LD_LIBRARY_PATH=/opt/whisper-assets${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}' \
      'TMP_WAV=$(mktemp /tmp/whisper_XXXXXX.wav)' \
      '/opt/whisper-assets/ffmpeg -i "$1" -ar 16000 -ac 1 -f wav "$TMP_WAV" -y 2>/dev/null' \
      '/opt/whisper-assets/whisper-cli -m /opt/whisper-assets/ggml-tiny.bin -f "$TMP_WAV" --language auto --no-timestamps 2>/dev/null' \
      'EC=$?' \
      'rm -f "$TMP_WAV"' \
      'exit $EC' > "${WHISPER_ASSETS_DIR}/run-whisper.sh"; \
    chmod +x "${WHISPER_ASSETS_DIR}/run-whisper.sh"; \
    rm -rf /tmp/whispersrc; \
    apt-get clean; \
    rm -rf /var/lib/apt/lists/*
