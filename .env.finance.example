# OpenFinclaw finance env template
# Copy to .env.finance and adjust for your deployment.

# ── Findoo DataHub (unified financial data source) ───────────────
# Full mode: set DATAHUB_API_KEY for all 172 endpoints (Tushare/Polygon/CCXT/DefiLlama/CoinGecko/WorldBank)
# Free mode: leave empty — uses CCXT/CoinGecko/DefiLlama/Yahoo Finance (no API key needed)
# DATAHUB_API_URL=http://43.134.61.136:8088
# DATAHUB_API_KEY=your_datahub_api_key

# ── Tushare Proxy (legacy fallback, used when DataHub key is absent) ──
# TUSHARE_PROXY_URL=http://43.134.187.48:7088
# TUSHARE_PROXY_API_KEY=your_tushare_api_key

# Expert SDK
FIN_EXPERT_SDK_MODE=stub
# FIN_EXPERT_SDK_API_KEY=
# FIN_EXPERT_SDK_ENDPOINT=https://expert.example
FIN_EXPERT_SDK_TIMEOUT_MS=15000

# Info Feed (modes: stub | live | grok)
FIN_INFO_FEED_MODE=stub
# FIN_INFO_FEED_API_KEY=
# FIN_INFO_FEED_ENDPOINT=https://feed.example
FIN_INFO_FEED_TIMEOUT_MS=15000

# ── Info Feed: Grok KOL Monitoring ───────────────────────────────
# Set FIN_INFO_FEED_MODE=grok to enable KOL monitoring via xAI x_search
# xAI API Key — get yours at https://console.x.ai → API Keys
# XAI_API_KEY=xai-your_api_key_here
# OPENFINCLAW_XAI_API_KEY=xai-your_api_key_here
# Default KOL handles to monitor (comma-separated, no @ prefix)
# OPENFINCLAW_FIN_INFO_KOL_HANDLES=elonmusk,CryptoHayes,inversebrah,zaborowski,DeItaone
# Grok model (default: grok-4-1-fast)
# OPENFINCLAW_FIN_INFO_GROK_MODEL=grok-4-1-fast
# Scan interval in ms (default: 900000 = 15 min)
# OPENFINCLAW_FIN_INFO_SCAN_INTERVAL_MS=900000
# Score threshold for urgent push (default: 9)
# OPENFINCLAW_FIN_INFO_URGENT_THRESHOLD=9
# Focus topic for analysis (optional)
# OPENFINCLAW_FIN_INFO_SCAN_TOPIC=crypto and macro markets

# Monitoring
FIN_MONITORING_AUTO_EVALUATE=1
FIN_MONITORING_RUN_ON_START=1
FIN_MONITORING_POLL_INTERVAL_MS=300000

# ── Binance Testnet (trading E2E tests) ──────────────────────────
# Get keys from https://testnet.binance.vision/
# BINANCE_TESTNET_API_KEY=your_testnet_api_key
# BINANCE_TESTNET_SECRET=your_testnet_secret_key
