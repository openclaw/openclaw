{
  "package": {
    "productName": "OpenClaw",
    "version": "1.0.0"
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "all": false,
        "sidecar": true,
        "scope": [
          {
            "name": "binaries/openclaw",
            "sidecar": true,
            "args": ["gateway", "run"]
          }
        ]
      },
      "notification": {
        "all": true
      },
      "process": {
        "relaunch": true,
        "exit": true
      }
    },
    "updater": {
      "active": false,
      "endpoints": [
        "https://raw.githubusercontent.com/openclaw/openclaw/main/apps/windows/update.json"
      ],
      "dialog": true,
      "pubkey": "REPLACE_WITH_ACTUAL_PUBKEY_IF_AVAILABLE"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.openclaw.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": ["binaries/openclaw"],
      "windows": {
        "wix": {
          "language": "en-US",
          "template": null
        },
        "nsis": {
          "installMode": "perMachine"
        }
      }
    },
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob:;"
    },
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  }
}
