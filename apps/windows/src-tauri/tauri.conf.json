{
  "package": {
    "productName": "OpenClaw",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "all": false,
        "sidecar": true,
        "scope": [
          {
            "name": "binaries/openclaw",
            "sidecar": true,
            "args": ["gateway", "run"]
          }
        ]
      },
      "dialog": {
        "all": true
      },
      "notification": {
        "all": true
      },
      "process": {
        "relaunch": true,
        "exit": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.openclaw.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": ["binaries/openclaw"],
      "windows": {
        "wix": {
          "language": "en-US",
          "template": null
        },
        "nsis": {
          "installMode": "perMachine"
        }
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:18789; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw — Aliyev Ecosystem",
        "url": "http://localhost:18789",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  }
}
