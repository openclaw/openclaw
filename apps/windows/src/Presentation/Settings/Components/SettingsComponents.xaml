<UserControl
    x:Class="OpenClawWindows.Presentation.Settings.Components.SettingsToggleRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Mirrors SettingsToggleRow.swift: checkbox with title (body) + optional subtitle (footnote, tertiary).
         VStack(alignment: .leading, spacing: 6) -->
    <StackPanel Spacing="6">

        <CheckBox
            x:Name="ToggleCheck"
            Content="{x:Bind Title, Mode=OneWay}"
            Checked="OnCheckedChanged"
            Unchecked="OnCheckedChanged" />

        <TextBlock
            x:Name="SubtitleText"
            FontSize="12"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            TextWrapping="Wrap"
            Visibility="Collapsed" />

    </StackPanel>

</UserControl>
