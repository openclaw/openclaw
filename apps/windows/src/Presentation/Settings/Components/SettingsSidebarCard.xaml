<UserControl
    x:Class="OpenClawWindows.Presentation.Settings.Components.SettingsSidebarCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    MinWidth="220"
    MaxWidth="280"
    HorizontalAlignment="Left"
    VerticalAlignment="Stretch">

    <!-- Mirrors settingsSidebarCardLayout() Swift extension: cornerRadius=12, windowBackground fill,
         minWidth=220/idealWidth=240/maxWidth=280, content aligned top-leading. -->
    <Border
        CornerRadius="12"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ContentPresenter
            Content="{x:Bind CardContent, Mode=OneWay}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top" />
    </Border>

</UserControl>
