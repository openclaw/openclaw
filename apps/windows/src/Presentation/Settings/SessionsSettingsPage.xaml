<Page
    x:Class="OpenClawWindows.Presentation.Settings.SessionsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Mirrors SessionsSettings.swift: session list with label, key, age, context usage. -->
    <Grid Padding="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Spacing="2">
                <TextBlock Text="Sessions" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock
                    Text="Conversation buckets the CLI reuses for context and rate limits."
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <Button
                Content="Refresh"
                Command="{Binding RefreshCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top" />
        </Grid>

        <ListView
            Grid.Row="1"
            ItemsSource="{Binding Sessions}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Padding="0,6,0,6" Spacing="3">

                        <!-- Label + age — mirrors HStack(row.label, Spacer, row.ageText) -->
                        <Grid>
                            <TextBlock
                                Text="{Binding Label}"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{Binding AgeText}"
                                FontSize="11"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>

                        <!-- Session key (monospace) -->
                        <TextBlock
                            Text="{Binding Key}"
                            FontFamily="Cascadia Mono, Consolas, Courier New"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- Context usage — mirrors row.tokens.contextSummaryShort -->
                        <TextBlock
                            Text="{Binding ContextSummaryShort}"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
