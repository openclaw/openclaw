<UserControl
    x:Class="OpenClawWindows.Presentation.Tray.NodesMenuSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawWindows.Presentation.Tray"
    xmlns:comp="using:OpenClawWindows.Presentation.Tray.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Mirrors injectNodes(into:): separator + node rows.
         Entire section hidden when not connected. -->
    <StackPanel
        Visibility="{x:Bind IsConnected, Mode=OneWay,
                     Converter={StaticResource BoolToVisibilityConverter}}">

        <!-- Top separator — mirrors NSMenuItem.separator() injected before nodes -->
        <Rectangle
            Height="1"
            HorizontalAlignment="Stretch"
            Margin="0,4,0,4"
            Opacity="0.15">
            <Rectangle.Fill>
                <SolidColorBrush Color="Black" />
            </Rectangle.Fill>
        </Rectangle>

        <!-- Node rows: one item per NodesSectionRowVM dispatched by template selector -->
        <ItemsControl ItemsSource="{x:Bind NodeRows, Mode=OneWay}">
            <ItemsControl.ItemTemplateSelector>
                <local:NodesSectionTemplateSelector>

                    <!-- Placeholder: "Loading devices…" / "No devices yet" -->
                    <local:NodesSectionTemplateSelector.PlaceholderTemplate>
                        <DataTemplate x:DataType="local:NodesPlaceholderVM">
                            <TextBlock
                                Text="{x:Bind Text}"
                                FontSize="13"
                                Margin="18,8,12,8"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </DataTemplate>
                    </local:NodesSectionTemplateSelector.PlaceholderTemplate>

                    <!-- Node row: MenuHighlightedHostView wrapping NodeMenuRowView.
                         Highlight propagated via ElementName binding (no code-behind wiring). -->
                    <local:NodesSectionTemplateSelector.NodeTemplate>
                        <DataTemplate x:DataType="local:NodesNodeVM">
                            <comp:MenuHighlightedHostView x:Name="HighlightHost">
                                <comp:MenuHighlightedHostView.HostedContent>
                                    <comp:NodeMenuRowView
                                        Node="{x:Bind Node}"
                                        IsHighlighted="{Binding IsHighlighted,
                                                        ElementName=HighlightHost,
                                                        Mode=OneWay}" />
                                </comp:MenuHighlightedHostView.HostedContent>
                            </comp:MenuHighlightedHostView>
                        </DataTemplate>
                    </local:NodesSectionTemplateSelector.NodeTemplate>

                    <!-- Overflow: "More Devices…" — mirrors entries.count > MaxVisibleNodes -->
                    <local:NodesSectionTemplateSelector.OverflowTemplate>
                        <DataTemplate x:DataType="local:NodesOverflowVM">
                            <TextBlock
                                Text="{x:Bind Text}"
                                FontSize="13"
                                Margin="18,8,12,8"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </DataTemplate>
                    </local:NodesSectionTemplateSelector.OverflowTemplate>

                </local:NodesSectionTemplateSelector>
            </ItemsControl.ItemTemplateSelector>
        </ItemsControl>

    </StackPanel>

</UserControl>
