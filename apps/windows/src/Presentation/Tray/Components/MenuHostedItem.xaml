<UserControl
    x:Class="OpenClawWindows.Presentation.Tray.Components.MenuHostedItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Mirrors MenuHostedItem.swift (NSViewRepresentable):
         hosts arbitrary content inside a tray menu item slot with an explicit width.
         Height is auto-sized by WinUI3 layout (mirrors NSHostingView.fittingSize.height). -->
    <ContentPresenter x:Name="HostedPresenter" />

</UserControl>
