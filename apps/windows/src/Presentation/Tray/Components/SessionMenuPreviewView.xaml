<UserControl
    x:Class="OpenClawWindows.Presentation.Tray.Components.SessionMenuPreviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawWindows.Presentation.Tray.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Mirrors SessionMenuPreviewView.swift:
         VStack(spacing:8) { title row, status-driven content }
         padding: vertical 6, leading 16, trailing 11 -->
    <StackPanel Spacing="8" Padding="16,6,11,6">

        <!-- Title row — mirrors Text(title).semibold + Spacer -->
        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                   FontSize="11" FontWeight="SemiBold"
                   Foreground="{x:Bind TitleForeground, Mode=OneWay}" />

        <!-- Placeholder: Loading / Empty / Error (and Ready with 0 items) -->
        <TextBlock Text="{x:Bind PlaceholderText, Mode=OneWay}"
                   FontSize="11"
                   Foreground="{x:Bind ContentForeground, Mode=OneWay}"
                   Visibility="{x:Bind IsNotReady, Mode=OneWay,
                                Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Ready with items: one row per SessionPreviewItem -->
        <ItemsControl ItemsSource="{x:Bind PreviewRows, Mode=OneWay}"
                      Visibility="{x:Bind IsReady, Mode=OneWay,
                                   Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="6" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:SessionPreviewRowVM">
                    <!-- Mirrors previewRow(_:) — HStack { roleLabel(width:50) + text(lineLimit:maxLines) } -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{x:Bind RoleLabel}"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Width="50"
                                   Foreground="{x:Bind RoleColor}"
                                   VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ItemText}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   MaxLines="{x:Bind MaxLines}"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{x:Bind TextColor}"
                                   VerticalAlignment="Top" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</UserControl>
