<UserControl
    x:Class="OpenClawWindows.Presentation.Tray.Components.NodeMenuRowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Mirrors NodeMenuRowView.swift:
         HStack(spacing:10) { icon(22×22) | VStack(spacing:2) { headline HStack | detail HStack } }
         padding: vertical 8, leading 18, trailing 12 -->
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <!-- leading icon: 22px fixed (mirrors .frame(width:22, height:22)) -->
            <ColumnDefinition Width="22" />
            <!-- gap between icon and content -->
            <ColumnDefinition Width="10" />
            <!-- content fills remaining space -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Leading icon — FontIcon or Android placeholder -->
        <FontIcon
            x:Name="LeadingIcon"
            Grid.Column="0"
            FontSize="18"
            Width="22"
            Height="22"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />

        <!-- VStack(spacing:2): headline + detail -->
        <StackPanel Grid.Column="2" Spacing="2">

            <!-- Headline HStack: name [spacer min:8] [platformText] [chevron] -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- primaryName — semibold if connected, regular otherwise; truncates middle -->
                <TextBlock
                    x:Name="PrimaryNameBlock"
                    Grid.Column="0"
                    FontSize="13"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                    Margin="0,0,8,0"
                    VerticalAlignment="Bottom" />

                <!-- headlineRight (platform text) — caption monospaced -->
                <TextBlock
                    x:Name="HeadlineRightBlock"
                    Grid.Column="1"
                    FontSize="11"
                    FontFamily="Consolas"
                    MaxLines="1"
                    Visibility="Collapsed"
                    VerticalAlignment="Bottom" />

                <!-- chevron.right — caption semibold; padding(.leading, 2) → Margin left 8 (spacing:6 + 2) -->
                <FontIcon
                    x:Name="ChevronIcon"
                    Grid.Column="2"
                    Glyph="&#xE76C;"
                    FontSize="9"
                    FontWeight="SemiBold"
                    Margin="8,0,0,0"
                    VerticalAlignment="Bottom" />
            </Grid>

            <!-- Detail HStack: detailLeft [spacer] detailRightVersion -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- detailLeft — caption, secondary color -->
                <TextBlock
                    x:Name="DetailLeftBlock"
                    Grid.Column="0"
                    FontSize="11"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Bottom" />

                <!-- detailRightVersion — caption monospaced, secondary color -->
                <TextBlock
                    x:Name="DetailRightBlock"
                    Grid.Column="1"
                    FontSize="11"
                    FontFamily="Consolas"
                    MaxLines="1"
                    Visibility="Collapsed"
                    VerticalAlignment="Bottom" />
            </Grid>

        </StackPanel>
    </Grid>

</UserControl>
