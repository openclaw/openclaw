<UserControl
    x:Class="OpenClawWindows.Presentation.Components.SelectableRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        Mirrors openClawSelectableRowChrome: rounded row with selected/hover highlight and
        accent border. RowContent replaces the Swift view-modifier's wrapped child view.
    -->
    <Border
        x:Name="Container"
        CornerRadius="10"
        BorderThickness="1"
        HorizontalAlignment="Stretch">

        <ContentPresenter x:Name="RowContentPresenter" />

    </Border>

</UserControl>
