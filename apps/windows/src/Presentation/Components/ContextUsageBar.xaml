<UserControl
    x:Class="OpenClawWindows.Presentation.Components.ContextUsageBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="6"
    AutomationProperties.Name="Context usage">

    <!-- Mirrors ContextUsageBar.swift: horizontal bar, track + fill, green→red by context fill. -->
    <Grid x:Name="Root" SizeChanged="Root_SizeChanged">
        <!-- Track: rounded background with subtle stroke -->
        <Border x:Name="Track" CornerRadius="3" BorderThickness="0.75" />
        <!-- Fill: left-aligned, width set in code-behind from fraction -->
        <Border x:Name="Fill" HorizontalAlignment="Left" CornerRadius="3" Width="0" />
    </Grid>

</UserControl>
