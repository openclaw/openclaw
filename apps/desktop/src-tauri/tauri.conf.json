{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Desktop",
  "version": "0.1.0",
  "identifier": "ai.openclaw.desktop",
  "build": {
    "beforeBuildCommand": "pnpm build:web",
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw Desktop",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
