{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenClaw",
  "version": "0.1.0",
  "identifier": "ai.openclaw.windows",
  "build": {
    "frontendDist": "../../../dist/control-ui",
    "devUrl": "http://localhost:18789",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "url": "http://localhost:18789"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../../dist/**/*",
      "../onboard.html"
    ],
    "externalBin": [
      "binaries/gateway"
    ]
  }
}
