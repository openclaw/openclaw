// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

MULLUSI_CODE_SIGN_STYLE = Automatic
MULLUSI_DEVELOPMENT_TEAM = YOUR_TEAM_ID

MULLUSI_APP_BUNDLE_ID = ai.mullusi.client
MULLUSI_SHARE_BUNDLE_ID = ai.mullusi.client.share
MULLUSI_ACTIVITY_WIDGET_BUNDLE_ID = ai.mullusi.client.activitywidget
MULLUSI_WATCH_APP_BUNDLE_ID = ai.mullusi.client.watchkitapp
MULLUSI_WATCH_EXTENSION_BUNDLE_ID = ai.mullusi.client.watchkitapp.extension

// Leave empty with automatic signing.
MULLUSI_APP_PROFILE =
MULLUSI_SHARE_PROFILE =
