# App Store Connect API key (pick one approach)
#
# Recommended (use the downloaded .p8 directly):
# ASC_KEY_ID=XXXXXXXXXX
# ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ASC_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
#
# Or (JSON key file):
# APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXX.json
#
# Or:
# ASC_KEY_ID=XXXXXXXXXX
# ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ASC_KEY_CONTENT=BASE64_P8_CONTENT

# Code signing
# IOS_DEVELOPMENT_TEAM=XXXXXXXXXX

# App Review contact injection for `fastlane ios metadata`
# IOS_APP_REVIEW_FIRST_NAME=Jane
# IOS_APP_REVIEW_LAST_NAME=Doe
# IOS_APP_REVIEW_EMAIL=review-contact@example.com
# IOS_APP_REVIEW_PHONE=+1 415 555 0101
# IOS_APP_REVIEW_NOTES_APPEND=Pair with the test gateway at https://example.invalid using setup code 123456. Demo account: reviewer@example.com / Password123!

# Deliver toggles (off by default)
# DELIVER_METADATA=1
# DELIVER_SCREENSHOTS=1
