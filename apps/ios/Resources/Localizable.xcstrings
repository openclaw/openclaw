          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "gateway को सक्रिय एजेंट वर्कस्पेस में DREAMS.md या dreams.md नहीं मिला।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
