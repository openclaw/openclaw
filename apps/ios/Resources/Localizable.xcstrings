    "Use iPhone Settings to enable direct connection.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use iPhone Settings to enable direct connection."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 iPhone 设置启用直接连接。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 iPhone 設定以啟用直接連線。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use os Ajustes do iPhone para ativar a conexão direta."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie die iPhone-Einstellungen, um die Direktverbindung zu aktivieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa los Ajustes del iPhone para activar la conexión directa."
          }
        },
