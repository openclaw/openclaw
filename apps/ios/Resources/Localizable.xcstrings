    "No recent recall, daily, grounded, or phase signals were reported.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No recent recall, daily, grounded, or phase signals were reported."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "未报告最近的回忆、每日、已接地或阶段信号。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "未回報近期回想、每日、基礎或階段訊號。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum sinal recente de recall, diário, fundamentado ou de fase foi reportado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es wurden keine aktuellen Recall-, Tages-, Grounded- oder Phasensignale gemeldet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se han notificado señales recientes de recuerdo, diarias, fundamentadas o de fase."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "最近のリコール、日次、根拠付き、またはフェーズシグナルは報告されていません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최근 recall, daily, grounded 또는 phase signal이 보고되지 않았습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun signal récent de rappel, quotidien, ancré ou de phase n’a été signalé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई हालिया रिकॉल, दैनिक, grounded, या phase संकेत रिपोर्ट नहीं किए गए।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم الإبلاغ عن أي إشارات استدعاء حديثة أو يومية أو مؤسَّسة أو مرحلية."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non sono stati segnalati richiami recenti, segnali giornalieri, fondati o di fase."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son geri çağırma, günlük, temellendirilmiş veya aşama sinyali bildirilmedi."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не було повідомлено про нещодавні сигнали відтворення, щоденні, заземлені або фазові сигнали."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada sinyal pengingatan terbaru, harian, terikat konteks, atau fase yang dilaporkan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie zgłoszono ostatnich sygnałów przywołania, dziennych, ugruntowanych ani fazowych."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มีการรายงานสัญญาณการเรียกคืนล่าสุด รายวัน แบบ grounded หรือระยะ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không có tín hiệu gọi lại gần đây, hằng ngày, có căn cứ hoặc theo pha nào được báo cáo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er zijn geen recente recall-, daily-, grounded- of phase-signalen gerapporteerd."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "هیچ سیگنال اخیرِ فراخوانی، روزانه، زمینه‌مند یا مرحله‌ای گزارش نشده است."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недавние сигналы воспоминаний, ежедневные, привязанные к контексту или фазовые сигналы не поступали."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen nyligen gjord återkallelse, dagliga, grundade eller fassignaler rapporterades."
          }
        }
      }
    },
