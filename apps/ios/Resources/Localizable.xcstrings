    "Pair a gateway to make it available here.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pair a gateway to make it available here."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "配对一个 gateway 以在此处使用。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "配對一個 gateway 以便在此使用。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pareie um gateway para torná-lo disponível aqui."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Koppeln Sie ein Gateway, um es hier verfügbar zu machen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empareja un gateway para que esté disponible aquí."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Gatewayをペアリングすると、ここで利用可能になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에서 사용할 수 있도록 Gateway를 페어링하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appairez un gateway pour le rendre disponible ici."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे यहाँ उपलब्ध बनाने के लिए एक gateway पेयर करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بإقران Gateway لجعله متاحًا هنا."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Associa un gateway per renderlo disponibile qui."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Burada kullanılabilir olması için bir gateway eşleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Сполучіть gateway, щоб зробити його доступним тут."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasangkan gateway agar tersedia di sini."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sparuj gateway, aby był tutaj dostępny."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จับคู่ Gateway เพื่อให้พร้อมใช้งานที่นี่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ghép nối một gateway để nó khả dụng tại đây."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Koppel een gateway om deze hier beschikbaar te maken."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "یک gateway را جفت کنید تا اینجا در دسترس باشد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выполните сопряжение с gateway, чтобы он стал доступен здесь."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Koppla en gateway för att göra den tillgänglig här."
          }
        }
      }
