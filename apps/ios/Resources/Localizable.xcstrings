    "Matching proposals appear here after gateway refresh.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Matching proposals appear here after gateway refresh."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway 刷新后，匹配的提案会显示在这里。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway 重新整理後，符合的提案會顯示在這裡。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Propostas correspondentes aparecem aqui após a atualização do gateway."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passende Vorschläge werden hier nach der Gateway-Aktualisierung angezeigt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las propuestas coincidentes aparecen aquí después de actualizar el Gateway."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway の更新後、一致する提案がここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway 새로 고침 후 일치하는 제안이 여기에 표시됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les propositions correspondantes apparaissent ici après l’actualisation de la Gateway."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway रिफ्रेश के बाद मेल खाते प्रस्ताव यहाँ दिखाई देते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر المقترحات المطابقة هنا بعد تحديث Gateway."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le proposte corrispondenti vengono visualizzate qui dopo l'aggiornamento del gateway."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eşleşen öneriler, gateway yenilendikten sonra burada görünür."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відповідні пропозиції з’являться тут після оновлення gateway."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Proposal yang cocok muncul di sini setelah penyegaran gateway."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasujące propozycje pojawią się tutaj po odświeżeniu gateway."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ข้อเสนอที่ตรงกันจะปรากฏที่นี่หลังจากรีเฟรช Gateway"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các đề xuất phù hợp sẽ xuất hiện ở đây sau khi làm mới gateway."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Overeenkomende voorstellen verschijnen hier na het vernieuwen van de Gateway."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پیشنهادهای مطابق پس از تازه‌سازی Gateway اینجا نمایش داده می‌شوند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подходящие предложения появятся здесь после обновления gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Matchande förslag visas här efter Gateway-uppdatering."
          }
        }
      }
    },
