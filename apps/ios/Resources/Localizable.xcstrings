    "Gateway rejected credentials. Scan a fresh setup code or update token/password.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway rejected credentials. Scan a fresh setup code or update token/password."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway 拒绝了凭据。请扫描新的设置代码或更新令牌/密码。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway 拒絕了憑證。請掃描新的設定碼，或更新權杖/密碼。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Gateway rejeitou as credenciais. Escaneie um novo código de configuração ou atualize o token/senha."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway hat die Anmeldedaten abgelehnt. Scannen Sie einen neuen Einrichtungscode oder aktualisieren Sie Token/Passwort."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway rechazó las credenciales. Escanea un nuevo código de configuración o actualiza el token/la contraseña."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway が認証情報を拒否しました。新しいセットアップコードをスキャンするか、トークン/パスワードを更新してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway에서 자격 증명을 거부했습니다. 새 설정 코드를 스캔하거나 토큰/비밀번호를 업데이트하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Gateway a rejeté les identifiants. Scannez un nouveau code de configuration ou mettez à jour le jeton/mot de passe."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway ने क्रेडेंशियल अस्वीकार कर दिए। नया सेटअप कोड स्कैन करें या टोकन/पासवर्ड अपडेट करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رفض Gateway بيانات الاعتماد. امسح رمز إعداد جديدًا أو حدّث الرمز المميز/كلمة المرور."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway ha rifiutato le credenziali. Scansiona un nuovo codice di configurazione o aggiorna token/password."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway kimlik bilgilerini reddetti. Yeni bir kurulum kodu tarayın veya token/parolayı güncelleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway відхилив облікові дані. Відскануйте новий код налаштування або оновіть токен/пароль."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway menolak kredensial. Pindai kode penyiapan baru atau perbarui token/kata sandi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway odrzucił dane uwierzytelniające. Zeskanuj nowy kod konfiguracji lub zaktualizuj token/hasło."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway ปฏิเสธข้อมูลรับรอง สแกนรหัสตั้งค่าใหม่หรืออัปเดตโทเคน/รหัสผ่าน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway đã từ chối thông tin xác thực. Quét mã thiết lập mới hoặc cập nhật token/mật khẩu."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway heeft inloggegevens geweigerd. Scan een nieuwe installatiecode of werk token/wachtwoord bij."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway اطلاعات ورود را رد کرد. یک کد راه‌اندازی جدید اسکن کنید یا توکن/گذرواژه را به‌روزرسانی کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway отклонил учетные данные. Отсканируйте новый код настройки или обновите токен/пароль."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway avvisade autentiseringsuppgifterna. Skanna en ny installationskod eller uppdatera token/lösenord."
          }
        }
      }
    },
