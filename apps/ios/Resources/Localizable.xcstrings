        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดการตั้งค่าหากคุณต้องระบุโฮสต์ด้วยตนเอง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mở Cài đặt nếu bạn cần nhập máy chủ thủ công."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Instellingen als je een handmatige host nodig hebt."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
