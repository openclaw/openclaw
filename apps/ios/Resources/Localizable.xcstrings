          "stringUnit": {
            "state": "translated",
            "value": "Gateway đã từ chối thông tin đăng nhập."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway heeft de referenties geweigerd."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway اعتبارنامه‌ها را رد کرد."
          }
        },
