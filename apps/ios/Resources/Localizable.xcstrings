    "Setup queued for the watch. Open OpenClaw before the code expires.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Setup queued for the watch. Open OpenClaw before the code expires."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "已为手表排队设置。请在验证码过期前打开 OpenClaw。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "已為手錶排入設定佇列。請在代碼過期前開啟 OpenClaw。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configuração na fila para o relógio. Abra o OpenClaw antes que o código expire."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einrichtung für die Uhr in Warteschlange. Öffne OpenClaw, bevor der Code abläuft."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configuración en cola para el reloj. Abre OpenClaw antes de que caduque el código."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "ウォッチのセットアップがキューに入りました。コードの有効期限が切れる前に OpenClaw を開いてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "워치에 설정이 대기 중입니다. 코드가 만료되기 전에 OpenClaw를 여세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Configuration mise en file d'attente pour la montre. Ouvrez OpenClaw avant l'expiration du code."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "watch के लिए सेटअप कतारबद्ध है। कोड समाप्त होने से पहले OpenClaw खोलें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم وضع الإعداد في قائمة الانتظار للساعة. افتح OpenClaw قبل انتهاء صلاحية الرمز."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurazione in coda per l'orologio. Apri OpenClaw prima che il codice scada."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurulum saat için sıraya alındı. Kod süresi dolmadan OpenClaw'ı açın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштування поставлено в чергу для годинника. Відкрийте OpenClaw до завершення терміну дії коду."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Penyiapan diantrekan untuk jam tangan. Buka OpenClaw sebelum kode kedaluwarsa."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfiguracja zakolejkowana dla zegarka. Otwórz OpenClaw, zanim kod wygaśnie."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จัดคิวการตั้งค่าสำหรับนาฬิกาแล้ว เปิด OpenClaw ก่อนที่รหัสจะหมดอายุ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã xếp hàng thiết lập cho đồng hồ. Mở OpenClaw trước khi mã hết hạn."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Installatie in wachtrij voor de watch. Open OpenClaw voordat de code verloopt."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "راه‌اندازی برای ساعت در صف قرار گرفت. پیش از انقضای کد، OpenClaw را باز کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройка поставлена в очередь для часов. Откройте OpenClaw до истечения срока действия кода."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfiguration köad för klockan. Öppna OpenClaw innan koden går ut."
          }
        }
      }
    },
