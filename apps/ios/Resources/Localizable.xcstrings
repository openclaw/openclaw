    "Connect to the gateway to load installed channels, accounts, and routing status.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect to the gateway to load installed channels, accounts, and routing status."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "连接到 Gateway 以加载已安装的渠道、账户和路由状态。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "連線到 Gateway 以載入已安裝的頻道、帳號和路由狀態。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte-se ao gateway para carregar os canais instalados, as contas e o status de roteamento."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbinden Sie sich mit dem Gateway, um installierte Kanäle, Konten und Routing-Status zu laden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conéctate al Gateway para cargar los canales instalados, las cuentas y el estado de enrutamiento."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway に接続して、インストール済みのチャンネル、アカウント、ルーティングステータスを読み込みます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설치된 채널, 계정 및 라우팅 상태를 불러오려면 Gateway에 연결하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous à la Gateway pour charger les canaux installés, les comptes et le statut du routage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इंस्टॉल किए गए चैनल, खाते और रूटिंग स्थिति लोड करने के लिए gateway से कनेक्ट करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتصل بالـ gateway لتحميل القنوات والحسابات وحالة التوجيه المثبّتة."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Connettiti al gateway per caricare i canali installati, gli account e lo stato di instradamento."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüklü kanalları, hesapları ve yönlendirme durumunu yüklemek için gateway'e bağlanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Підключіться до gateway, щоб завантажити встановлені канали, облікові записи та статус маршрутизації."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hubungkan ke gateway untuk memuat saluran terinstal, akun, dan status perutean."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połącz się z gateway, aby załadować zainstalowane kanały, konta i status routingu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เชื่อมต่อกับ gateway เพื่อโหลดช่องทาง บัญชี และสถานะการกำหนดเส้นทางที่ติดตั้งไว้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kết nối với gateway để tải các kênh đã cài đặt, tài khoản và trạng thái định tuyến."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Maak verbinding met de Gateway om geïnstalleerde kanalen, accounts en routeringsstatus te laden."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای بارگذاری کانال‌های نصب‌شده، حساب‌ها و وضعیت مسیریابی، به Gateway متصل شوید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключитесь к Gateway, чтобы загрузить установленные каналы, учетные записи и статус маршрутизации."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Anslut till gatewayen för att läsa in installerade kanaler, konton och routningsstatus."
          }
        }
      }
    },
