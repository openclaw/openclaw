        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यदि आपको मैन्युअल होस्ट चाहिए, तो Settings खोलें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح الإعدادات إذا كنت بحاجة إلى مضيف يدوي."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
