            "state": "translated",
            "value": "Gateway 拒绝了凭据。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway 拒絕了憑證。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Gateway rejeitou as credenciais."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway hat die Anmeldedaten abgelehnt."
          }
        },
        "es": {
