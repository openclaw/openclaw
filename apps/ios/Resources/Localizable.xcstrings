          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum gateway encontrado ainda. Use a configuração manual se o Bonjour estiver bloqueado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Gateways gefunden. Verwenden Sie die manuelle Einrichtung, wenn Bonjour blockiert ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no se encontraron gateways. Usa la configuración manual si Bonjour está bloqueado."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Gatewayがまだ見つかりません。Bonjourがブロックされている場合は手動セットアップを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 Gateway를 찾을 수 없습니다. Bonjour가 차단된 경우 수동 설정을 사용하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun Gateway trouvé pour le moment. Utilisez la configuration manuelle si Bonjour est bloqué."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी तक कोई gateway नहीं मिला। यदि Bonjour ब्लॉक है, तो मैनुअल सेटअप का उपयोग करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم العثور على أي بوابات حتى الآن. استخدم الإعداد اليدوي إذا كان Bonjour محظورًا."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun gateway trovato ancora. Usa la configurazione manuale se Bonjour è bloccato."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Henüz gateway bulunamadı. Bonjour engelleniyorsa manuel kurulumu kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway ще не знайдено. Використайте ручне налаштування, якщо Bonjour заблоковано."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada gateway yang ditemukan. Gunakan penyiapan manual jika Bonjour diblokir."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
