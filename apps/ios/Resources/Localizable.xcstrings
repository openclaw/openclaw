    "OpenClaw appreciates its partners in the open-source community.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw appreciates its partners in the open-source community."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw 感谢其在开源社区中的合作伙伴。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw 感謝其開源社群夥伴。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A OpenClaw agradece a seus parceiros na comunidade de código aberto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw dankt seinen Partnern in der Open-Source-Community."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw agradece a sus socios de la comunidad de código abierto."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw は、オープンソースコミュニティのパートナーに感謝します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw는 오픈 소스 커뮤니티의 파트너 여러분께 감사드립니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw remercie ses partenaires de la communauté open source."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw ओपन-सोर्स समुदाय में अपने भागीदारों की सराहना करता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقدّر OpenClaw شركاءها في مجتمع المصادر المفتوحة."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw apprezza i suoi partner nella community open-source."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw, açık kaynak topluluğundaki iş ortaklarına teşekkür eder."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw цінує своїх партнерів у спільноті відкритого коду."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw menghargai para mitranya di komunitas sumber terbuka."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw docenia swoich partnerów w społeczności open-source."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw ขอขอบคุณพันธมิตรในชุมชนโอเพนซอร์ส"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw trân trọng các đối tác của mình trong cộng đồng mã nguồn mở."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw waardeert zijn partners in de open-sourcecommunity."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw از شرکای خود در جامعهٔ متن‌باز قدردانی می‌کند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw благодарит своих партнеров в сообществе open-source."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw uppskattar sina partner i open source-communityn."
          }
        }
      }
    },
    "OpenClaw can show approval prompts and event alerts when the app is not active.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw can show approval prompts and event alerts when the app is not active."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw 可以在应用未激活时显示审批提示和事件提醒。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw 可在應用程式未啟用時顯示核准提示與事件警示。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O OpenClaw pode exibir solicitações de aprovação e alertas de eventos quando o app não está ativo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw kann Genehmigungsanfragen und Ereignisbenachrichtigungen anzeigen, wenn die App nicht aktiv ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw puede mostrar solicitudes de aprobación y alertas de eventos cuando la aplicación no está activa."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClawはアプリが非アクティブなときに承認プロンプトやイベントアラートを表示できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw는 앱이 활성 상태가 아닐 때 승인 요청과 이벤트 알림을 표시할 수 있습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw peut afficher des demandes d'approbation et des alertes d'événements lorsque l'application n'est pas active."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब ऐप सक्रिय न हो तब OpenClaw स्वीकृति संकेत और इवेंट अलर्ट दिखा सकता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن لـ OpenClaw عرض مطالبات الموافقة وتنبيهات الأحداث عندما لا يكون التطبيق نشطًا."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw può mostrare richieste di approvazione e avvisi di eventi quando l'app non è attiva."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw, uygulama etkin olmadığında onay istemleri ve olay uyarıları gösterebilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw може показувати запити на підтвердження та сповіщення про події, коли застосунок неактивний."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw dapat menampilkan permintaan persetujuan dan peringatan peristiwa saat aplikasi tidak aktif."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw może wyświetlać monity o zatwierdzenie i alerty o zdarzeniach, gdy aplikacja jest nieaktywna."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw สามารถแสดงคำขออนุมัติและการแจ้งเตือนเหตุการณ์ได้เมื่อแอปไม่ได้ทำงานอยู่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw có thể hiển thị lời nhắc phê duyệt và cảnh báo sự kiện khi ứng dụng không hoạt động."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw kan goedkeuringsvragen en gebeurtenismeldingen tonen wanneer de app niet actief is."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw می‌تواند وقتی برنامه فعال نیست، درخواست‌های تأیید و هشدارهای رویداد را نمایش دهد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw может показывать запросы на подтверждение и оповещения о событиях, когда приложение неактивно."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw kan visa godkännandeförfrågningar och händelseaviseringar när appen inte är aktiv."
          }
        }
      }
    },
    "OpenClaw cannot determine the current iOS location permission.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw cannot determine the current iOS location permission."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw 无法确定当前的 iOS 位置权限。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw 無法判斷目前的 iOS 位置權限。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O OpenClaw não consegue determinar a permissão de localização atual do iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw kann die aktuelle iOS-Standortberechtigung nicht ermitteln."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw no puede determinar el permiso de ubicación actual de iOS."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw は現在の iOS 位置情報の権限を確認できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw가 현재 iOS 위치 권한을 확인할 수 없습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw ne peut pas déterminer l'autorisation de localisation iOS actuelle."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw वर्तमान iOS लोकेशन अनुमति निर्धारित नहीं कर सकता।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يستطيع OpenClaw تحديد إذن الموقع الحالي في iOS."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw non può determinare l’autorizzazione alla posizione iOS attuale."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw geçerli iOS konum iznini belirleyemiyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw не може визначити поточний дозвіл iOS на геолокацію."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw tidak dapat menentukan izin lokasi iOS saat ini."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw nie może określić bieżącego uprawnienia do lokalizacji w iOS."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw ไม่สามารถระบุการอนุญาตตำแหน่งที่ตั้งของ iOS ในปัจจุบันได้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw không thể xác định quyền vị trí iOS hiện tại."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw kan de huidige iOS-locatietoestemming niet bepalen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw نمی‌تواند مجوز فعلی موقعیت مکانی iOS را تشخیص دهد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw не может определить текущее разрешение iOS на доступ к местоположению."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw kan inte fastställa den aktuella iOS-platsbehörigheten."
          }
        }
      }
    },
