    "Speaking, tap to stop": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Speaking, tap to stop"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "正在朗读，轻点以停止"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "正在朗讀，點一下即可停止"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falando, toque para parar"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spricht, zum Stoppen tippen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hablando, toca para detener"
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "読み上げ中、タップして停止"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "말하는 중, 탭하여 중지"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lecture, toucher pour arrêter"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बोला जा रहा है, रोकने के लिए टैप करें"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جارٍ التحدث، اضغط للإيقاف"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduzione vocale, tocca per interrompere"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konuşuyor, durdurmak için dokunun"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Озвучення, торкніться, щоб зупинити"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Berbicara, ketuk untuk berhenti"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mówienie, stuknij, aby zatrzymać"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กำลังพูด แตะเพื่อหยุด"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đang nói, chạm để dừng"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spreekt, tik om te stoppen"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "در حال صحبت، برای توقف ضربه بزنید"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Воспроизведение речи, нажмите, чтобы остановить"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Talar, tryck för att stoppa"
          }
        }
      }
    },
