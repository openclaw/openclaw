    "Use this if you have a setup code instead of scanning.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use this if you have a setup code instead of scanning."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您有设置代码而不是扫描，请使用此项。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您有設定碼而不是掃描，請使用此選項。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use isto se você tiver um código de configuração em vez de escanear."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie dies, wenn Sie einen Einrichtungscode haben, statt ihn zu scannen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa esto si tienes un código de configuración en lugar de escanear."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "スキャンの代わりにセットアップコードがある場合は、これを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스캔하는 대신 설정 코드가 있는 경우 사용하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez cette option si vous disposez d’un code de configuration au lieu de le scanner."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यदि आपके पास स्कैन करने के बजाय सेटअप कोड है, तो इसका उपयोग करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم هذا إذا كان لديك رمز إعداد بدلًا من المسح الضوئي."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa questa opzione se hai un codice di configurazione invece di scansionarlo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarama yerine bir kurulum kodunuz varsa bunu kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовуйте це, якщо у вас є код налаштування замість сканування."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan ini jika Anda memiliki kode penyiapan alih-alih memindai."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj tej opcji, jeśli masz kod konfiguracji zamiast skanowania."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ตัวเลือกนี้หากคุณมีรหัสตั้งค่าแทนการสแกน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dùng tùy chọn này nếu bạn có mã thiết lập thay vì quét."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik dit als u een installatiecode hebt in plaats van te scannen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "اگر به‌جای اسکن، کد راه‌اندازی دارید، از این گزینه استفاده کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте это, если у вас есть код настройки вместо сканирования."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd detta om du har en installationskod i stället för att skanna."
          }
        }
      }
    },
