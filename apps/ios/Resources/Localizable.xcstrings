    "Mobile setup codes, QR, and node approval.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mobile setup codes, QR, and node approval."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "移动端设置代码、QR 和节点批准。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "行動設定代碼、QR 與節點核准。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Códigos de configuração móvel, QR e aprovação de nó."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mobile Einrichtungscodes, QR und Knotenfreigabe."
          }
        },
