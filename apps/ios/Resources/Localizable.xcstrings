        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema sigue el ajuste de apariencia de este dispositivo."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "システムはこのデバイスの外観設定に従います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템은 이 기기의 화면 모드 설정을 따릅니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le système suit le réglage d’apparence de cet appareil."
          }
