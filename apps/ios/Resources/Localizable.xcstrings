    "This permanently deletes the session and its transcript.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This permanently deletes the session and its transcript."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除该会话及其转录内容。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "這會永久刪除此工作階段及其文字記錄。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso exclui permanentemente a sessão e sua transcrição."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden die Sitzung und ihr Transkript dauerhaft gelöscht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente la sesión y su transcripción."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、セッションとそのトランスクリプトが完全に削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션과 해당 대화 기록이 영구적으로 삭제됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette action supprime définitivement la session et sa transcription."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे सेशन और उसका ट्रांसक्रिप्ट स्थायी रूप से हट जाएगा।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى حذف الجلسة ونصها بشكل دائم."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La sessione e la relativa trascrizione verranno eliminate definitivamente."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem oturumu ve dökümünü kalıcı olarak siler."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це назавжди видалить сеанс і його стенограму."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan menghapus sesi dan transkripnya secara permanen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to trwałe usunięcie sesji i jej transkrypcji."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบเซสชันและข้อความถอดเสียงอย่างถาวร"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa vĩnh viễn phiên và bản ghi của phiên đó."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermee verwijder je de sessie en het transcript permanent."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این کار جلسه و رونوشت آن را برای همیشه حذف می‌کند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это безвозвратно удалит сеанс и его стенограмму."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta raderar sessionen och dess transkript permanent."
          }
        }
      }
    },
    "This removes saved credentials, device access, TLS trust, and cached chats for this gateway.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes saved credentials, device access, TLS trust, and cached chats for this gateway."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "这将移除已保存的凭据、设备访问权限、TLS 信任和此 gateway 的缓存聊天。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "這會移除此 gateway 的已儲存憑證、裝置存取權、TLS 信任及快取的聊天記錄。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso remove as credenciais salvas, o acesso ao dispositivo, a confiança TLS e os chats em cache deste gateway."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden gespeicherte Anmeldedaten, Gerätezugriff, TLS-Vertrauen und zwischengespeicherte Chats für dieses Gateway entfernt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina las credenciales guardadas, el acceso al dispositivo, la confianza TLS y los chats en caché de este Gateway."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、この Gateway の保存された認証情報、デバイスアクセス、TLS 信頼、キャッシュされたチャットが削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Gateway에 대해 저장된 자격 증명, 기기 접근, TLS 신뢰, 캐시된 채팅을 삭제합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci supprime les identifiants enregistrés, l'accès à l'appareil, la confiance TLS et les discussions en cache de ce Gateway."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह इस gateway के लिए सहेजे गए क्रेडेंशियल, डिवाइस एक्सेस, TLS ट्रस्ट, और कैश की गई चैट हटा देता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يؤدي هذا إلى إزالة بيانات الاعتماد المحفوظة والوصول إلى الجهاز وثقة TLS والمحادثات المخزنة مؤقتًا لهذا الـ Gateway."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuove le credenziali salvate, l'accesso ai dispositivi, l'attendibilità TLS e le chat memorizzate nella cache per questo gateway."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem, bu gateway için kaydedilen kimlik bilgilerini, cihaz erişimini, TLS güvenini ve önbelleğe alınmış sohbetleri kaldırır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це видаляє збережені облікові дані, доступ пристрою, довіру TLS та кешовані чати для цього Gateway."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini menghapus kredensial tersimpan, akses perangkat, kepercayaan TLS, dan obrolan tersimpan untuk gateway ini."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Powoduje to usunięcie zapisanych poświadczeń, dostępu urządzenia, zaufania TLS i buforowanych czatów dla tego Gateway."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบข้อมูลรับรองที่บันทึกไว้ การเข้าถึงอุปกรณ์ ความน่าเชื่อถือ TLS และแชทที่แคชไว้สำหรับ Gateway นี้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này xóa thông tin đăng nhập đã lưu, quyền truy cập thiết bị, tin cậy TLS và các cuộc trò chuyện được lưu trong bộ nhớ đệm cho gateway này."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermee worden opgeslagen inloggegevens, apparaattoegang, TLS-vertrouwen en gecachte chats voor deze gateway verwijderd."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این کار اعتبارنامه‌های ذخیره‌شده، دسترسی دستگاه، اعتماد TLS و گفتگوهای ذخیره‌شده این gateway را حذف می‌کند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это удалит сохранённые учётные данные, доступ устройства, доверие TLS и кэшированные чаты для этого Gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta tar bort sparade autentiseringsuppgifter, enhetsåtkomst, TLS-förtroende och cachade chattar för denna gateway."
          }
        }
      }
    },
