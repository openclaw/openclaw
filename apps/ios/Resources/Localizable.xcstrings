    "Remove attachments or wait for delivery to resolve before starting a new chat.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove attachments or wait for delivery to resolve before starting a new chat."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请移除附件或等待发送完成后再开始新聊天。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "請先移除附件或等待傳送完成，再開始新的聊天。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remova os anexos ou aguarde a entrega ser concluída antes de iniciar uma nova conversa."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernen Sie Anhänge oder warten Sie auf die Zustellung, bevor Sie einen neuen Chat starten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina los adjuntos o espera a que se complete la entrega antes de iniciar un nuevo chat."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいチャットを開始する前に、添付ファイルを削除するか送信が完了するのを待ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 채팅을 시작하기 전에 첨부 파일을 제거하거나 전송이 완료될 때까지 기다리세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimez les pièces jointes ou attendez la livraison avant de démarrer une nouvelle conversation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नई चैट शुरू करने से पहले अटैचमेंट हटाएं या डिलीवरी पूरी होने की प्रतीक्षा करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أزِل المرفقات أو انتظر اكتمال التسليم قبل بدء محادثة جديدة."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovi gli allegati o attendi il completamento della consegna prima di iniziare una nuova chat."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni bir sohbet başlatmadan önce ekleri kaldırın veya teslimatın tamamlanmasını bekleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Видаліть вкладення або зачекайте на завершення доставлення, перш ніж починати новий чат."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hapus lampiran atau tunggu pengiriman selesai sebelum memulai obrolan baru."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuń załączniki lub poczekaj na zakończenie dostarczania przed rozpoczęciem nowego czatu."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบไฟล์แนบหรือรอให้การส่งเสร็จสิ้นก่อนเริ่มแชทใหม่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gỡ tệp đính kèm hoặc chờ gửi xong trước khi bắt đầu cuộc trò chuyện mới."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwijder bijlagen of wacht tot de bezorging is voltooid voordat je een nieuwe chat start."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پیش از شروع گفتگوی جدید، پیوست‌ها را حذف کنید یا منتظر تکمیل ارسال بمانید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалите вложения или дождитесь доставки, прежде чем начинать новый чат."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta bort bilagor eller vänta på att leveransen slutförs innan du startar en ny chatt."
          }
        }
      }
    },
    "Remove attachments or wait for delivery to resolve before switching chats.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove attachments or wait for delivery to resolve before switching chats."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "请移除附件或等待发送完成后再切换聊天。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "請先移除附件或等待傳送完成，再切換聊天。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remova os anexos ou aguarde a entrega ser concluída antes de trocar de conversa."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernen Sie Anhänge oder warten Sie auf die Zustellung, bevor Sie den Chat wechseln."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina los adjuntos o espera a que se complete la entrega antes de cambiar de chat."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "チャットを切り替える前に、添付ファイルを削除するか送信が完了するのを待ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "채팅을 전환하기 전에 첨부 파일을 제거하거나 전송이 완료될 때까지 기다리세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimez les pièces jointes ou attendez la livraison avant de changer de conversation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चैट बदलने से पहले अटैचमेंट हटाएं या डिलीवरी पूरी होने की प्रतीक्षा करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أزِل المرفقات أو انتظر اكتمال التسليم قبل تبديل المحادثات."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovi gli allegati o attendi il completamento della consegna prima di cambiare chat."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sohbetleri değiştirmeden önce ekleri kaldırın veya teslimatın tamamlanmasını bekleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Видаліть вкладення або зачекайте на завершення доставлення, перш ніж перемикати чати."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hapus lampiran atau tunggu pengiriman selesai sebelum beralih obrolan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuń załączniki lub poczekaj na zakończenie dostarczania przed przełączeniem czatów."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบไฟล์แนบหรือรอให้การส่งเสร็จสิ้นก่อนสลับแชท"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gỡ tệp đính kèm hoặc chờ gửi xong trước khi chuyển cuộc trò chuyện."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwijder bijlagen of wacht tot de bezorging is voltooid voordat je van chat wisselt."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پیش از تغییر گفتگو، پیوست‌ها را حذف کنید یا منتظر تکمیل ارسال بمانید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалите вложения или дождитесь доставки, прежде чем переключать чаты."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta bort bilagor eller vänta på att leveransen slutförs innan du byter chatt."
          }
        }
      }
    },
