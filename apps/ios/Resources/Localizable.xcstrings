    "Not sent, touch and hold to retry or delete": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not sent, touch and hold to retry or delete"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "未发送，轻触并按住以重试或删除"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "未傳送，按住以重試或刪除"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não enviado, toque e segure para tentar novamente ou excluir"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht gesendet, zum erneuten Versuch oder Löschen berühren und halten"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No enviado; mantén pulsado para reintentar o eliminar"
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "未送信、長押しして再試行または削除"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전송되지 않음, 다시 시도하거나 삭제하려면 길게 터치하세요"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non envoyé, touchez de manière prolongée pour réessayer ou supprimer"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नहीं भेजा गया, फिर से कोशिश करने या मिटाने के लिए स्पर्श करके दबाए रखें"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم الإرسال، المس مطولًا لإعادة المحاولة أو الحذف"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non inviato, tieni premuto per riprovare o eliminare"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gönderilmedi, yeniden denemek veya silmek için dokunup basılı tutun"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не надіслано, торкніться й утримуйте, щоб повторити або видалити"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak terkirim, sentuh dan tahan untuk mencoba lagi atau menghapus"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie wysłano, dotknij i przytrzymaj, aby spróbować ponownie lub usunąć"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังไม่ได้ส่ง แตะค้างไว้เพื่อลองอีกครั้งหรือลบ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chưa gửi, chạm và giữ để thử lại hoặc xóa"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niet verzonden, houd ingedrukt om opnieuw te proberen of te verwijderen"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "ارسال نشد، برای تلاش دوباره یا حذف، لمس کنید و نگه دارید"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не отправлено, коснитесь и удерживайте, чтобы повторить отправку или удалить"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inte skickat, tryck och håll ned för att försöka igen eller ta bort"
          }
        }
      }
    },
