    "Connect to your gateway to open a shell in the agent workspace.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect to your gateway to open a shell in the agent workspace."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "连接到你的 Gateway，以在代理工作区中打开 shell。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "連線到您的 Gateway，以在代理程式工作區中開啟 shell。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte-se ao seu Gateway para abrir um shell no workspace do agente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbinden Sie sich mit Ihrer Gateway, um eine Shell im Agent-Arbeitsbereich zu öffnen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conéctate a tu Gateway para abrir un shell en el espacio de trabajo del agente."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway に接続して、エージェントのワークスペースでシェルを開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트 워크스페이스에서 셸을 열려면 gateway에 연결하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous à votre Gateway pour ouvrir un shell dans l’espace de travail de l’agent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एजेंट वर्कस्पेस में शेल खोलने के लिए अपने Gateway से कनेक्ट करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتصل بالـ Gateway لفتح shell في مساحة عمل الوكيل."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Connettiti al tuo Gateway per aprire una shell nell'area di lavoro dell'agente."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aracı çalışma alanında bir shell açmak için Gateway’inize bağlanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Підключіться до свого Gateway, щоб відкрити оболонку в робочому просторі агента."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hubungkan ke Gateway Anda untuk membuka shell di ruang kerja agen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połącz się ze swoim Gateway, aby otworzyć powłokę w obszarze roboczym agenta."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เชื่อมต่อกับ Gateway ของคุณเพื่อเปิดเชลล์ในพื้นที่ทำงานของเอเจนต์"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kết nối với Gateway của bạn để mở shell trong không gian làm việc của agent."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Maak verbinding met je Gateway om een shell in de agentwerkruimte te openen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای باز کردن یک shell در فضای کاری عامل، به Gateway خود متصل شوید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключитесь к своему Gateway, чтобы открыть оболочку в рабочей области агента."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Anslut till din Gateway för att öppna ett skal i agentens arbetsyta."
          }
        }
      }
    },
