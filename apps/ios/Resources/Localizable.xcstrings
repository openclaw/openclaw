    "Choose a location mode to request iOS permission.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a location mode to request iOS permission."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一种位置模式以请求 iOS 权限。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇位置模式以要求 iOS 權限。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um modo de localização para solicitar a permissão do iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie einen Standortmodus aus, um die iOS-Berechtigung anzufordern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un modo de ubicación para solicitar el permiso de iOS."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS の権限をリクエストする位置情報モードを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 권한을 요청할 위치 모드를 선택하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un mode de localisation pour demander l’autorisation iOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS अनुमति का अनुरोध करने के लिए कोई लोकेशन मोड चुनें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر وضع موقع لطلب إذن iOS."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli una modalità di posizione per richiedere l’autorizzazione di iOS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS izni istemek için bir konum modu seçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть режим геолокації, щоб запитати дозвіл iOS."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih mode lokasi untuk meminta izin iOS."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz tryb lokalizacji, aby poprosić o uprawnienie iOS."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกโหมดตำแหน่งที่ตั้งเพื่อขอสิทธิ์อนุญาตจาก iOS"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn chế độ vị trí để yêu cầu quyền iOS."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies een locatiemodus om iOS-toestemming aan te vragen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای درخواست مجوز iOS، یک حالت موقعیت مکانی انتخاب کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
