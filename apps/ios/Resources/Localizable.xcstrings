    "queued after route change": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "queued after route change"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "路由更改后已排队"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "路由變更後已排入佇列"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "na fila após alteração de rota"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "nach Routenänderung in Warteschlange"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "en cola tras cambio de ruta"
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "経路変更後にキューに追加済み"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "경로 변경 후 대기열에 추가됨"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "mis en file d’attente après le changement d’itinéraire"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रूट बदलने के बाद कतार में रखा गया"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تمت الإضافة إلى قائمة الانتظار بعد تغيير المسار"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "in coda dopo la modifica del percorso"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "rota değişikliğinden sonra kuyruğa alındı"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "поставлено в чергу після зміни маршруту"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "diantrekan setelah perubahan rute"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "dodano do kolejki po zmianie trasy"
          }
        },
        "th": {
