        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전송됨, 채팅 기록 확인을 기다리는 중"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyé, en attente de confirmation de l’historique de discussion"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "भेजा गया, चैट इतिहास की पुष्टि की प्रतीक्षा है"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
