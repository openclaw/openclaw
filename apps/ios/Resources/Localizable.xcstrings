    "Background location requests and significant-change updates are allowed.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background location requests and significant-change updates are allowed."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "已允许后台位置请求和显著位置变化更新。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "已允許背景位置請求和重大位置變更更新。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitações de localização em segundo plano e atualizações de mudança significativa são permitidas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standortanfragen im Hintergrund und Updates bei signifikanten Änderungen sind erlaubt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se permiten las solicitudes de ubicación en segundo plano y las actualizaciones de cambios significativos."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "バックグラウンドでの位置情報リクエストと重要な位置情報の変化の更新が許可されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "백그라운드 위치 요청 및 중요 변경 업데이트가 허용됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les demandes de localisation en arrière-plan et les mises à jour en cas de changement significatif sont autorisées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बैकग्राउंड स्थान अनुरोधों और महत्वपूर्ण-बदलाव अपडेट की अनुमति है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "طلبات الموقع في الخلفية وتحديثات التغيير الكبير مسموح بها."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le richieste di posizione in background e gli aggiornamenti per variazioni significative sono consentiti."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arka planda konum isteklerine ve önemli değişiklik güncellemelerine izin verilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Фонові запити геолокації та оновлення за значною зміною дозволено."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Permintaan lokasi latar belakang dan pembaruan perubahan signifikan diizinkan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żądania lokalizacji w tle i aktualizacje przy istotnej zmianie są dozwolone."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตคำขอตำแหน่งที่ตั้งเบื้องหลังและการอัปเดตเมื่อมีการเปลี่ยนแปลงสำคัญแล้ว"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các yêu cầu vị trí trong nền và cập nhật thay đổi đáng kể được cho phép."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Locatieverzoeken op de achtergrond en updates bij significante wijzigingen zijn toegestaan."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "درخواست‌های مکان در پس‌زمینه و به‌روزرسانی‌های تغییر مهم مجاز هستند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запросы геопозиции в фоновом режиме и обновления при значительном изменении местоположения разрешены."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Platsförfrågningar i bakgrunden och uppdateringar vid betydande ändringar är tillåtna."
          }
        }
      }
    },
    "Background location requests and significant-change updates are allowed. Precise Location is off.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background location requests and significant-change updates are allowed. Precise Location is off."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "已允许后台位置请求和显著位置变化更新。精确位置已关闭。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "已允許背景位置請求和重大位置變更更新。精確位置已關閉。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitações de localização em segundo plano e atualizações de mudança significativa são permitidas. Localização Precisa está desativada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standortanfragen im Hintergrund und Updates bei signifikanten Änderungen sind erlaubt. Genauer Standort ist deaktiviert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se permiten las solicitudes de ubicación en segundo plano y las actualizaciones de cambios significativos. La ubicación precisa está desactivada."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "バックグラウンドでの位置情報リクエストと重要な位置情報の変化の更新が許可されています。正確な位置情報はオフです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "백그라운드 위치 요청 및 중요 변경 업데이트가 허용됩니다. 정확한 위치가 꺼져 있습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les demandes de localisation en arrière-plan et les mises à jour en cas de changement significatif sont autorisées. La position précise est désactivée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बैकग्राउंड स्थान अनुरोधों और महत्वपूर्ण-बदलाव अपडेट की अनुमति है। सटीक स्थान बंद है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "طلبات الموقع في الخلفية وتحديثات التغيير الكبير مسموح بها. الموقع الدقيق متوقف."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le richieste di posizione in background e gli aggiornamenti per variazioni significative sono consentiti. Posizione esatta è disattivata."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arka planda konum isteklerine ve önemli değişiklik güncellemelerine izin verilir. Kesin Konum kapalı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Фонові запити геолокації та оновлення за значною зміною дозволено. Точну геопозицію вимкнено."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Permintaan lokasi latar belakang dan pembaruan perubahan signifikan diizinkan. Lokasi Presisi nonaktif."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żądania lokalizacji w tle i aktualizacje przy istotnej zmianie są dozwolone. Dokładna lokalizacja jest wyłączona."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตคำขอตำแหน่งที่ตั้งเบื้องหลังและการอัปเดตเมื่อมีการเปลี่ยนแปลงสำคัญแล้ว ตำแหน่งที่ตั้งแม่นยำปิดอยู่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các yêu cầu vị trí trong nền và cập nhật thay đổi đáng kể được cho phép. Vị trí chính xác đang tắt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Locatieverzoeken op de achtergrond en updates bij significante wijzigingen zijn toegestaan. Exacte locatie is uitgeschakeld."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "درخواست‌های مکان در پس‌زمینه و به‌روزرسانی‌های تغییر مهم مجاز هستند. مکان دقیق خاموش است."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запросы геопозиции в фоновом режиме и обновления при значительном изменении местоположения разрешены. Точная геопозиция выключена."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Platsförfrågningar i bakgrunden och uppdateringar vid betydande ändringar är tillåtna. Exakt plats är av."
          }
        }
      }
    },
