    "Delivery unconfirmed, touch and hold to retry or delete": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delivery unconfirmed, touch and hold to retry or delete"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "送达未确认，轻触并按住以重试或删除"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "傳送狀態未確認，按住以重試或刪除"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrega não confirmada, toque e segure para tentar novamente ou apagar"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zustellung unbestätigt, zum erneuten Versuchen oder Löschen berühren und halten"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrega no confirmada, mantén presionado para reintentar o eliminar"
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "配信未確認、再試行または削除するには長押ししてください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전송 확인 안 됨, 다시 시도하거나 삭제하려면 길게 터치"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Livraison non confirmée, touchez de façon prolongée pour réessayer ou supprimer"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिलीवरी की पुष्टि नहीं हुई, फिर से प्रयास करने या हटाने के लिए स्पर्श करके दबाए रखें"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم تأكيد التسليم، المس مع الاستمرار لإعادة المحاولة أو الحذف"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consegna non confermata, tocca e tieni premuto per riprovare o eliminare"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Teslimat onaylanmadı, yeniden denemek veya silmek için dokunup basılı tutun"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Доставку не підтверджено, торкніться й утримуйте, щоб повторити спробу або видалити"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pengiriman belum dikonfirmasi, sentuh dan tahan untuk mencoba lagi atau menghapus"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostarczenie niepotwierdzone, dotknij i przytrzymaj, aby ponowić próbę lub usunąć"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังไม่ได้ยืนยันการส่ง แตะค้างไว้เพื่อลองอีกครั้งหรือลบ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chưa xác nhận được trạng thái gửi, chạm và giữ để thử lại hoặc xóa"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bezorging niet bevestigd, houd ingedrukt om opnieuw te proberen of te verwijderen"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "تحویل تأیید نشده است، برای تلاش دوباره یا حذف، لمس کنید و نگه دارید"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доставка не подтверждена, коснитесь и удерживайте, чтобы повторить попытку или удалить"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Leverans obekräftad, tryck och håll för att försöka igen eller radera"
          }
        }
      }
    },
