    "Always is selected, but iOS currently allows location only while using the app.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Always is selected, but iOS currently allows location only while using the app."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "已选择“始终”，但 iOS 当前仅允许在使用 App 时访问位置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "已選取「永遠」，但 iOS 目前只允許在使用 App 期間取用位置。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sempre está selecionado, mas o iOS atualmente permite localização apenas enquanto o app está em uso."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Immer“ ist ausgewählt, aber iOS erlaubt den Standort derzeit nur während der Nutzung der App."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siempre está seleccionado, pero actualmente iOS permite la ubicación solo mientras se usa la app."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "「常に」が選択されていますが、iOS では現在、アプリの使用中のみ位置情報の利用が許可されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "항상이 선택되어 있지만, 현재 iOS는 앱을 사용하는 동안에만 위치를 허용합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toujours est sélectionné, mais iOS autorise actuellement la localisation uniquement lors de l’utilisation de l’app."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Always चयनित है, लेकिन iOS वर्तमान में केवल ऐप का उपयोग करते समय ही लोकेशन की अनुमति देता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد «دائمًا»، لكن iOS يسمح حاليًا بالوصول إلى الموقع فقط أثناء استخدام التطبيق."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È selezionato Sempre, ma iOS attualmente consente la posizione solo mentre usi l’app."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her Zaman seçili, ancak iOS şu anda konuma yalnızca uygulama kullanılırken izin veriyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вибрано «Завжди», але наразі iOS дозволяє доступ до геолокації лише під час використання застосунку."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Selalu dipilih, tetapi iOS saat ini hanya mengizinkan lokasi saat menggunakan aplikasi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybrano „Zawsze”, ale iOS obecnie zezwala na lokalizację tylko podczas używania aplikacji."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก Always แล้ว แต่ขณะนี้ iOS อนุญาตให้เข้าถึงตำแหน่งที่ตั้งได้เฉพาะขณะใช้แอปเท่านั้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Luôn luôn được chọn, nhưng iOS hiện chỉ cho phép vị trí khi đang sử dụng ứng dụng."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Altijd is geselecteerd, maar iOS staat locatie momenteel alleen toe tijdens het gebruik van de app."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Always انتخاب شده است، اما iOS در حال حاضر فقط هنگام استفاده از برنامه اجازهٔ دسترسی به موقعیت مکانی را می‌دهد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбрано «Всегда», но сейчас iOS разрешает доступ к геопозиции только при использовании приложения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alltid är valt, men iOS tillåter för närvarande plats endast när appen används."
          }
        }
      }
    },
    "Always is selected, but iOS currently allows location only while using the app. Precise Location is off.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Always is selected, but iOS currently allows location only while using the app. Precise Location is off."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "已选择“始终”，但 iOS 当前仅允许在使用 App 时访问位置。精确位置已关闭。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "已選取「永遠」，但 iOS 目前只允許在使用 App 期間取用位置。精確位置已關閉。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sempre está selecionado, mas o iOS atualmente permite localização apenas enquanto o app está em uso. Localização Precisa está desativada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Immer“ ist ausgewählt, aber iOS erlaubt den Standort derzeit nur während der Nutzung der App. „Genauer Standort“ ist deaktiviert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siempre está seleccionado, pero actualmente iOS permite la ubicación solo mientras se usa la app. Ubicación precisa está desactivada."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "「常に」が選択されていますが、iOS では現在、アプリの使用中のみ位置情報の利用が許可されています。正確な位置情報はオフです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "항상이 선택되어 있지만, 현재 iOS는 앱을 사용하는 동안에만 위치를 허용합니다. 정확한 위치가 꺼져 있습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toujours est sélectionné, mais iOS autorise actuellement la localisation uniquement lors de l’utilisation de l’app. Position exacte est désactivée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Always चयनित है, लेकिन iOS वर्तमान में केवल ऐप का उपयोग करते समय ही लोकेशन की अनुमति देता है। Precise Location बंद है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديد «دائمًا»، لكن iOS يسمح حاليًا بالوصول إلى الموقع فقط أثناء استخدام التطبيق. الموقع الدقيق متوقف."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È selezionato Sempre, ma iOS attualmente consente la posizione solo mentre usi l’app. Posizione precisa è disattivata."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her Zaman seçili, ancak iOS şu anda konuma yalnızca uygulama kullanılırken izin veriyor. Kesin Konum kapalı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вибрано «Завжди», але наразі iOS дозволяє доступ до геолокації лише під час використання застосунку. Точна геолокація вимкнена."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Selalu dipilih, tetapi iOS saat ini hanya mengizinkan lokasi saat menggunakan aplikasi. Lokasi Tepat nonaktif."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybrano „Zawsze”, ale iOS obecnie zezwala na lokalizację tylko podczas używania aplikacji. Dokładna lokalizacja jest wyłączona."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือก Always แล้ว แต่ขณะนี้ iOS อนุญาตให้เข้าถึงตำแหน่งที่ตั้งได้เฉพาะขณะใช้แอปเท่านั้น Precise Location ปิดอยู่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Luôn luôn được chọn, nhưng iOS hiện chỉ cho phép vị trí khi đang sử dụng ứng dụng. Vị trí chính xác đang tắt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Altijd is geselecteerd, maar iOS staat locatie momenteel alleen toe tijdens het gebruik van de app. Exacte locatie is uitgeschakeld."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Always انتخاب شده است، اما iOS در حال حاضر فقط هنگام استفاده از برنامه اجازهٔ دسترسی به موقعیت مکانی را می‌دهد. Precise Location خاموش است."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбрано «Всегда», но сейчас iOS разрешает доступ к геопозиции только при использовании приложения. Точная геопозиция выключена."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alltid är valt, men iOS tillåter för närvarande plats endast när appen används. Exakt plats är av."
          }
        }
      }
    },
