        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتم إزالة الجلسة ونصها من الـ Gateway."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La sessione e la relativa trascrizione vengono rimosse dal gateway."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oturum ve dökümü gateway'den kaldırılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Сеанс і його транскрипт видаляються з gateway."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesi dan transkripnya dihapus dari gateway."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesja i jej transkrypcja zostaną usunięte z gateway."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เซสชันและบันทึกการสนทนาจะถูกลบออกจาก Gateway"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phiên và bản ghi của nó bị xóa khỏi gateway."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De sessie en het transcript worden van de gateway verwijderd."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "جلسه و رونوشت آن از Gateway حذف می‌شوند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сессия и её транскрипт удаляются из Gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessionen och dess transkript tas bort från gatewayen."
          }
        }
      }
    },
    "The session attaches once the gateway is ready.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The session attaches once the gateway is ready."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway 准备就绪后，会话将会附加。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway 準備就緒後，工作階段會連接。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A sessão será anexada assim que o Gateway estiver pronto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Sitzung wird angehängt, sobald die Gateway bereit ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La sesión se adjunta una vez que el gateway esté listo."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway の準備ができると、セッションが接続されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway가 준비되면 세션이 연결됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La session se connecte une fois que le gateway est prêt."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway तैयार होने के बाद सेशन अटैच हो जाता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم إرفاق الجلسة بمجرد أن يصبح Gateway جاهزًا."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La sessione si collega quando il Gateway è pronto."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway hazır olduğunda oturum bağlanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Сеанс під’єднається, щойно Gateway буде готовий."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesi terhubung setelah gateway siap."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesja zostanie dołączona, gdy Gateway będzie gotowy."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เซสชันจะเชื่อมต่อเมื่อ gateway พร้อมใช้งาน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phiên sẽ được đính kèm khi gateway sẵn sàng."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De sessie wordt gekoppeld zodra de Gateway gereed is."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پس از آماده شدن Gateway، نشست متصل می‌شود."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сеанс подключится, когда Gateway будет готов."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessionen ansluter när Gateway är redo."
          }
        }
      }
    },
