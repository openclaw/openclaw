    "Tailscale is off on this device. Turn it on, then try again.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale is off on this device. Turn it on, then try again."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备上的 Tailscale 已关闭。请将其打开，然后重试。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "此裝置上的 Tailscale 已關閉。請將其開啟，然後再試一次。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Tailscale está desativado neste dispositivo. Ative-o e tente novamente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale ist auf diesem Gerät deaktiviert. Aktivieren Sie es und versuchen Sie es dann erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale está desactivado en este dispositivo. Actívalo y vuelve a intentarlo."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスでTailscaleがオフになっています。オンにしてから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서 Tailscale이 꺼져 있습니다. 켠 다음 다시 시도하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale est désactivé sur cet appareil. Activez-le, puis réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस डिवाइस पर Tailscale बंद है। इसे चालू करें, फिर दोबारा कोशिश करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale متوقف على هذا الجهاز. شغّله، ثم حاول مرة أخرى."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale è disattivato su questo dispositivo. Attivalo, quindi riprova."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihazda Tailscale kapalı. Açın, ardından tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale вимкнено на цьому пристрої. Увімкніть його, а потім спробуйте ще раз."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale tidak aktif di perangkat ini. Aktifkan, lalu coba lagi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale jest wyłączony na tym urządzeniu. Włącz go, a następnie spróbuj ponownie."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale ปิดอยู่บนอุปกรณ์นี้ เปิดใช้งานแล้วลองอีกครั้ง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale đang tắt trên thiết bị này. Hãy bật Tailscale rồi thử lại."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale staat uit op dit apparaat. Schakel het in en probeer het opnieuw."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale در این دستگاه خاموش است. آن را روشن کنید، سپس دوباره تلاش کنید."
          }
        },
        "ru": {
