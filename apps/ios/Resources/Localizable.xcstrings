    "Securely connect this iPhone to your gateway.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Securely connect this iPhone to your gateway."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "安全地将此 iPhone 连接到您的 Gateway。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "安全地將此 iPhone 連接到你的 Gateway。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte este iPhone ao seu gateway com segurança."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbinden Sie dieses iPhone sicher mit Ihrer Gateway."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecta de forma segura este iPhone a tu gateway."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "このiPhoneをGatewayに安全に接続します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 iPhone을 Gateway에 안전하게 연결하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez cet iPhone à votre Gateway en toute sécurité."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस iPhone को अपने gateway से सुरक्षित रूप से कनेक्ट करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وصّل هذا الـ iPhone بأمان بالـ gateway الخاص بك."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Connetti in modo sicuro questo iPhone al tuo gateway."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu iPhone'u gateway'inize güvenli bir şekilde bağlayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Безпечно підключіть цей iPhone до вашого Gateway."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hubungkan iPhone ini ke gateway Anda dengan aman."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bezpiecznie połącz tego iPhone’a z gateway."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เชื่อมต่อ iPhone เครื่องนี้กับ Gateway ของคุณอย่างปลอดภัย"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kết nối iPhone này với gateway của bạn một cách an toàn."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbind deze iPhone veilig met je Gateway."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این iPhone را به‌صورت امن به Gateway خود متصل کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Безопасно подключите этот iPhone к вашему Gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Anslut denna iPhone säkert till din gateway."
          }
        }
      }
