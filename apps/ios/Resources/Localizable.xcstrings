    "Foreground location requests are allowed.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Foreground location requests are allowed."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "已允许前台位置请求。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "已允許前景位置請求。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitações de localização em primeiro plano são permitidas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standortanfragen im Vordergrund sind erlaubt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se permiten las solicitudes de ubicación en primer plano."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "フォアグラウンドでの位置情報リクエストが許可されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "포그라운드 위치 요청이 허용됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les demandes de localisation au premier plan sont autorisées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ोरग्राउंड स्थान अनुरोधों की अनुमति है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "طلبات الموقع في المقدمة مسموح بها."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le richieste di posizione in primo piano sono consentite."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ön planda konum isteklerine izin verilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запити геолокації на передньому плані дозволено."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Permintaan lokasi latar depan diizinkan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żądania lokalizacji na pierwszym planie są dozwolone."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตคำขอตำแหน่งที่ตั้งเบื้องหน้าแล้ว"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các yêu cầu vị trí khi ứng dụng ở nền trước được cho phép."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Locatieverzoeken op de voorgrond zijn toegestaan."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "درخواست‌های مکان در پیش‌زمینه مجاز هستند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запросы геопозиции на переднем плане разрешены."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Platsförfrågningar i förgrunden är tillåtna."
          }
        }
      }
    },
    "Foreground location requests are allowed. Precise Location is off.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Foreground location requests are allowed. Precise Location is off."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "已允许前台位置请求。精确位置已关闭。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "已允許前景位置請求。精確位置已關閉。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitações de localização em primeiro plano são permitidas. Localização Precisa está desativada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standortanfragen im Vordergrund sind erlaubt. Genauer Standort ist deaktiviert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se permiten las solicitudes de ubicación en primer plano. La ubicación precisa está desactivada."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "フォアグラウンドでの位置情報リクエストが許可されています。正確な位置情報はオフです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "포그라운드 위치 요청이 허용됩니다. 정확한 위치가 꺼져 있습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les demandes de localisation au premier plan sont autorisées. La position précise est désactivée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ोरग्राउंड स्थान अनुरोधों की अनुमति है। सटीक स्थान बंद है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "طلبات الموقع في المقدمة مسموح بها. الموقع الدقيق متوقف."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le richieste di posizione in primo piano sono consentite. Posizione esatta è disattivata."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ön planda konum isteklerine izin verilir. Kesin Konum kapalı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запити геолокації на передньому плані дозволено. Точну геопозицію вимкнено."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Permintaan lokasi latar depan diizinkan. Lokasi Presisi nonaktif."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żądania lokalizacji na pierwszym planie są dozwolone. Dokładna lokalizacja jest wyłączona."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตคำขอตำแหน่งที่ตั้งเบื้องหน้าแล้ว ตำแหน่งที่ตั้งแม่นยำปิดอยู่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các yêu cầu vị trí khi ứng dụng ở nền trước được cho phép. Vị trí chính xác đang tắt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Locatieverzoeken op de voorgrond zijn toegestaan. Exacte locatie is uitgeschakeld."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "درخواست‌های مکان در پیش‌زمینه مجاز هستند. مکان دقیق خاموش است."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запросы геопозиции на переднем плане разрешены. Точная геопозиция выключена."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Platsförfrågningar i förgrunden är tillåtna. Exakt plats är av."
          }
        }
      }
    },
