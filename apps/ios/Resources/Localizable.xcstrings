    "Camera, microphone, photos, contacts, calendar, and location may be available.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera, microphone, photos, contacts, calendar, and location may be available."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "可能会提供相机、麦克风、照片、联系人、日历和位置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "相機、麥克風、照片、聯絡人、行事曆和位置資訊可能會可供使用。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Câmera, microfone, fotos, contatos, calendário e localização podem estar disponíveis."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera, Mikrofon, Fotos, Kontakte, Kalender und Standort können verfügbar sein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cámara, el micrófono, las fotos, los contactos, el calendario y la ubicación pueden estar disponibles."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラ、マイク、写真、連絡先、カレンダー、位置情報が利用可能になる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카메라, 마이크, 사진, 연락처, 캘린더, 위치를 사용할 수 있게 될 수 있습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’appareil photo, le microphone, les photos, les contacts, le calendrier et la localisation peuvent être disponibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैमरा, माइक्रोफ़ोन, फ़ोटो, संपर्क, कैलेंडर और स्थान उपलब्ध हो सकते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد تتوفر الكاميرا والميكروفون والصور وجهات الاتصال والتقويم والموقع."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotocamera, microfono, foto, contatti, calendario e posizione potrebbero essere disponibili."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera, mikrofon, fotoğraflar, kişiler, takvim ve konum kullanılabilir olabilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Можуть бути доступні камера, мікрофон, фото, контакти, календар і геолокація."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera, mikrofon, foto, kontak, kalender, dan lokasi mungkin tersedia."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostępne mogą być aparat, mikrofon, zdjęcia, kontakty, kalendarz i lokalizacja."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กล้อง ไมโครโฟน รูปภาพ รายชื่อ ปฏิทิน และตำแหน่งที่ตั้งอาจพร้อมใช้งาน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Máy ảnh, micrô, ảnh, danh bạ, lịch và vị trí có thể khả dụng."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera, microfoon, foto's, contacten, agenda en locatie zijn mogelijk beschikbaar."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "دوربین، میکروفون، عکس‌ها، مخاطبان، تقویم و موقعیت مکانی ممکن است در دسترس باشند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Могут быть доступны камера, микрофон, фотографии, контакты, календарь и геопозиция."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera, mikrofon, bilder, kontakter, kalender och plats kan vara tillgängliga."
          }
        }
      }
    },
