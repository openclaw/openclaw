    "Choose when OpenClaw may share this iPhone's location with gateway tools.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose when OpenClaw may share this iPhone's location with gateway tools."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 OpenClaw 何时可以与 gateway 工具共享此 iPhone 的位置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇 OpenClaw 何時可以將此 iPhone 的位置分享給 gateway 工具。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quando o OpenClaw pode compartilhar a localização deste iPhone com as ferramentas do gateway."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, wann OpenClaw den Standort dieses iPhones mit Gateway-Tools teilen darf."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige cuándo OpenClaw puede compartir la ubicación de este iPhone con las herramientas del Gateway."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw がこの iPhone の位置情報を Gateway ツールと共有できるタイミングを選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw가 이 iPhone의 위치를 Gateway 도구와 공유할 시점을 선택하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez quand OpenClaw peut partager la position de cet iPhone avec les outils du Gateway."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि OpenClaw कब इस iPhone का स्थान gateway टूल के साथ साझा कर सकता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر متى يمكن لـ OpenClaw مشاركة موقع هذا الـ iPhone مع أدوات Gateway."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli quando OpenClaw può condividere la posizione di questo iPhone con gli strumenti del gateway."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw'ın bu iPhone'un konumunu gateway araçlarıyla ne zaman paylaşabileceğini seçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Оберіть, коли OpenClaw може ділитися розташуванням цього iPhone з інструментами Gateway."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih kapan OpenClaw boleh membagikan lokasi iPhone ini dengan alat gateway."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz, kiedy OpenClaw może udostępniać lokalizację tego iPhone'a narzędziom Gateway."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกว่าเมื่อใดที่ OpenClaw สามารถแชร์ตำแหน่งของ iPhone เครื่องนี้กับเครื่องมือของ Gateway"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn khi nào OpenClaw có thể chia sẻ vị trí của iPhone này với các công cụ gateway."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies wanneer OpenClaw de locatie van deze iPhone mag delen met gatewaytools."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "انتخاب کنید که چه زمانی OpenClaw می‌تواند موقعیت مکانی این iPhone را با ابزارهای Gateway به اشتراک بگذارد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, когда OpenClaw может передавать местоположение этого iPhone инструментам Gateway."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj när OpenClaw får dela den här iPhonens plats med gateway-verktyg."
          }
        }
      }
    },
