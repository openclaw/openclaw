    "Setup sent. Open OpenClaw on the watch to connect.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Setup sent. Open OpenClaw on the watch to connect."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "设置已发送。在手表上打开 OpenClaw 以连接。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "設定已送出。在手錶上開啟 OpenClaw 以連線。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configuração enviada. Abra o OpenClaw no relógio para conectar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einrichtung gesendet. Öffne OpenClaw auf der Uhr, um die Verbindung herzustellen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configuración enviada. Abre OpenClaw en el reloj para conectar."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "セットアップを送信しました。ウォッチで OpenClaw を開いて接続してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정을 보냈습니다. 워치에서 OpenClaw를 열어 연결하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Configuration envoyée. Ouvrez OpenClaw sur la montre pour vous connecter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेटअप भेजा गया। कनेक्ट करने के लिए watch पर OpenClaw खोलें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إرسال الإعداد. افتح OpenClaw على الساعة للاتصال."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurazione inviata. Apri OpenClaw sull'orologio per connetterti."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurulum gönderildi. Bağlanmak için saatte OpenClaw'ı açın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштування надіслано. Відкрийте OpenClaw на годиннику, щоб підключитися."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Penyiapan terkirim. Buka OpenClaw di jam tangan untuk terhubung."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfiguracja wysłana. Otwórz OpenClaw na zegarku, aby się połączyć."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ส่งการตั้งค่าแล้ว เปิด OpenClaw บนนาฬิกาเพื่อเชื่อมต่อ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã gửi thiết lập. Mở OpenClaw trên đồng hồ để kết nối."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Installatie verzonden. Open OpenClaw op de watch om verbinding te maken."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "راه‌اندازی ارسال شد. برای اتصال، OpenClaw را روی ساعت باز کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройка отправлена. Откройте OpenClaw на часах, чтобы подключиться."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfiguration skickad. Öppna OpenClaw på klockan för att ansluta."
          }
        }
      }
    },
