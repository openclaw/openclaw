    "System follows this device’s appearance setting.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System follows this device’s appearance setting."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "系统遵循此设备的外观设置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "系統會遵循此裝置的外觀設定。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema segue a configuração de aparência deste dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das System folgt der Erscheinungsbild-Einstellung dieses Geräts."
          }
