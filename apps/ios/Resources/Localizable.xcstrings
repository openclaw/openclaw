        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम इस डिवाइस की अपीयरेंस सेटिंग का पालन करता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتبع النظام إعداد مظهر هذا الجهاز."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sistema segue l'impostazione dell'aspetto di questo dispositivo."
          }
        },
