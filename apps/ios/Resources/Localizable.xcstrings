    "Direct mode supports device info, status, and notifications. Chat, Talk, and approvals still use the iPhone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Direct mode supports device info, status, and notifications. Chat, Talk, and approvals still use the iPhone."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "直连模式支持设备信息、状态和通知。聊天、通话和审批仍使用 iPhone。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "直接模式支援裝置資訊、狀態與通知。聊天、語音與核准仍使用 iPhone。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo direto oferece suporte a informações do dispositivo, status e notificações. Chat, Talk e aprovações continuam usando o iPhone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Direktmodus unterstützt Geräteinfos, Status und Benachrichtigungen. Chat, Talk und Genehmigungen verwenden weiterhin das iPhone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo directo admite información del dispositivo, estado y notificaciones. Chat, Talk y las aprobaciones siguen usando el iPhone."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "直接モードはデバイス情報、ステータス、通知に対応しています。チャット、Talk、承認は引き続き iPhone を使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "직접 모드는 기기 정보, 상태, 알림을 지원합니다. 채팅, Talk, 승인은 여전히 iPhone을 사용합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode direct prend en charge les infos sur l'appareil, l'état et les notifications. Chat, Talk et les approbations utilisent toujours l'iPhone."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सीधा मोड डिवाइस जानकारी, स्थिति और सूचनाओं का समर्थन करता है। चैट, टॉक और अनुमोदन अभी भी iPhone का उपयोग करते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يدعم الوضع المباشر معلومات الجهاز والحالة والإشعارات. لا تزال المحادثة والتحدث والموافقات تستخدم iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La modalità diretta supporta informazioni sul dispositivo, stato e notifiche. Chat, Talk e approvazioni usano ancora l'iPhone."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğrudan mod cihaz bilgisini, durumu ve bildirimleri destekler. Sohbet, Konuşma ve onaylar hâlâ iPhone'u kullanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Прямий режим підтримує інформацію про пристрій, статус і сповіщення. Чат, Talk та підтвердження, як і раніше, використовують iPhone."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode langsung mendukung info perangkat, status, dan notifikasi. Chat, Talk, dan persetujuan masih menggunakan iPhone."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryb bezpośredni obsługuje informacje o urządzeniu, status i powiadomienia. Czat, Talk i zatwierdzenia nadal korzystają z iPhone'a."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โหมดโดยตรงรองรับข้อมูลอุปกรณ์ สถานะ และการแจ้งเตือน ส่วน Chat, Talk และการอนุมัติยังคงใช้ iPhone"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chế độ trực tiếp hỗ trợ thông tin thiết bị, trạng thái và thông báo. Chat, Talk và phê duyệt vẫn dùng iPhone."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Directe modus ondersteunt apparaatinfo, status en meldingen. Chat, Talk en goedkeuringen gebruiken nog steeds de iPhone."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "حالت مستقیم از اطلاعات دستگاه، وضعیت و اعلان‌ها پشتیبانی می‌کند. چت، صحبت و تأییدها همچنان از iPhone استفاده می‌کنند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прямой режим поддерживает информацию об устройстве, статус и уведомления. Чат, Talk и подтверждения по-прежнему используют iPhone."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Direktläge stöder enhetsinformation, status och notiser. Chatt, Tal och godkännanden använder fortfarande iPhone."
          }
        }
      }
    },
