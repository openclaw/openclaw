          "stringUnit": {
            "state": "translated",
            "value": "マイクへのアクセスが必要です。設定で有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마이크 접근 권한이 필요합니다. 설정에서 활성화하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au microphone est requis. Activez-le dans Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफ़ोन एक्सेस आवश्यक है। इसे Settings में सक्षम करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوصول إلى الميكروفون مطلوب. فعّله في الإعدادات."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È necessario l'accesso al microfono. Abilitalo nelle Impostazioni."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofon erişimi gereklidir. Ayarlar'dan etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Потрібен доступ до мікрофона. Увімкніть його в Налаштуваннях."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses mikrofon diperlukan. Aktifkan di Pengaturan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wymagany jest dostęp do mikrofonu. Włącz go w Ustawieniach."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จำเป็นต้องเข้าถึงไมโครโฟน เปิดใช้งานได้ในการตั้งค่า"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cần quyền truy cập micrô. Bật quyền đó trong Cài đặt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Microfoontoegang is vereist. Schakel dit in via Instellingen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "دسترسی به میکروفون لازم است. آن را در تنظیمات فعال کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Требуется доступ к микрофону. Включите его в настройках."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofonåtkomst krävs. Aktivera den i Inställningar."
          }
        }
      }
    },
