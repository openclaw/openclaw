        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone 설정에서 직접 연결을 활성화하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez les réglages de l'iPhone pour activer la connexion directe."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सीधा कनेक्शन सक्षम करने के लिए iPhone सेटिंग्स का उपयोग करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم إعدادات iPhone لتفعيل الاتصال المباشر."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa le Impostazioni di iPhone per abilitare la connessione diretta."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğrudan bağlantıyı etkinleştirmek için iPhone Ayarları'nı kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Скористайтеся Налаштуваннями iPhone, щоб увімкнути пряме з’єднання."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan Pengaturan iPhone untuk mengaktifkan koneksi langsung."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj Ustawień iPhone'a, aby włączyć połączenie bezpośrednie."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้การตั้งค่า iPhone เพื่อเปิดใช้งานการเชื่อมต่อโดยตรง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dùng Cài đặt iPhone để bật kết nối trực tiếp."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik iPhone-instellingen om directe verbinding in te schakelen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای فعال کردن اتصال مستقیم از تنظیمات iPhone استفاده کنید."
          }
        },
        "ru": {
          "stringUnit": {
