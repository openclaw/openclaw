    "Open Settings if you need a manual host.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Settings if you need a manual host."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "如果需要手动指定主机，请打开“设置”。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "如果需要手動主機，請開啟「設定」。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra os Ajustes se precisar de um host manual."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnen Sie die Einstellungen, wenn Sie einen manuellen Host benötigen."
          }
