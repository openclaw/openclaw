    "Enable Gateway TLS, or enter your Tailscale Serve HTTPS host in Manual Setup. Use Unencrypted only with a trusted private-LAN address.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Gateway TLS, or enter your Tailscale Serve HTTPS host in Manual Setup. Use Unencrypted only with a trusted private-LAN address."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "启用 Gateway TLS，或在手动设置中输入您的 Tailscale Serve HTTPS 主机。仅在受信任的专用局域网地址上使用未加密连接。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用 Gateway TLS，或在手動設定中輸入你的 Tailscale Serve HTTPS 主機。僅在受信任的私人區網位址下使用未加密連線。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative o TLS do Gateway ou informe seu host HTTPS do Tailscale Serve na Configuração Manual. Use Não criptografado apenas com um endereço de LAN privada confiável."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie Gateway-TLS oder geben Sie Ihren Tailscale Serve HTTPS-Host in der manuellen Einrichtung ein. Verwenden Sie „Unverschlüsselt“ nur mit einer vertrauenswürdigen Adresse im privaten LAN."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilita el TLS del Gateway o introduce tu host HTTPS de Tailscale Serve en Configuración manual. Usa Sin cifrar solo con una dirección de LAN privada de confianza."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway の TLS を有効にするか、手動セットアップで Tailscale Serve の HTTPS ホストを入力してください。信頼できるプライベート LAN アドレスの場合にのみ暗号化なしを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway TLS를 활성화하거나 수동 설정에서 Tailscale Serve HTTPS 호스트를 입력하세요. 암호화되지 않음은 신뢰할 수 있는 사설 LAN 주소에서만 사용하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez le TLS de la Gateway, ou saisissez votre hôte HTTPS Tailscale Serve dans la Configuration manuelle. N'utilisez Non chiffré qu'avec une adresse LAN privée de confiance."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway TLS सक्षम करें, या Manual Setup में अपना Tailscale Serve HTTPS होस्ट दर्ज करें। Unencrypted का उपयोग केवल किसी विश्वसनीय निजी-LAN पते के साथ करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فعّل TLS الخاص بـ Gateway، أو أدخل مضيف HTTPS الخاص بـ Tailscale Serve في الإعداد اليدوي. استخدم غير المشفّر فقط مع عنوان شبكة محلية خاصة موثوق."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita il TLS del Gateway o inserisci l'host HTTPS di Tailscale Serve in Configurazione manuale. Usa Non crittografato solo con un indirizzo LAN privato attendibile."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway TLS'yi etkinleştirin veya Manuel Kurulum'da Tailscale Serve HTTPS ana bilgisayarınızı girin. Şifresiz seçeneğini yalnızca güvenilir bir özel LAN adresiyle kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увімкніть TLS для Gateway або введіть свій хост Tailscale Serve HTTPS у розділі «Ручне налаштування». Використовуйте нешифроване з'єднання лише з надійною адресою приватної локальної мережі."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan TLS Gateway, atau masukkan host HTTPS Tailscale Serve Anda di Manual Setup. Gunakan Unencrypted hanya dengan alamat private-LAN yang tepercaya."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz TLS Gateway lub podaj swój host HTTPS Tailscale Serve w konfiguracji ręcznej. Używaj opcji Niezaszyfrowane tylko z zaufanym adresem prywatnej sieci LAN."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดใช้งาน Gateway TLS หรือกรอกโฮสต์ HTTPS ของ Tailscale Serve ใน Manual Setup ใช้ Unencrypted เฉพาะกับที่อยู่ private-LAN ที่เชื่อถือได้เท่านั้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bật Gateway TLS, hoặc nhập máy chủ HTTPS Tailscale Serve của bạn trong Thiết lập thủ công. Chỉ sử dụng Không mã hóa với địa chỉ LAN riêng đáng tin cậy."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel Gateway TLS in, of voer je Tailscale Serve HTTPS-host in bij Handmatige installatie. Gebruik Onversleuteld alleen met een vertrouwd privé-LAN-adres."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "TLS مربوط به Gateway را فعال کنید، یا میزبان HTTPS مربوط به Tailscale Serve خود را در راه‌اندازی دستی وارد کنید. از حالت رمزنگاری‌نشده فقط با یک آدرس مورد اعتماد در شبکه محلی خصوصی استفاده کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите TLS для Gateway или укажите ваш HTTPS-хост Tailscale Serve в разделе «Ручная настройка». Используйте незашифрованное соединение только с доверенным адресом в частной локальной сети."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivera Gateway-TLS, eller ange din Tailscale Serve HTTPS-värd i Manuell konfiguration. Använd endast okrypterat med en betrodd privat LAN-adress."
          }
        }
      }
    },
    "Enable Notifications to receive approval alerts while OpenClaw is not open.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Notifications to receive approval alerts while OpenClaw is not open."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "启用通知，以便在 OpenClaw 未打开时接收审批提醒。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用通知，以便在 OpenClaw 未開啟時接收核准提醒。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative as notificações para receber alertas de aprovação enquanto o OpenClaw não estiver aberto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere Benachrichtigungen, um Genehmigungswarnungen zu erhalten, während OpenClaw nicht geöffnet ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa las notificaciones para recibir alertas de aprobación mientras OpenClaw no esté abierto."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw が開いていないときに承認アラートを受け取るには、通知を有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw가 열려 있지 않을 때 승인 알림을 받으려면 알림을 활성화하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez les notifications pour recevoir des alertes d’approbation lorsque OpenClaw n’est pas ouvert."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw खुला न होने पर अनुमोदन अलर्ट प्राप्त करने के लिए सूचनाएं सक्षम करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فعّل الإشعارات لتلقي تنبيهات الموافقة عندما لا يكون OpenClaw مفتوحًا."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita le notifiche per ricevere avvisi di approvazione mentre OpenClaw non è aperto."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "OpenClaw açık değilken onay uyarıları almak için Bildirimler’i etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увімкніть сповіщення, щоб отримувати запити на схвалення, коли OpenClaw не відкрито."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan Notifikasi untuk menerima peringatan persetujuan saat OpenClaw tidak terbuka."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz powiadomienia, aby otrzymywać alerty o zatwierdzeniu, gdy OpenClaw nie jest otwarty."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดใช้งานการแจ้งเตือนเพื่อรับการแจ้งเตือนการอนุมัติขณะที่ OpenClaw ไม่ได้เปิดอยู่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bật Thông báo để nhận cảnh báo phê duyệt khi OpenClaw không mở."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel meldingen in om goedkeuringsmeldingen te ontvangen wanneer OpenClaw niet geopend is."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای دریافت هشدارهای تأیید هنگامی که OpenClaw باز نیست، اعلان‌ها را فعال کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите уведомления, чтобы получать оповещения о подтверждении, когда OpenClaw не открыт."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivera aviseringar för att få godkännandeaviseringar när OpenClaw inte är öppet."
          }
        }
      }
    },
    "Enable notifications to receive approval prompts and event alerts outside the app.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable notifications to receive approval prompts and event alerts outside the app."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "启用通知，以便在应用外接收审批提示和事件提醒。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用通知，以便在應用程式之外接收核准提示與事件警示。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative as notificações para receber solicitações de aprovação e alertas de eventos fora do app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere Benachrichtigungen, um Genehmigungsanfragen und Ereignisbenachrichtigungen außerhalb der App zu erhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa las notificaciones para recibir solicitudes de aprobación y alertas de eventos fuera de la aplicación."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリ外で承認プロンプトやイベントアラートを受け取るには通知を有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 외부에서 승인 요청과 이벤트 알림을 받으려면 알림을 활성화하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez les notifications pour recevoir les demandes d'approbation et les alertes d'événements en dehors de l'application."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप के बाहर स्वीकृति संकेत और इवेंट अलर्ट प्राप्त करने के लिए सूचनाएँ सक्षम करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فعّل الإشعارات لتلقي مطالبات الموافقة وتنبيهات الأحداث خارج التطبيق."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita le notifiche per ricevere richieste di approvazione e avvisi di eventi fuori dall'app."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulama dışında onay istemleri ve olay uyarıları almak için bildirimleri etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увімкніть сповіщення, щоб отримувати запити на підтвердження та сповіщення про події поза застосунком."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan notifikasi untuk menerima permintaan persetujuan dan peringatan peristiwa di luar aplikasi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz powiadomienia, aby otrzymywać monity o zatwierdzenie i alerty o zdarzeniach poza aplikacją."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดใช้งานการแจ้งเตือนเพื่อรับคำขออนุมัติและการแจ้งเตือนเหตุการณ์นอกแอป"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bật thông báo để nhận lời nhắc phê duyệt và cảnh báo sự kiện bên ngoài ứng dụng."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel meldingen in om goedkeuringsvragen en gebeurtenismeldingen buiten de app te ontvangen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "اعلان‌ها را فعال کنید تا درخواست‌های تأیید و هشدارهای رویداد را خارج از برنامه دریافت کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите уведомления, чтобы получать запросы на подтверждение и оповещения о событиях вне приложения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivera aviseringar för att få godkännandeförfrågningar och händelseaviseringar utanför appen."
          }
        }
      }
    },
