    "Cards moved into this lane appear here.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cards moved into this lane appear here."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "移入此泳道的卡片会显示在这里。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "移入此欄的卡片會顯示在這裡。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os cartões movidos para esta raia aparecem aqui."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In diese Lane verschobene Karten werden hier angezeigt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tarjetas movidas a este carril aparecen aquí."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "このレーンに移動されたカードがここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 레인으로 이동된 카드가 여기에 표시됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les cartes déplacées dans cette colonne apparaissent ici."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस लेन में ले जाए गए कार्ड यहां दिखाई देते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر هنا البطاقات التي تم نقلها إلى هذا المسار."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le schede spostate in questa corsia vengono visualizzate qui."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu kulvara taşınan kartlar burada görünür."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Картки, переміщені в цю смугу, з’являться тут."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kartu yang dipindahkan ke lajur ini muncul di sini."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Karty przeniesione do tej kolumny pojawią się tutaj."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การ์ดที่ถูกย้ายมายังเลนนี้จะปรากฏที่นี่"
          }
        },
        "vi": {
          "stringUnit": {
