    "Fetching installed channels, accounts, and routing status from the gateway.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetching installed channels, accounts, and routing status from the gateway."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "正在从 Gateway 获取已安装的渠道、账户和路由状态。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "正在從 Gateway 擷取已安裝的頻道、帳戶和路由狀態。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscando canais instalados, contas e status de roteamento no gateway."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installierte Kanäle, Konten und Routing-Status werden von der Gateway abgerufen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obteniendo canales instalados, cuentas y estado de enrutamiento desde el Gateway."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "インストール済みのチャネル、アカウント、ルーティング状態をGatewayから取得しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway에서 설치된 채널, 계정 및 라우팅 상태를 가져오는 중입니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récupération des canaux installés, des comptes et de l’état du routage depuis le Gateway."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway से इंस्टॉल किए गए चैनल, खाते और रूटिंग स्थिति प्राप्त की जा रही है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جارٍ جلب القنوات والحسابات وحالة التوجيه المثبّتة من Gateway."
          }
        },
        "it": {
