    "New proposals will appear here when agents draft skills.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New proposals will appear here when agents draft skills."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "当 Agent 草拟 Skills 时，新提案将显示在此处。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "當 agents 起草 skills 時，新的提案會顯示在這裡。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Novas propostas aparecerão aqui quando os agentes criarem rascunhos de skills."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Neue Vorschläge werden hier angezeigt, wenn Agenten Skills entwerfen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las nuevas propuestas aparecerán aquí cuando los agentes redacten skills."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントが Skills を下書きすると、新しい提案がここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 스킬 초안을 작성하면 새 제안이 여기에 표시됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les nouvelles propositions apparaîtront ici lorsque les agents rédigeront des skills."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब एजेंट Skills का ड्राफ़्ट बनाएंगे, तो नए प्रस्ताव यहाँ दिखाई देंगे."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستظهر المقترحات الجديدة هنا عندما تقوم الوكلاء بصياغة المهارات."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nuove proposte appariranno qui quando gli agenti creeranno bozze di skill."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aracılar skill taslakları oluşturduğunda yeni teklifler burada görünür."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Нові пропозиції з’являться тут, коли агенти створять чернетки Skills."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Proposal baru akan muncul di sini saat agen menyusun skill."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nowe propozycje pojawią się tutaj, gdy agenci opracują skills."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ข้อเสนอใหม่จะแสดงที่นี่เมื่อ Agent ร่าง Skills"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các đề xuất mới sẽ xuất hiện tại đây khi tác nhân soạn thảo kỹ năng."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nieuwe voorstellen verschijnen hier wanneer agents skills opstellen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "وقتی عامل‌ها مهارت‌ها را پیش‌نویس کنند، پیشنهادهای جدید اینجا ظاهر می‌شوند."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Новые предложения появятся здесь, когда агенты подготовят Skills."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nya förslag visas här när agenter utformar skills."
          }
        }
      }
    },
