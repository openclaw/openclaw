    "iOS currently allows location only while using the app.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS currently allows location only while using the app."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 当前仅允许在使用应用时获取位置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 目前僅允許在使用應用程式時取得位置。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualmente o iOS permite a localização apenas ao usar o app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS erlaubt den Standort derzeit nur während der Nutzung der App."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualmente iOS permite la ubicación solo mientras se usa la app."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "現在 iOS はアプリ使用中のみ位置情報を許可しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 iOS는 앱 사용 중에만 위치를 허용합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS autorise actuellement la localisation uniquement lors de l'utilisation de l'app."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS वर्तमान में केवल ऐप उपयोग करते समय स्थान की अनुमति देता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسمح iOS حاليًا بالموقع فقط أثناء استخدام التطبيق."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attualmente iOS consente la posizione solo durante l'uso dell'app."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS şu anda konuma yalnızca uygulama kullanılırken izin veriyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Наразі iOS дозволяє геолокацію лише під час використання застосунку."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS saat ini hanya mengizinkan lokasi saat menggunakan aplikasi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS obecnie zezwala na lokalizację tylko podczas korzystania z aplikacji."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ขณะนี้ iOS อนุญาตตำแหน่งที่ตั้งเฉพาะขณะใช้งานแอปเท่านั้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS hiện chỉ cho phép vị trí khi đang sử dụng ứng dụng."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS staat locatie momenteel alleen toe tijdens gebruik van de app."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS در حال حاضر موقعیت مکانی را فقط هنگام استفاده از برنامه اجازه می‌دهد."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сейчас iOS разрешает доступ к местоположению только во время использования приложения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS tillåter för närvarande plats endast medan appen används."
          }
        }
      }
    },
    "iOS permission is required to share location.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS permission is required to share location."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "共享位置需要 iOS 权限。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "分享位置需要 iOS 權限。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A permissão do iOS é necessária para compartilhar a localização."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zum Teilen des Standorts ist eine iOS-Berechtigung erforderlich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se requiere permiso de iOS para compartir la ubicación."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報を共有するには iOS の許可が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위치를 공유하려면 iOS 권한이 필요합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'autorisation iOS est requise pour partager la localisation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थान साझा करने के लिए iOS अनुमति आवश्यक है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلزم إذن iOS لمشاركة الموقع."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È richiesta l'autorizzazione di iOS per condividere la posizione."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konum paylaşmak için iOS izni gerekli."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Для надання доступу до геолокації потрібен дозвіл iOS."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Izin iOS diperlukan untuk membagikan lokasi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Do udostępniania lokalizacji wymagane jest uprawnienie iOS."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ต้องได้รับอนุญาตจาก iOS เพื่อแชร์ตำแหน่งที่ตั้ง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cần quyền iOS để chia sẻ vị trí."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS-toestemming is vereist om locatie te delen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای اشتراک‌گذاری موقعیت مکانی، مجوز iOS لازم است."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для передачи местоположения требуется разрешение iOS."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS-behörighet krävs för att dela plats."
          }
        }
      }
    },
