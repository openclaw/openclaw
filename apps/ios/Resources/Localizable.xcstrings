    "List and read calendar events.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "List and read calendar events."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "列出并读取日历事件。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "列出並讀取行事曆事件。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Liste e leia eventos do calendário."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalenderereignisse auflisten und lesen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enumera y lee eventos del calendario."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーイベントを一覧表示して読み取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 이벤트를 나열하고 읽습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lister et lire les événements du calendrier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैलेंडर इवेंट की सूची देखें और उन्हें पढ़ें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سرد أحداث التقويم وقراءتها."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elenca e leggi gli eventi del calendario."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Takvim etkinliklerini listeleyin ve okuyun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Переглядайте список і читайте події календаря."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cantumkan dan baca acara kalender."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyświetlaj listę wydarzeń z kalendarza i odczytuj je."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แสดงรายการและอ่านกิจกรรมในปฏิทิน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Liệt kê và đọc sự kiện trên lịch."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geef agendagebeurtenissen weer en lees ze."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "رویدادهای تقویم را فهرست و مطالعه کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просматривайте список событий календаря и читайте их."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lista och läs kalenderhändelser."
          }
        }
      }
    },
    "List, add, and complete reminders.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "List, add, and complete reminders."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "列出、添加和完成提醒事项。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "列出、新增並完成提醒事項。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Liste, adicione e conclua lembretes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erinnerungen auflisten, hinzufügen und abschließen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enumera, añade y completa recordatorios."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "リマインダーを一覧表示、追加、完了します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미리 알림을 나열하고, 추가하고, 완료 처리합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lister, ajouter et terminer des rappels."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिमाइंडर की सूची देखें, जोड़ें और पूरा करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسرد التذكيرات وأضِفها وأكملها."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elenca, aggiungi e completa promemoria."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Anımsatıcıları listeleyin, ekleyin ve tamamlayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Переглядайте список, додавайте й позначайте нагадування як виконані."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cantumkan, tambahkan, dan selesaikan pengingat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyświetlaj listę przypomnień, dodawaj je i oznaczaj jako wykonane."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แสดงรายการ เพิ่ม และทำรายการเตือนความจำให้เสร็จสิ้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Liệt kê, thêm và hoàn tất lời nhắc."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geef herinneringen weer, voeg ze toe en voltooi ze."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "یادآورها را فهرست، اضافه و کامل کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просматривайте список напоминаний, добавляйте и отмечайте их как выполненные."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lista, lägg till och slutför påminnelser."
          }
        }
      }
    },
