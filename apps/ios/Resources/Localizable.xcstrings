    "Install the OpenClaw watch app before enabling direct mode.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install the OpenClaw watch app before enabling direct mode."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "在启用直连模式前，请安装 OpenClaw 手表应用。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "在啟用直連模式前，請先安裝 OpenClaw 手錶 App。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale o app do OpenClaw para o relógio antes de ativar o modo direto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installiere die OpenClaw-Watch-App, bevor du den Direktmodus aktivierst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala la app de OpenClaw para el reloj antes de habilitar el modo directo."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "ダイレクトモードを有効にする前に OpenClaw ウォッチアプリをインストールしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "직접 모드를 사용하기 전에 OpenClaw 워치 앱을 설치하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez l'app OpenClaw pour la montre avant d'activer le mode direct."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डायरेक्ट मोड सक्षम करने से पहले OpenClaw watch ऐप इंस्टॉल करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ثبّت تطبيق OpenClaw للساعة قبل تمكين الوضع المباشر."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installa l'app OpenClaw per l'orologio prima di abilitare la modalità diretta."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğrudan modu etkinleştirmeden önce OpenClaw saat uygulamasını yükleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Встановіть застосунок OpenClaw для годинника, перш ніж вмикати прямий режим."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Instal aplikasi jam tangan OpenClaw sebelum mengaktifkan mode langsung."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zainstaluj aplikację OpenClaw na zegarku przed włączeniem trybu bezpośredniego."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ติดตั้งแอป OpenClaw บนนาฬิกาก่อนเปิดใช้งานโหมดตรง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cài đặt ứng dụng OpenClaw cho đồng hồ trước khi bật chế độ trực tiếp."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Installeer de OpenClaw watch-app voordat je directe modus inschakelt."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پیش از فعال‌سازی حالت مستقیم، برنامه ساعت OpenClaw را نصب کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите приложение OpenClaw для часов перед включением прямого режима."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Installera OpenClaw-klockappen innan du aktiverar direktläge."
          }
        }
      }
    },
