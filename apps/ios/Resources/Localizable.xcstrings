    "Return to the queue and choose another proposal.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Return to the queue and choose another proposal."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "返回队列并选择其他提案。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "返回佇列並選擇另一個提案。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Volte para a fila e escolha outra proposta."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zur Warteschlange zurückkehren und einen anderen Vorschlag auswählen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelve a la cola y elige otra propuesta."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "キューに戻り、別の提案を選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대기열로 돌아가 다른 제안을 선택하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Retournez à la file d’attente et choisissez une autre proposition."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कतार में वापस जाएँ और कोई दूसरा प्रस्ताव चुनें."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ارجع إلى قائمة الانتظار واختر مقترحًا آخر."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Torna alla coda e scegli un'altra proposta."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuyruğa dönün ve başka bir teklif seçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Поверніться до черги та виберіть іншу пропозицію."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kembali ke antrean dan pilih proposal lain."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wróć do kolejki i wybierz inną propozycję."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
