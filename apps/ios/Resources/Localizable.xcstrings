    "Refreshing connection, discovery, and device trust state.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refreshing connection, discovery, and device trust state."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "正在刷新连接、发现和设备信任状态。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "正在重新整理連線、探索和裝置信任狀態。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualizando conexão, descoberta e estado de confiança do dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindung, Erkennung und Vertrauensstatus des Geräts werden aktualisiert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualizando la conexión, la detección y el estado de confianza del dispositivo."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "接続、検出、デバイスの信頼状態を更新しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연결, 검색 및 기기 신뢰 상태를 새로 고치는 중입니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualisation de la connexion, de la découverte et de l’état de confiance de l’appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कनेक्शन, डिस्कवरी, और डिवाइस ट्रस्ट स्थिति रीफ़्रेश की जा रही है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جارٍ تحديث الاتصال والاكتشاف وحالة موثوقية الجهاز."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiornamento dello stato di connessione, rilevamento e attendibilità del dispositivo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bağlantı, keşif ve cihaz güven durumu yenileniyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Оновлення стану підключення, виявлення та довіри до пристрою."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyegarkan koneksi, penemuan, dan status kepercayaan perangkat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odświeżanie stanu połączenia, wykrywania i zaufania urządzenia."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กำลังรีเฟรชสถานะการเชื่อมต่อ การค้นหา และความเชื่อถือของอุปกรณ์"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đang làm mới trạng thái kết nối, khám phá và tin cậy thiết bị."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindings-, detectie- en apparaatvertrouwensstatus vernieuwen."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "در حال تازه‌سازی اتصال، شناسایی، و وضعیت اعتماد دستگاه."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновление подключения, обнаружения и состояния доверия устройства."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Uppdaterar anslutning, identifiering och enhetens förtroendestatus."
          }
        }
      }
    },
