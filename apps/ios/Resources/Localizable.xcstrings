    "No gateways found yet. Use manual setup if Bonjour is blocked.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No gateways found yet. Use manual setup if Bonjour is blocked."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "尚未找到 Gateway。如果 Bonjour 被阻止，请使用手动设置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
