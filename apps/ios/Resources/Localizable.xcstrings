          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Manuel ana bilgisayar gerekiyorsa Ayarlar’ı açın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відкрийте Налаштування, якщо потрібно вказати хост вручну."
          }
        },
        "id": {
          "stringUnit": {
