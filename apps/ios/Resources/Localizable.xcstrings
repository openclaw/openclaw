    "Dreaming has not promoted durable memory entries yet.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming has not promoted durable memory entries yet."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming 尚未提升任何持久记忆条目。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming 尚未提升任何持久記憶項目。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming ainda não promoveu entradas de memória durável."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming hat noch keine dauerhaften Speichereinträge hervorgehoben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming aún no ha promocionado entradas de memoria duradera."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming はまだ永続メモリエントリを昇格していません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming에서 아직 내구성 메모리 항목을 승격하지 않았습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming n’a pas encore promu d’entrées de mémoire durable."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming ने अभी तक टिकाऊ मेमोरी प्रविष्टियों को प्रमोट नहीं किया है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يقم Dreaming بترقية أي إدخالات ذاكرة دائمة بعد."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sogno non ha ancora promosso voci di memoria durevole."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming henüz kalıcı bellek girdilerini öne çıkarmadı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming ще не просунув записи довготривалої пам’яті."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming belum mempromosikan entri memori tahan lama."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming nie wypromowało jeszcze trwałych wpisów pamięci."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming ยังไม่ได้โปรโมตรายการหน่วยความจำถาวร"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming chưa quảng bá mục bộ nhớ bền vững nào."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming heeft nog geen duurzame geheugenitems gepromoot."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "رؤیاپردازی هنوز هیچ ورودی حافظهٔ پایدار را ارتقا نداده است."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming пока не продвинул записи долговременной памяти."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreaming har inte framhävt några varaktiga minnesposter än."
          }
        }
      }
