          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway, etkin ajan çalışma alanında DREAMS.md veya dreams.md bulamadı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Gateway не знайшов DREAMS.md або dreams.md в активному робочому просторі агента."
          }
        },
        "id": {
          "stringUnit": {
