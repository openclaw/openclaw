    "Run app, permission, and gateway-adjacent checks without editing setup.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Run app, permission, and gateway-adjacent checks without editing setup."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "运行应用、权限以及 Gateway 相关检查，而不编辑设置。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "在不編輯設定的情況下執行 App、權限與 Gateway 相關檢查。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Execute verificações do app, de permissões e relacionadas ao gateway sem editar a configuração."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "App-, Berechtigungs- und Gateway-nahe Prüfungen ausführen, ohne die Einrichtung zu bearbeiten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta comprobaciones de la app, permisos y aspectos relacionados con Gateway sin editar la configuración."
          }
        },
        "ja-JP": {
          "stringUnit": {
            "state": "translated",
            "value": "設定を編集せずに、アプリ、権限、Gateway関連のチェックを実行します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정을 편집하지 않고 앱, 권한 및 게이트웨이 관련 검사를 실행합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exécutez des vérifications de l’app, des autorisations et liées à la Gateway sans modifier la configuration."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेटअप संपादित किए बिना ऐप, अनुमति, और Gateway-संबंधित जाँचें चलाएँ।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تشغيل فحوصات التطبيق والأذونات وما يتعلق بـ Gateway دون تعديل الإعداد."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esegui controlli dell'app, delle autorizzazioni e relativi al gateway senza modificare la configurazione."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurulumu düzenlemeden uygulama, izin ve Gateway bağlantılı kontrolleri çalıştırın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запустіть перевірки застосунку, дозволів і пов’язані з Gateway перевірки без редагування налаштування."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jalankan pemeriksaan aplikasi, izin, dan yang terkait gateway tanpa mengedit penyiapan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uruchom kontrole aplikacji, uprawnień i elementów powiązanych z Gateway bez edytowania konfiguracji."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เรียกใช้การตรวจสอบแอป สิทธิ์ และส่วนที่เกี่ยวข้องกับ Gateway โดยไม่แก้ไขการตั้งค่า"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chạy kiểm tra ứng dụng, quyền và các mục liên quan đến gateway mà không chỉnh sửa thiết lập."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voer app-, toestemmings- en Gateway-gerelateerde controles uit zonder de configuratie te bewerken."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "بررسی‌های برنامه، مجوز و موارد مرتبط با Gateway را بدون ویرایش راه‌اندازی اجرا کنید."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выполните проверки приложения, разрешений и компонентов, связанных с Gateway, без изменения настроек."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kör kontroller av appen, behörigheter och gateway-nära funktioner utan att ändra konfigurationen."
          }
        }
      }
    },
