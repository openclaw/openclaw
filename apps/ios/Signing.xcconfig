// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

MULLUSI_CODE_SIGN_STYLE = Manual
MULLUSI_DEVELOPMENT_TEAM = Y5PE65HELJ

MULLUSI_APP_BUNDLE_ID = ai.mullusi.client
MULLUSI_SHARE_BUNDLE_ID = ai.mullusi.client.share
MULLUSI_WATCH_APP_BUNDLE_ID = ai.mullusi.client.watchkitapp
MULLUSI_WATCH_EXTENSION_BUNDLE_ID = ai.mullusi.client.watchkitapp.extension
MULLUSI_ACTIVITY_WIDGET_BUNDLE_ID = ai.mullusi.client.activitywidget

MULLUSI_APP_PROFILE = ai.mullusi.client Development
MULLUSI_SHARE_PROFILE = ai.mullusi.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
