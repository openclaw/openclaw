# Database
DATABASE_URL="postgresql://user:password@localhost:5432/openclaw_web"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe plan price IDs (monthly)
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_GROWTH_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# Stripe plan price IDs (yearly)
STRIPE_STARTER_YEARLY_PRICE_ID="price_..."
STRIPE_GROWTH_YEARLY_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."

# Stripe usage-based billing (metered)
STRIPE_USAGE_PRICE_ID="price_..."

# Gateway
GATEWAY_URL="http://localhost:18789"
GATEWAY_TOKEN=""

# Platform AI keys (used for paid-plan users when no BYOK key is set)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Admin
ADMIN_SECRET=""
