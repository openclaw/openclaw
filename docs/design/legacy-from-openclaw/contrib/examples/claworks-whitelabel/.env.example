# Copy to .env and fill before render-nginx.sh / docker compose.

# Public HTTPS hostname (no scheme), e.g. ai.example.com
PUBLIC_HOST=ai.example.com

# Upstreams (bare metal: loopback; Docker: service names — see docker-compose.yml)
OPENCLAW_UPSTREAM=127.0.0.1:18789
CLAWORKS_UPSTREAM=127.0.0.1:8000

# TLS (Let's Encrypt paths or your corporate cert)
TLS_CERT_PATH=/etc/ssl/certs/claworks/fullchain.pem
TLS_KEY_PATH=/etc/ssl/private/claworks/privkey.pem

# Built ClaWorks Studio static files (index.html + assets)
STUDIO_STATIC_ROOT=/var/www/claworks-studio

# Operator console is NOT exposed via public HTTPS.
# Access via SSH tunnel: ssh -L 18789:127.0.0.1:18789 user@host
# then open: http://localhost:18789/cw-admin/

# Agent runtime token (generate: openclaw gateway token --state-dir ~/.claworks)
OPENCLAW_GATEWAY_TOKEN=generate-with-openclaw-doctor-or-onboard
OPENCLAW_DISABLE_BONJOUR=1

# ── Identity hiding ──────────────────────────────────────────────────────────
# State/config under .claworks — hides runtime namespace from lsof/proc
CLAWORKS_CONFIG_DIR=${HOME}/.claworks
CLAWORKS_WORKSPACE_DIR=${HOME}/.claworks/workspace

# Process title in ps/top/htop inside the container
NODE_OPTIONS=--title=claworks-agent

# OpenTelemetry service name sent to observability backends (Datadog, Grafana…)
# Also set in claworks.json diagnostics.otel.serviceName; both are applied.
OTEL_SERVICE_NAME=ClaWorks
OTEL_RESOURCE_ATTRIBUTES=service.name=ClaWorks,service.namespace=claworks

# Docker image tag — neutral name so docker ps doesn't expose upstream image name
AGENT_RUNTIME_IMAGE=claworks-agent:local

# ── LLM outbound attribution white-label ─────────────────────────────────────
# Product name in LLM provider attribution headers (X-OpenRouter-Title, product, etc.)
OPENCLAW_ATTRIBUTION_PRODUCT_OVERRIDE=ClaWorks
# Originator slug in User-Agent / originator headers to OpenAI-family endpoints
OPENCLAW_ATTRIBUTION_ORIGINATOR_OVERRIDE=claworks
# HTTP-Referer sent to OpenRouter (replace with your public domain)
OPENCLAW_OPENROUTER_REFERER=https://ai.example.com
# X-OpenRouter-Title (defaults to OPENCLAW_ATTRIBUTION_PRODUCT_OVERRIDE if unset)
OPENCLAW_OPENROUTER_TITLE=ClaWorks
# User-Agent for gateway outbound media/URL fetch requests
OPENCLAW_GATEWAY_USER_AGENT=ClaWorks-Gateway/1.0
# Docs and source URL injected into agent system prompt (optional; omit to use defaults)
# OPENCLAW_DOCS_URL_OVERRIDE=https://docs.claworks.example.com
# OPENCLAW_SOURCE_URL_OVERRIDE=https://github.com/your-org/claworks

# ── ClaWorks Platform ────────────────────────────────────────────────────────
CLAWORKS_API_KEY=
DATABASE_URL=postgresql+asyncpg://claworks:claworks@127.0.0.1:5432/claworks

# TLS host paths (Docker compose volume sources)
TLS_CERT_HOST_PATH=/etc/letsencrypt/live/ai.example.com/fullchain.pem
TLS_KEY_HOST_PATH=/etc/letsencrypt/live/ai.example.com/privkey.pem

# Docker only: upstream service names (see docker-compose.yml)
# OPENCLAW_UPSTREAM=agent-runtime:18789
# CLAWORKS_UPSTREAM=host.docker.internal:8000
