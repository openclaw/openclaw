            "body": "🚨 CRITICAL SYSTEM ALERT\n\n{{input}}\n\n@channel Please investigate immediately!"
          }
        },
        {
          "id": "agent-3",
          "type": "action",
          "position": { "x": 1000, "y": 300 },
          "data": {
            "label": "AI Agent Prompt",
            "subline": "Ask an AI Agent",
            "icon": "🧠",
            "actionType": "agent-prompt",
            "prompt": "System status is normal. Create a brief summary for the daily log:\n\n1. Overall health status\n2. Any minor issues noted\n3. Performance metrics\n\nKeep it concise."
          }
        },
        {
          "id": "send-2",
          "type": "action",
