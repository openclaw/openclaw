{
  "workflows": [
    {
      "id": "wf-example-ifelse-1",
      "name": "Customer Support Auto-Response",
      "nodes": [
        {
          "id": "trigger-1",
          "type": "trigger",
          "position": { "x": 100, "y": 200 },
          "data": {
            "label": "Schedule (Cron)",
            "subline": "Run periodically",
            "icon": "⏱️",
            "cronExpr": "*/5 * * * *"
          }
        },
        {
          "id": "agent-1",
          "type": "action",
          "position": { "x": 400, "y": 200 },
          "data": {
            "label": "AI Agent Prompt",
            "subline": "Ask an AI Agent",
            "icon": "🧠",
            "actionType": "agent-prompt",
            "prompt": "Analyze this customer message and classify it as either 'urgent' or 'normal'. Urgent messages contain words like 'emergency', 'broken', 'not working', 'critical'. Normal messages are general inquiries. Respond with just the word 'urgent' or 'normal'."
          }
        },
        {
          "id": "if-else-1",
          "type": "logic",
          "position": { "x": 700, "y": 200 },
          "data": {
            "label": "If / Else",
            "subline": "Branch by condition",
            "icon": "🔀",
            "actionType": "if-else",
            "condition": "input.toLowerCase().includes('urgent')",
            "trueLabel": "Urgent",
            "falseLabel": "Normal"
          }
        },
        {
          "id": "agent-2",
          "type": "action",
          "position": { "x": 1000, "y": 100 },
          "data": {
            "label": "AI Agent Prompt",
            "subline": "Ask an AI Agent",
            "icon": "🧠",
            "actionType": "agent-prompt",
            "prompt": "This is an URGENT customer issue. Draft an immediate response that:\n1. Acknowledges the urgency\n2. Apologizes for the inconvenience\n3. Assures them we're prioritizing this\n4. Provides a ticket number: URGENT-{{new Date().getTime()}}\n5. Says someone will contact them within 1 hour\n\nKeep it professional and empathetic."
          }
        },
        {
          "id": "agent-3",
          "type": "action",
          "position": { "x": 1000, "y": 300 },
          "data": {
            "label": "AI Agent Prompt",
            "subline": "Ask an AI Agent",
            "icon": "🧠",
            "actionType": "agent-prompt",
            "prompt": "This is a NORMAL customer inquiry. Draft a friendly response that:\n1. Thanks them for reaching out\n2. Addresses their question helpfully\n3. Offers additional assistance\n4. Provides reference number: NORM-{{new Date().getTime()}}\n\nKeep it warm and professional."
          }
        },
        {
          "id": "send-1",
          "type": "action",
          "position": { "x": 1300, "y": 200 },
          "data": {
            "label": "Send Message",
            "subline": "Send via channel",
            "icon": "📤",
            "actionType": "send-message",
            "channel": "slack",
            "recipientId": "#customer-support",
            "body": "📨 Customer Response Generated:\n\n{{input}}\n\n---\nPlease review and send to customer."
          }
        }
      ],
      "edges": [
        {
          "id": "edge-1",
          "source": "trigger-1",
          "target": "agent-1",
          "type": "smoothstep"
        },
        {
          "id": "edge-2",
          "source": "agent-1",
          "target": "if-else-1",
          "type": "smoothstep"
        },
        {
          "id": "edge-3",
          "source": "if-else-1",
          "target": "agent-2",
          "sourceHandle": "true",
          "data": {
            "label": "true"
          },
          "type": "smoothstep",
          "label": "true"
        },
        {
          "id": "edge-4",
          "source": "if-else-1",
          "target": "agent-3",
          "sourceHandle": "false",
          "data": {
            "label": "false"
          },
          "type": "smoothstep",
          "label": "false"
        },
        {
          "id": "edge-5",
          "source": "agent-2",
          "target": "send-1",
          "type": "smoothstep"
        },
        {
          "id": "edge-6",
          "source": "agent-3",
          "target": "send-1",
          "type": "smoothstep"
        }
      ],
      "updatedAt": "2026-03-09T10:30:00.000Z",
