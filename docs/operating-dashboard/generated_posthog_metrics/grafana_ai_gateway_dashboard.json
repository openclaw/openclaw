            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "expr": "histogram_quantile(0.95, sum by(le)(rate(gateway_proxy_request_duration_seconds_bucket{namespace=~\"$namespace\", provider=~\"$provider\", model=~\"$model\"}[5m])))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "expr": "histogram_quantile(0.99, sum by(le)(rate(gateway_proxy_request_duration_seconds_bucket{namespace=~\"$namespace\", provider=~\"$provider\", model=~\"$model\"}[5m])))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
