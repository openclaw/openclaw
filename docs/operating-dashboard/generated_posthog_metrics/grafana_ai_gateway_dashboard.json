  "dashboard": {
    "description": "AI Gateway proxy metrics: request rate, latency, TTFB, token consumption, errors by provider/model",
    "id": 1,
    "panels": [
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineInterpolation": "smooth"
            },
            "unit": "reqps"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "id": 1,
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "expr": "sum(rate(gateway_proxy_requests_total{namespace=~\"$namespace\", provider=~\"$provider\", model=~\"$model\"}[5m]))",
            "legendFormat": "Total",
            "refId": "A"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "expr": "sum by(provider)(rate(gateway_proxy_requests_total{namespace=~\"$namespace\", provider=~\"$provider\", model=~\"$model\"}[5m]))",
            "legendFormat": "{{ provider }}",
            "refId": "B"
          }
        ],
        "title": "Request Rate",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 50
                },
                {
                  "color": "red",
                  "value": 100
                }
              ]
            }
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "id": 2,
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "expr": "sum(gateway_proxy_active_requests{namespace=~\"$namespace\", provider=~\"$provider\"})",
            "legendFormat": "Active",
            "refId": "A"
          }
        ],
        "title": "Active Requests",
        "type": "gauge"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "fieldConfig": {
          "defaults": {
            "max": 1,
            "min": 0,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.01
                },
                {
                  "color": "red",
                  "value": 0.05
                }
              ]
            },
            "unit": "percentunit"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "id": 3,
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "expr": "sum(rate(gateway_proxy_errors_total{namespace=~\"$namespace\", provider=~\"$provider\"}[5m])) / sum(rate(gateway_proxy_requests_total{namespace=~\"$namespace\", provider=~\"$provider\"}[5m]))",
            "legendFormat": "Error Rate",
            "refId": "A"
          }
        ],
        "title": "Error Rate",
        "type": "gauge"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "fieldConfig": {
          "defaults": {
